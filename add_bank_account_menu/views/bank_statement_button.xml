<odoo>
    <record id="view_bank_statement_line_kanban_inherit" model="ir.ui.view">
        <field name="name">bank.statement.line.kanban.inherit</field>
        <field name="model">account.bank.statement.line</field>

        <!-- ✅ CORRECT ID -->
        <field name="inherit_id" ref="base_accounting_kit.account_bank_statement_line_view_kanban"/>

        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="on_create">
                    account_reconcile_oca.action_bank_statement_line_create
                </attribute>
            </xpath>
        </field>
    </record>
</odoo>