<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Cost Price Protection Settings
         Own dedicated form - no inheritance, no XPath, guaranteed safe
         Access: Sales > Configuration > Cost Price Protection
         ============================================================ -->

    <record id="view_cost_price_protection_wizard" model="ir.ui.view">
        <field name="name">cost.price.protection.wizard.form</field>
        <field name="model">cost.price.protection.wizard</field>
        <field name="arch" type="xml">
            <form string="Cost Price Protection">
                <sheet>
                    <div class="oe_title">
                        <h1>Cost Price Protection</h1>
                        <p class="text-muted">
                            Configure rules to prevent selling products below their cost price.
                        </p>
                    </div>
                    <group string="Settings">
                        <group>
                            <field name="block_sale_below_cost"
                                   widget="boolean_toggle"/>
                            <field name="allow_manager_override"
                                   widget="boolean_toggle"
                                   invisible="not block_sale_below_cost"/>
                        </group>
                        <group>
                            <div invisible="not block_sale_below_cost" class="alert alert-info" role="alert">
                                <strong>Active:</strong> Orders with prices below cost will be blocked.
                            </div>
                            <div invisible="block_sale_below_cost" class="alert alert-warning" role="alert">
                                <strong>Inactive:</strong> No cost price checks are applied.
                            </div>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_save" type="object"
                            string="Save Settings" class="btn-primary"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cost_price_protection_wizard" model="ir.actions.act_window">
        <field name="name">Cost Price Protection</field>
        <field name="res_model">cost.price.protection.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_cost_price_protection"
              name="Cost Price Protection"
              parent="sale.menu_sale_config"
              action="action_cost_price_protection_wizard"
              sequence="99"
              groups="sales_team.group_sale_manager"/>

</odoo>
