<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Inject "Cost Price Protection" block into Sales Settings page.
         We anchor after the "Margins" setting (group_sale_margin field)
         which is clearly visible in the Pricing section of Sales Settings.
         ================================================================ -->

    <record id="res_config_settings_view_form_cost_block" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.cost.block</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- Target the setting box that contains group_sale_margin (Margins checkbox) -->
            <!-- This is visible in the Pricing section of Sales > Configuration > Settings -->
            <xpath expr="//field[@name='group_sale_margin']/.." position="after">
                <div class="o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="block_sale_below_cost"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="block_sale_below_cost"
                               string="Block Sales Below Cost Price"/>
                        <div class="text-muted">
                            Prevent confirming sales orders or POS orders when
                            any product is priced below its cost price.
                        </div>
                    </div>
                </div>
                <div class="o_setting_box" invisible="not block_sale_below_cost">
                    <div class="o_setting_left_pane">
                        <field name="allow_manager_override"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="allow_manager_override"
                               string="Allow Sales Manager Override"/>
                        <div class="text-muted">
                            Sales Managers can confirm orders even if priced below cost.
                        </div>
                    </div>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
