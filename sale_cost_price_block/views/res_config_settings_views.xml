<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_cost_block" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.cost.block</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="before">
                <app string="Cost Price Protection" name="sale_cost_price_block"
                     groups="base.group_system">
                    <block title="Cost Price Protection" name="cost_price_block_section">
                        <setting id="block_sale_below_cost" string="Block Sales Below Cost Price"
                                 help="Prevent confirming sales orders or POS orders when any product is priced below its cost price.">
                            <field name="block_sale_below_cost"/>
                            <div class="content-group" attrs="{'invisible': [('block_sale_below_cost', '=', False)]}">
                                <setting string="Allow Sales Manager Override"
                                         help="If enabled, users with the Sales Manager role can confirm orders even if a product is priced below cost.">
                                    <field name="allow_manager_override"/>
                                </setting>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
