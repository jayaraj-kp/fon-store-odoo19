<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        noupdate="1" means this record is only created ONCE on first install.
        On upgrade it will NOT be recreated. Duplicates were from previous
        installs - delete extras manually from Contacts.
    -->
    <record id="partner_cash_customer" model="res.partner">
        <field name="name">CASH CUSTOMER</field>
        <field name="customer_rank">1</field>
        <field name="is_cash_customer">True</field>
        <field name="active">True</field>
    </record>
</odoo>
