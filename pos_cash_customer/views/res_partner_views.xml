<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add is_cash_customer field to partner form (backend) -->
    <record id="view_partner_form_cash_customer" model="ir.ui.view">
        <field name="name">res.partner.form.cash.customer</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_cash_customer" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
