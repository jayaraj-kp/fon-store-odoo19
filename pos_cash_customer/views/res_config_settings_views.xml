<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_pos_cash_customer" model="ir.ui.view">
        <field name="name">res.config.settings.view.pos.cash.customer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!--
                Odoo 17+ / 18 / 19: The old div[hasclass('settings')] XPath no longer exists.
                The correct anchor is //form with position="inside".
                Settings are now structured with <app>, <block>, and <setting> tags.
            -->
            <xpath expr="//form" position="inside">
                <app string="POS Cash Customer"
                     name="pos_cash_customer"
                     data-string="POS Cash Customer">
                    <block title="Cash Customer">
                        <setting string="Cash Customer Partner"
                                 help="All new customers created in POS will be added as contacts under this partner. Leave empty to use the standard create customer form."
                                 id="pos_cash_customer_id_setting">
                            <field name="pos_cash_customer_id"
                                   placeholder="e.g. CASH CUSTOMER"
                                   options="{'no_open': True}"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>