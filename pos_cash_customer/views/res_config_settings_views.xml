<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_pos_cash_customer" model="ir.ui.view">
        <field name="name">res.config.settings.view.pos.cash.customer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='pos_connected_devices']" position="before">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane"/>
                    <div class="o_setting_right_pane">
                        <label for="pos_cash_customer_id" string="Cash Customer Partner"/>
                        <div class="text-muted">
                            All new customers created in POS will be added as contacts under this partner.
                            Leave empty to use the standard create customer form.
                        </div>
                        <div class="content-group mt8">
                            <div class="row mt4">
                                <field name="pos_cash_customer_id"
                                       class="col-lg-7"
                                       placeholder="e.g. CASH CUSTOMER"
                                       options="{'no_open': True}"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
