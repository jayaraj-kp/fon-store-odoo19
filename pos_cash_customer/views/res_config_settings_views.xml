<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_pos_cash_customer" model="ir.ui.view">
        <field name="name">res.config.settings.view.pos.cash.customer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!--
                Odoo 19: The o_settings_container xpath is unreliable because the POS settings
                view structure changed. We instead append our block inside the main <form>
                sheet, after the last existing <block> element, which is stable in Odoo 19.
            -->
            <xpath expr="//form/div[@class='settings']" position="inside">
                <app string="Cash Customer" name="pos_cash_customer">
                    <block title="Cash Customer">
                        <setting string="Cash Customer Partner"
                                 help="All new customers created in POS will be added as contacts under this partner. Leave empty to use the standard create customer form.">
                            <field name="pos_cash_customer_id"
                                   placeholder="e.g. CASH CUSTOMER"
                                   options="{'no_open': True}"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>