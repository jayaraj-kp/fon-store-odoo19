<?xml version="1.0" encoding="utf-8"?>
<templates>

    <t t-name="pos_cash_customer.CreateContactPopup" owl="1">
        <div class="create-contact-overlay">
            <div class="create-contact-popup">

                <!-- Header -->
                <div class="create-contact-header">
                    <span class="create-contact-title">
                        <i class="fa fa-user-plus"/>
                        Create Contact
                    </span>
                </div>

                <!-- Body -->
                <div class="create-contact-body">

                    <!-- Contact Type Tabs -->
                    <div class="contact-type-tabs">
                        <t t-foreach="['contact','invoice','delivery','other']" t-as="ctype" t-key="ctype">
                            <button t-att-class="getTabClass(ctype)"
                                    t-on-click="() => this.setContactType(ctype)">
                                <t t-if="ctype === 'contact'">Contact</t>
                                <t t-elif="ctype === 'invoice'">Invoice</t>
                                <t t-elif="ctype === 'delivery'">Delivery</t>
                                <t t-else="">Other</t>
                            </button>
                        </t>
                    </div>

                    <!-- Avatar + Name/Email/Phone -->
                    <div class="contact-name-row">
                        <div class="contact-avatar">
                            <i class="fa fa-user"/>
                        </div>
                        <div class="contact-fields">
                            <input class="input-name"
                                   type="text"
                                   placeholder="e.g. Brandon Freeman"
                                   t-model="state.name"/>
                            <div class="input-icon-row">
                                <i class="fa fa-envelope"/>
                                <input type="email" placeholder="Email" t-model="state.email"/>
                            </div>
                            <div class="input-icon-row">
                                <i class="fa fa-phone"/>
                                <input type="tel" placeholder="Phone" t-model="state.phone"/>
                            </div>
                        </div>
                    </div>

                    <!-- Address + GSTIN/Tags -->
                    <div class="contact-address-row">
                        <div class="address-block">
                            <label>Address</label>
                            <input type="text" placeholder="Street..." t-model="state.street"/>
                            <input type="text" placeholder="Street 2..." t-model="state.street2"/>
                            <div class="address-inline">
                                <input type="text" placeholder="City" t-model="state.city"/>
                                <input type="text" placeholder="ZIP" class="input-zip" t-model="state.zip"/>
                            </div>
                            <input type="text" placeholder="Country" t-model="state.country"/>
                        </div>
                        <div class="gstin-block">
                            <div class="gstin-field">
                                <label>GSTIN <span class="help-icon">?</span></label>
                                <input type="text" placeholder="e.g. 29ABCDE1234F1Z5" t-model="state.gstin"/>
                            </div>
                        </div>
                    </div>

                    <!-- Notes -->
                    <div class="notes-block">
                        <label class="notes-label">NOTES</label>
                        <textarea placeholder="Internal notes..." t-model="state.notes"/>
                    </div>

                    <!-- Error -->
                    <t t-if="state.error">
                        <div class="contact-error">
                            <i class="fa fa-exclamation-circle"/> <t t-esc="state.error"/>
                        </div>
                    </t>

                </div>

                <!-- Footer -->
                <div class="create-contact-footer">
                    <button class="btn-save-close"
                            t-att-disabled="state.saving"
                            t-on-click="saveAndClose">
                        <t t-if="state.saving"><i class="fa fa-spinner fa-spin"/></t>
                        Save &amp; Close
                    </button>
                    <button class="btn-save-new"
                            t-att-disabled="state.saving"
                            t-on-click="saveAndNew">
                        Save &amp; New
                    </button>
                    <button class="btn-discard" t-on-click="discard">
                        Discard
                    </button>
                </div>

            </div>
        </div>
    </t>

</templates>
