<?xml version="1.0" encoding="utf-8"?>
<templates>

    <!--
        Inherit the PartnerDetailsEdit template to show a notice
        that new customers will be saved under CASH CUSTOMER.
    -->
    <t t-name="pos_cash_customer.PartnerDetailsEditBanner" owl="1">
        <div class="cash-customer-banner">
            <span class="cash-customer-icon">👤</span>
            <span>
                This customer will be saved under
                <strong t-esc="cashCustomerName or 'CASH CUSTOMER'"/>
            </span>
        </div>
    </t>

</templates>
