<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- Standalone banner component — no xpath inheritance, no fragile selectors -->
    <t t-name="pos_cash_customer.CashCustomerBanner">
        <div t-if="cashCustomerName" class="cash-customer-banner">
            <span class="cash-customer-icon">👤</span>
            <span class="cash-customer-label">
                New contacts saved under: <strong t-esc="cashCustomerName"/>
            </span>
        </div>
    </t>

    <!-- Standalone parent-info row shown inside the create customer form -->
    <t t-name="pos_cash_customer.CashParentRow">
        <div t-if="cashCustomerName" class="cash-parent-row">
            <span class="cash-parent-icon">🏷️</span>
            <span class="cash-parent-text">
                Parent Account: <strong t-esc="cashCustomerName"/>
            </span>
            <span class="cash-parent-badge">Auto-assigned</span>
        </div>
    </t>

</templates>
