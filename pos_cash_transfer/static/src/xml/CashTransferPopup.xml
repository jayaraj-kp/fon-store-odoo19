<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Cash Transfer Button in POS Menu -->
    <t t-name="pos_cash_transfer.CashTransferButton">
        <button class="cash-transfer-btn" t-on-click="onClick">
            <i class="fa fa-exchange" />
            <span>Cash Transfer</span>
        </button>
    </t>

    <!-- Cash Transfer Popup -->
    <t t-name="pos_cash_transfer.CashTransferPopup">
        <div class="cash-transfer-popup popup">
            <div class="popup-header">
                <h3 class="popup-title">
                    <i class="fa fa-exchange me-2"/>
                    Cash Transfer Between Counters
                </h3>
            </div>

            <div class="popup-body">

                <!-- Loading State -->
                <t t-if="state.loading">
                    <div class="loading-state text-center py-4">
                        <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
                        <p class="mt-2">Loading open sessions...</p>
                    </div>
                </t>

                <!-- No Sessions Available -->
                <t t-elif="state.openSessions.length === 0">
                    <div class="alert alert-warning">
                        <i class="fa fa-warning me-2"/>
                        <strong>No other open POS sessions found!</strong>
                        <p class="mt-1 mb-0">
                            Please open another counter session first before transferring cash.
                        </p>
                    </div>
                </t>

                <!-- Transfer Form -->
                <t t-else="">
                    <div class="transfer-form">

                        <!-- From Counter (Read Only) -->
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">
                                <i class="fa fa-arrow-circle-right text-danger me-1"/>
                                Transfer FROM
                            </label>
                            <div class="from-counter-display">
                                <i class="fa fa-desktop me-2"/>
                                Current Counter (This POS)
                            </div>
                        </div>

                        <!-- To Counter Selection -->
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">
                                <i class="fa fa-arrow-circle-left text-success me-1"/>
                                Transfer TO Counter
                            </label>
                            <select
                                class="form-select transfer-select"
                                t-on-change="onSessionChange">
                                <t t-foreach="state.openSessions" t-as="session" t-key="session.id">
                                    <option t-att-value="session.id">
                                        <t t-esc="session.pos_name"/> - <t t-esc="session.cashier"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <!-- Amount -->
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">
                                <i class="fa fa-inr me-1"/>
                                Transfer Amount (₹)
                            </label>
                            <input
                                type="number"
                                class="form-control transfer-amount"
                                placeholder="Enter amount e.g. 5000"
                                t-att-value="state.amount"
                                t-on-input="onAmountChange"
                                min="1"
                                step="1"
                            />
                        </div>

                        <!-- Reason -->
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">
                                <i class="fa fa-pencil me-1"/>
                                Reason / Notes
                            </label>
                            <textarea
                                class="form-control"
                                placeholder="e.g. Counter 2 needs change, end of shift transfer..."
                                rows="2"
                                t-att-value="state.reason"
                                t-on-input="onReasonChange"
                            />
                        </div>

                        <!-- Summary Box -->
                        <t t-if="state.amount and parseFloat(state.amount) > 0">
                            <div class="transfer-summary">
                                <i class="fa fa-info-circle me-2"/>
                                <strong>₹ <t t-esc="parseFloat(state.amount).toFixed(2)"/></strong>
                                will be transferred to
                                <strong><t t-esc="getSelectedSessionName()"/></strong>
                            </div>
                        </t>

                        <!-- Error Message -->
                        <t t-if="state.error">
                            <div class="alert alert-danger mt-2">
                                <i class="fa fa-times-circle me-2"/>
                                <t t-esc="state.error"/>
                            </div>
                        </t>

                    </div>
                </t>
            </div>

            <!-- Footer Buttons -->
            <div class="popup-footer">
                <t t-if="state.openSessions.length > 0 and !state.loading">
                    <button
                        class="btn btn-primary btn-transfer"
                        t-on-click="confirm">
                        <i class="fa fa-exchange me-2"/>
                        Transfer Now
                    </button>
                </t>
                <button
                    class="btn btn-secondary btn-cancel"
                    t-on-click="cancel">
                    <i class="fa fa-times me-2"/>
                    Cancel
                </button>
            </div>
        </div>
    </t>

</templates>
