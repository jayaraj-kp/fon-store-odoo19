<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Cash Transfer Tree View -->
    <record id="view_pos_cash_transfer_tree" model="ir.ui.view">
        <field name="name">pos.cash.transfer.tree</field>
        <field name="model">pos.cash.transfer</field>
        <field name="arch" type="xml">
            <tree string="POS Cash Transfers"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'"
                  decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="transfer_date"/>
                <field name="from_pos_id"/>
                <field name="to_pos_id"/>
                <field name="amount"/>
                <field name="reason"/>
                <field name="cashier_id"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Cash Transfer Form View -->
    <record id="view_pos_cash_transfer_form" model="ir.ui.view">
        <field name="name">pos.cash.transfer.form</field>
        <field name="model">pos.cash.transfer</field>
        <field name="arch" type="xml">
            <form string="POS Cash Transfer">
                <header>
                    <button name="action_transfer"
                            string="Process Transfer"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Transfer Details">
                            <field name="from_session_id"
                                   domain="[('state','=','opened')]"/>
                            <field name="to_session_id"
                                   domain="[('state','=','opened')]"/>
                            <field name="amount"/>
                            <field name="transfer_date"/>
                        </group>
                        <group string="Other Info">
                            <field name="from_pos_id"/>
                            <field name="to_pos_id"/>
                            <field name="cashier_id"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" placeholder="Enter reason for transfer..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_pos_cash_transfer_search" model="ir.ui.view">
        <field name="name">pos.cash.transfer.search</field>
        <field name="model">pos.cash.transfer</field>
        <field name="arch" type="xml">
            <search string="Cash Transfers">
                <field name="name"/>
                <field name="from_pos_id"/>
                <field name="to_pos_id"/>
                <field name="cashier_id"/>
                <filter string="Done" name="done"
                        domain="[('state','=','done')]"/>
                <filter string="Draft" name="draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Today" name="today"
                        domain="[('transfer_date','&gt;=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter string="From Counter" name="from_pos"
                            context="{'group_by': 'from_pos_id'}"/>
                    <filter string="To Counter" name="to_pos"
                            context="{'group_by': 'to_pos_id'}"/>
                    <filter string="Date" name="date"
                            context="{'group_by': 'transfer_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pos_cash_transfer" model="ir.actions.act_window">
        <field name="name">Cash Transfers</field>
        <field name="res_model">pos.cash.transfer</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No cash transfers yet!
            </p>
            <p>Cash transfers between POS counters will appear here.</p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_pos_cash_transfer"
              name="Cash Transfers"
              parent="point_of_sale.menu_point_of_sale"
              action="action_pos_cash_transfer"
              sequence="25"/>

</odoo>
