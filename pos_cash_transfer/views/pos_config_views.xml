<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend POS Configuration Settings -->
    <record id="view_pos_config_form_cash_transfer" model="ir.ui.view">
        <field name="name">pos.config.form.cash.transfer</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='pos_features']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="allow_cash_transfer"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="allow_cash_transfer"
                               string="Cash Transfer Between Counters"/>
                        <div class="text-muted">
                            Allow transferring cash from this POS to another open POS session
                        </div>
                        <div class="content-group" invisible="not allow_cash_transfer">
                            <div class="row mt-2">
                                <field name="cash_transfer_requires_manager"/>
                                <label for="cash_transfer_requires_manager"
                                       string="Require Manager Approval"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
