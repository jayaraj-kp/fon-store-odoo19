<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!--
        Extend the TicketScreen OWL template (Odoo 19 CE).

        Odoo 19 changed the search dropdown structure slightly.
        The XPath targets the <ul> that holds the search-field autocomplete
        items and appends a new <li> for "Product".

        onClickSearchField('PRODUCT') is the correct handler in Odoo 19.
        It sets { fieldName: 'PRODUCT', searchTerm: <input value> }
        which is then passed into the filter methods patched in the JS file.
    -->
    <t t-inherit="point_of_sale.TicketScreen" t-inherit-mode="extension">
        <xpath expr="//ul[hasclass('py-1')]" position="inside">
            <li
                t-if="inputRef.el and inputRef.el.value"
                class="ps-5 py-1 text-start cursor-pointer"
                t-on-click="() => onClickSearchField('PRODUCT')"
            >
                <span class="field" t-esc="env._t('Product')"/>
                <span>: </span>
                <span class="term text-primary fw-bolder" t-esc="state.searchInput"/>
            </li>
        </xpath>
    </t>
</templates>