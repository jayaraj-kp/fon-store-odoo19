<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_order_search_extended" model="ir.ui.view">
        <field name="name">pos.order.search.extended</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">

                <!-- Mobile / Phone — direct char field on pos.order -->
                <field name="mobile" string="Phone / Mobile"/>

                <!-- Bill Amount — monetary field on pos.order -->
                <field name="amount_total" string="Bill Amount"/>

                <separator/>

                <filter string="Cash Orders"
                        name="filter_cash"
                        domain="[('payment_ids.payment_method_id.is_cash_count','=',True)]"/>

                <filter string="Card Orders"
                        name="filter_card"
                        domain="[('payment_ids.payment_method_id.is_cash_count','=',False)]"/>

                <separator/>

                <group expand="0" string="Group By">
                    <filter string="Customer"
                            name="groupby_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Date"
                            name="groupby_date"
                            context="{'group_by': 'date_order:day'}"/>
                    <filter string="Session"
                            name="groupby_session"
                            context="{'group_by': 'session_id'}"/>
                    <filter string="State"
                            name="groupby_state"
                            context="{'group_by': 'state'}"/>
                </group>

            </xpath>
        </field>
    </record>
</odoo>