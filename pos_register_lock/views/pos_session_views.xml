<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Unlock button and lock alert to POS Session form -->
    <record id="view_pos_session_form_lock" model="ir.ui.view">
        <field name="name">pos.session.form.register.lock</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_unlock_register"
                    string="🔓 Unlock Register"
                    type="object"
                    class="btn-warning"
                    invisible="not register_locked"
                    groups="point_of_sale.group_pos_manager"
                    confirm="Are you sure you want to unlock this register? The cashier will be able to continue."
                />
            </xpath>
            <xpath expr="//sheet" position="before">
                <div
                    class="alert alert-danger"
                    role="alert"
                    invisible="not register_locked"
                    style="margin: 8px 16px 0 16px; font-size: 15px;">
                    <strong>⚠️ Register is LOCKED</strong> —
                    Locked by <field name="locked_by_id" readonly="1" nolabel="1"/>
                    at <field name="locked_at" readonly="1" nolabel="1"/>.
                    Click <strong>Unlock Register</strong> above to allow the cashier to proceed.
                </div>
            </xpath>
        </field>
    </record>

</odoo>
