<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Patch Navbar to add Lock Register in the burger dropdown menu -->
    <t t-name="pos_register_lock.NavbarPatch"
       t-inherit="point_of_sale.Navbar"
       t-inherit-mode="extension">
        <xpath expr="//DropdownItem[last()]" position="before">
            <DropdownItem onSelected="() => this.lockRegister()">
                🔒 Lock Register
            </DropdownItem>
        </xpath>
    </t>

    <!-- Patch Chrome to show full-screen lock overlay -->
    <t t-name="pos_register_lock.ChromePatch"
       t-inherit="point_of_sale.Chrome"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos')]" position="inside">
            <t t-if="registerLockState and registerLockState.locked">
                <div style="
                    position:fixed; top:0; left:0; right:0; bottom:0;
                    background:rgba(15,15,15,0.97);
                    z-index:99999;
                    display:flex; flex-direction:column;
                    align-items:center; justify-content:center;
                    color:white; text-align:center;
                    font-family:sans-serif; user-select:none;
                    pointer-events:all;
                ">
                    <div style="font-size:90px; margin-bottom:20px;">🔒</div>
                    <div style="font-size:34px; font-weight:bold; color:#f0c040; margin-bottom:14px;">
                        Register Locked
                    </div>
                    <div style="font-size:17px; color:#ccc; max-width:480px; line-height:1.8;">
                        This register is locked for manager review.<br/>
                        Ask your <strong style="color:#f0c040;">manager</strong> to open Odoo backend,<br/>
                        go to <strong>Point of Sale → Sessions</strong>,<br/>
                        open this session and click <strong>🔓 Unlock Register</strong>.
                    </div>
                    <div style="margin-top:32px; font-size:13px; color:#555;">
                        Checking for unlock every 5 seconds...
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>
