<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        Patch Chrome to show a full-screen lock overlay when the register is locked.
        Shown after cashier clicks Close Register (auto-lock).
        Disappears automatically when manager unlocks from backend (polling every 5s).
    -->
    <t t-name="pos_register_lock.ChromePatch"
       t-inherit="point_of_sale.Chrome"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos')]" position="inside">
            <t t-if="registerLockState and registerLockState.locked">
                <div style="
                    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
                    background: rgba(15,15,15,0.97);
                    z-index: 99999;
                    display: flex; flex-direction: column;
                    align-items: center; justify-content: center;
                    color: white; text-align: center;
                    font-family: sans-serif; user-select: none;
                    pointer-events: all;
                ">
                    <div style="font-size: 80px; margin-bottom: 16px;">&#128274;</div>
                    <div style="font-size: 30px; font-weight: bold; color: #f0c040; margin-bottom: 12px;">
                        Register Locked for Manager Review
                    </div>
                    <div style="font-size: 16px; color: #ddd; max-width: 520px; line-height: 1.9;">
                        The closing amounts have been recorded and locked.<br/>
                        Your manager must review the
                        <strong style="color:#f0c040;">excess / short</strong> amounts<br/>
                        and click <strong style="color:#f0c040;">&#128275; Unlock Register</strong> to allow closing.
                    </div>
                    <div style="
                        margin-top: 28px;
                        background: rgba(255,255,255,0.07);
                        border-radius: 10px;
                        padding: 14px 30px;
                        font-size: 14px;
                        color: #bbb;
                        line-height: 1.8;
                    ">
                        Manager path:<br/>
                        <strong style="color: #eee;">
                            Point of Sale &#8594; Sessions &#8594; Open this session &#8594; Unlock Register
                        </strong>
                    </div>
                    <div style="margin-top: 20px; font-size: 12px; color: #555;">
                        Checking for unlock every 5 seconds...
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>
