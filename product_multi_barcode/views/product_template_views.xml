<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_multi_barcode" model="ir.ui.view">
        <field name="name">product.template.form.multi.barcode</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Append BEFORE internal notes - this xpath always exists in all Odoo versions -->
            <xpath expr="//div[@name='internal_notes_tab']" position="before">

                <separator string="─── Additional Barcodes &amp; Packaging ───"/>

                <group col="4" colspan="4">
                    <group string="📦 Pack 2 (e.g. Dozen)">
                        <field name="barcode_2"
                               string="Barcode 2"
                               placeholder="e.g. 8901234560002"/>
                        <field name="package_qty_2"
                               string="Qty in Pack 2"
                               placeholder="e.g. 12"/>
                        <field name="package_name_2"
                               string="Pack 2 Name"
                               placeholder="e.g. Dozen"/>
                    </group>
                    <group string="🏭 Pack 3 (e.g. Big Carton)">
                        <field name="barcode_3"
                               string="Barcode 3"
                               placeholder="e.g. 8901234560003"/>
                        <field name="package_qty_3"
                               string="Qty in Pack 3"
                               placeholder="e.g. 120"/>
                        <field name="package_name_3"
                               string="Pack 3 Name"
                               placeholder="e.g. Big Carton"/>
                    </group>
                </group>

                <group col="1" colspan="4">
                    <div colspan="1" style="background:#f0f8ff; border:1px solid #b8daff; border-radius:4px; padding:8px; color:#004085; font-size:12px;">
                        <strong>💡 How it works:</strong>
                        Scan <b>Barcode 2</b> in POS → adds <b>Pack 2 Qty</b> units automatically.
                        Scan <b>Barcode 3</b> → adds <b>Pack 3 Qty</b> units automatically.
                        Leave blank if not needed.
                    </div>
                </group>

            </xpath>

        </field>
    </record>

</odoo>
