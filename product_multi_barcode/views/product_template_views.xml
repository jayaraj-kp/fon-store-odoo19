<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_multi_barcode" model="ir.ui.view">
        <field name="name">product.template.form.multi.barcode</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Confirmed from architecture: group_standard_price exists -->
            <xpath expr="//group[@name='group_standard_price']" position="after">
                <group string="Additional Barcodes and Packaging" name="multi_barcode_group">
                    <group string="Pack 2 eg Dozen" name="pack2_group">
                        <field name="barcode_2" string="Barcode 2" placeholder="e.g. 8901234560002"/>
                        <field name="package_qty_2" string="Qty in Pack 2" placeholder="e.g. 12"/>
                        <field name="package_name_2" string="Pack 2 Name" placeholder="e.g. Dozen"/>
                    </group>
                    <group string="Pack 3 eg Big Carton" name="pack3_group">
                        <field name="barcode_3" string="Barcode 3" placeholder="e.g. 8901234560003"/>
                        <field name="package_qty_3" string="Qty in Pack 3" placeholder="e.g. 120"/>
                        <field name="package_name_3" string="Pack 3 Name" placeholder="e.g. Big Carton"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
