<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_multi_barcode" model="ir.ui.view">
        <field name="name">product.template.form.multi.barcode</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Place our fields inside General Information tab, at the bottom -->
            <xpath expr="//page[@name='general_information']//group[last()]" position="after">
                <separator string="Additional Barcodes &amp; Packaging"/>
                <group col="4">
                    <group string="Pack 2 (e.g. Dozen)">
                        <field name="barcode_2" placeholder="Scan or type barcode 2"/>
                        <field name="package_qty_2" placeholder="e.g. 12"/>
                        <field name="package_name_2" placeholder="e.g. Dozen"/>
                    </group>
                    <group string="Pack 3 (e.g. Big Carton)">
                        <field name="barcode_3" placeholder="Scan or type barcode 3"/>
                        <field name="package_qty_3" placeholder="e.g. 120"/>
                        <field name="package_name_3" placeholder="e.g. Big Carton"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
