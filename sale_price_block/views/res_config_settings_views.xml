<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_sale_price_block" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.sale.price.block</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <!--
                    Adds a toggle under Sales > Configuration > Settings
                    to enable or disable the below-cost price block.
                -->
                <xpath expr="//div[@id='sale_settings']" position="inside">
                    <div class="col-12 col-lg-6 o_setting_box" id="block_sale_below_cost_box">
                        <div class="o_setting_left_pane">
                            <field name="block_sale_below_cost" widget="boolean_toggle"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="block_sale_below_cost" string="Block Sale Below Cost Price"/>
                            <div class="text-muted mt-1">
                                Prevent confirming a sale order if any product's
                                unit price is lower than its cost price.
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
