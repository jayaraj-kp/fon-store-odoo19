<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_sale_price_block" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.sale.price.block</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <!--
                    Adds a new block with a toggle under Sales > Configuration > Settings
                    to enable or disable the below-cost price block.
                -->
                <xpath expr="//app[@name='sale_management']" position="inside">
                    <block title="Sale Price Controls" name="sale_price_block_settings">
                        <setting id="block_below_cost" help="Prevent confirming sale orders when product unit price is below cost price">
                            <field name="block_sale_below_cost" widget="boolean_toggle"/>
                            <label for="block_sale_below_cost" string="Block Sale Below Cost Price"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>