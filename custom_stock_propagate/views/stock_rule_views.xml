<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_rule_propagate_form" model="ir.ui.view">
        <field name="name">stock.rule.propagate.form</field>
        <field name="model">stock.rule</field>
        <field name="inherit_id" ref="stock.view_stock_rule_form"/>
        <field name="arch" type="xml">

            <!-- Add PROPAGATION section before OPTIONS section using propagate_cancel anchor -->
            <xpath expr="//field[@name='propagate_cancel']" position="before">
                <separator string="PROPAGATION"/>
                <field name="group_propagation_option" string="Propagation of Procurement Group"
                       invisible="action == 'push'"/>
            </xpath>

            <!-- Add remaining propagation fields after propagate_cancel -->
            <xpath expr="//field[@name='propagate_cancel']" position="after">
                <field name="propagate_carrier" string="Propagate Carrier"
                       invisible="action == 'push'"/>
                <field name="propagate_warehouse_id" string="Warehouse to Propagate"
                       invisible="action == 'push'"/>
            </xpath>

        </field>
    </record>

</odoo>
