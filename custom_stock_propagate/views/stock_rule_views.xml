<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit the stock rule form view to add Propagation section -->
    <record id="view_stock_rule_propagate_form" model="ir.ui.view">
        <field name="name">stock.rule.propagate.form</field>
        <field name="model">stock.rule</field>
        <field name="inherit_id" ref="stock.view_stock_rule_form"/>
        <field name="arch" type="xml">

            <!-- Append propagation fields after Lead Time (delay) field -->
            <xpath expr="//field[@name='delay']" position="after">
                <field name="propagate_carrier" string="Propagate Carrier"/>
                <field name="propagate_warehouse_id" string="Warehouse to Propagate"/>
            </xpath>

        </field>
    </record>

</odoo>
