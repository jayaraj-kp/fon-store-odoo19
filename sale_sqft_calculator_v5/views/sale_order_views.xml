<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         INHERIT: sale.order  (the main quotation/order form)
         Goal: Add a 📐 calculator button column immediately after the
               "Product" column in the order lines editable list.
         Fix:  We target product_uom_qty (Quantity field) and insert
               BEFORE it — this reliably places the button right after
               the product name column in Odoo 19 CE list views.
    ================================================================ -->
    <record id="view_sale_order_form_sqft_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.sqft.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']"
                   position="before">
                <button
                    name="action_open_sqft_wizard"
                    type="object"
                    icon="fa-calculator"
                    title="Sq.Ft Calculator (Alt+C to apply)"
                    string=""
                    class="btn btn-sm btn-link text-primary"
                    invisible="not product_id"
                />
            </xpath>

        </field>
    </record>

</odoo>
