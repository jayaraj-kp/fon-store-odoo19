<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_line_view_fix" model="ir.ui.view">
        <field name="name">sale.order.line.open.form.fix</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list[@string='Sales Order Lines']" position="attributes">
                <attribute name="open_form_view">True</attribute>
            </xpath>
        </field>
    </record>
</odoo>
