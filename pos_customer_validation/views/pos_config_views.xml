<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="pos_config_customer_validation_view" model="ir.ui.view">
            <field name="name">POS Config - Customer Validation</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Customer Validation">
                        <group>
                            <field name="require_customer_for_payment" />
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
