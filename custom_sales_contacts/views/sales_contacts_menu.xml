<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Action: Opens res.partner list filtered to contacts
        whose parent (company) name is "Cash Customer"
    -->
    <record id="action_sales_cash_customer_contacts" model="ir.actions.act_window">
        <field name="name">Contacts</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('parent_id.name', '=', 'Cash Customer')]</field>
        <field name="context">{
            'default_parent_id': False,
            'search_default_customer': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No contacts found under Cash Customer!
            </p>
            <p>
                Contacts listed here are child contacts of the
                <strong>Cash Customer</strong> parent partner.
            </p>
        </field>
    </record>

    <!--
        Menu Item: Sales > Orders > Contacts
        parent="sale.menu_sale_order" places this under the "Orders" submenu
    -->
    <menuitem
        id="menu_sales_cash_customer_contacts"
        name="Contacts"
        parent="sale.menu_sale_order"
        action="action_sales_cash_customer_contacts"
        sequence="30"/>

</odoo>
