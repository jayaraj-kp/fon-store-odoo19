<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===========================
         SALE ORDER RESTRICTION
         =========================== -->
    <record id="rule_sale_order_warehouse_restriction" model="ir.rule">
        <field name="name">Sale Order: Allowed Warehouses Restriction</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">
            ['|',
                ('warehouse_id', 'in', user.allowed_warehouse_ids.ids or [False]),
                ('warehouse_id', '=', False)
            ] if user.allowed_warehouse_ids else [(1, '=', 1)]
        </field>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ===========================
         PURCHASE ORDER RESTRICTION
         =========================== -->
    <record id="rule_purchase_order_warehouse_restriction" model="ir.rule">
        <field name="name">Purchase Order: Allowed Warehouses Restriction</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="domain_force">
            ['|',
                ('picking_type_id.warehouse_id', 'in', user.allowed_warehouse_ids.ids or [False]),
                ('picking_type_id.warehouse_id', '=', False)
            ] if user.allowed_warehouse_ids else [(1, '=', 1)]
        </field>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ===========================
         STOCK PICKING RESTRICTION
         =========================== -->
    <record id="rule_stock_picking_warehouse_restriction" model="ir.rule">
        <field name="name">Stock Picking: Allowed Warehouses Restriction</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">
            ['|',
                ('picking_type_id.warehouse_id', 'in', user.allowed_warehouse_ids.ids or [False]),
                ('picking_type_id.warehouse_id', '=', False)
            ] if user.allowed_warehouse_ids else [(1, '=', 1)]
        </field>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ===========================
         STOCK QUANT (Inventory) RESTRICTION
         =========================== -->
    <record id="rule_stock_quant_warehouse_restriction" model="ir.rule">
        <field name="name">Stock Quant: Allowed Warehouses Restriction</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="domain_force">
            ['|',
                ('warehouse_id', 'in', user.allowed_warehouse_ids.ids or [False]),
                ('warehouse_id', '=', False)
            ] if user.allowed_warehouse_ids else [(1, '=', 1)]
        </field>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ===========================
         PRODUCT TEMPLATE: Disallowed Category Restriction
         =========================== -->
    <record id="rule_product_template_category_restriction" model="ir.rule">
        <field name="name">Product Template: Disallowed Category Restriction</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="domain_force">[('categ_id', 'not in', user.disallowed_product_category_ids.ids)] if user.disallowed_product_category_ids else [(1, '=', 1)]</field>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ===========================
         PRODUCT PRODUCT: Disallowed Category Restriction
         =========================== -->
    <record id="rule_product_product_category_restriction" model="ir.rule">
        <field name="name">Product Product: Disallowed Category Restriction</field>
        <field name="model_id" ref="product.model_product_product"/>
        <field name="domain_force">[('categ_id', 'not in', user.disallowed_product_category_ids.ids)] if user.disallowed_product_category_ids else [(1, '=', 1)]</field>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>




