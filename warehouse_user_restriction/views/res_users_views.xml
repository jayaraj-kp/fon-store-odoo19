<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =============================================
         User Form: Allowed Warehouses + Default Customer Tags
         ============================================= -->
    <record id="view_users_form_warehouse_restriction" model="ir.ui.view">
        <field name="name">res.users.form.warehouse.restriction</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml" >
            <xpath expr="//page[@name='access_rights']/group[1]" position="before">
                <group string="Warehouse Restrictions">
                    <field name="allowed_warehouse_ids"
                           widget="many2many_tags"
                           options="{'no_create': True}"
                           placeholder="Leave empty = access to all warehouses" />
                    <field name="property_warehouse_id"
                           options="{'no_create': True}"
                           placeholder="Default warehouse for this user" />
                </group>
                <group string="Customer Defaults">
                    <field name="default_customer_tag_ids"
                           widget="many2many_tags"
                           options="{'no_create': False}"
                           placeholder="Tags auto-applied to every new customer this user creates"/>
                </group>
                <group string="Product Category Restrictions">
                    <field name="disallowed_product_category_ids"
                           widget="many2many_tags"
                           options="{'no_create': True}"
                           placeholder="Leave empty = access to all product categories"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- =============================================
         Sale Order Form: Filter warehouse dropdown
         ============================================= -->
    <record id="view_sale_order_warehouse_restriction" model="ir.ui.view">
        <field name="name">sale.order.form.warehouse.restriction</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='warehouse_id']" position="before">
                <field name="allowed_warehouse_domain" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='warehouse_id']" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_warehouse_domain)]</attribute>
            </xpath>
        </field>
    </record>

    <!-- =============================================
         Stock Picking Form: Filter operation type and locations
         ============================================= -->
    <record id="view_stock_picking_warehouse_restriction" model="ir.ui.view">
        <field name="name">stock.picking.form.warehouse.restriction</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_type_id']" position="before">
                <field name="allowed_warehouse_domain" invisible="1"/>
                <field name="allowed_location_domain" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='picking_type_id']" position="attributes">
                <attribute name="domain">[('warehouse_id', 'in', allowed_warehouse_domain)]</attribute>
            </xpath>
            <xpath expr="//field[@name='location_id']" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_location_domain)]</attribute>
            </xpath>
            <xpath expr="//field[@name='location_dest_id']" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_location_domain)]</attribute>
            </xpath>
        </field>
    </record>

</odoo>




