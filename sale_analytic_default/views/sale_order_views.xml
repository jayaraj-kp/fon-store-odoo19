<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Make Analytic Distribution ALWAYS VISIBLE in Sale Order Lines
         Odoo 19 CE
         
         Two strategies used together for maximum compatibility:
         1. XPath on the embedded list inside order_line
         2. Direct override of sale.order.line list view
    ============================================================ -->

    <!-- Strategy 1: Target the field inside the form's embedded list -->
    <record id="view_order_form_analytic_always_visible" model="ir.ui.view">
        <field name="name">sale.order.form.analytic.always.visible</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <!-- Remove optional attribute so column is always shown -->
            <xpath expr="//field[@name='order_line']//field[@name='analytic_distribution']" position="attributes">
                <attribute name="optional"/>
            </xpath>

        </field>
    </record>

    <!-- Note: sale.view_order_line_tree_with_onchange was removed in Odoo 19.
         The Python _get_view() override in models/sale_order_line.py handles
         the runtime removal of the optional attribute instead. -->

</odoo>
