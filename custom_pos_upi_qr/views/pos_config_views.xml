<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_config_form_upi_qr" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos.upi.qr</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- Anchor on the "Need an invoice?" QR block (line 337 confirmed in source) -->
            <xpath expr="//setting[@id='pos_use_ticket_qr_code']" position="after">

                <setting id="pos_upi_qr_on_receipt"
                         string="UPI QR Code on Receipt"
                         help="Print a dynamic UPI QR code on each receipt — customers scan with GPay, PhonePe, Paytm etc. and the exact amount is pre-filled automatically.">
                    <field name="pos_upi_qr_on_receipt"/>
                    <div class="content-group mt16" invisible="not pos_upi_qr_on_receipt">
                        <div class="row">
                            <label for="pos_upi_vpa" class="col-lg-3 o_light_label" string="UPI ID (VPA)"/>
                            <div class="col-lg-9">
                                <field name="pos_upi_vpa"
                                       placeholder="e.g. yourstore@paytm or 9876543210@ybl"/>
                            </div>
                        </div>
                        <div class="row mt4">
                            <label for="pos_upi_merchant_name" class="col-lg-3 o_light_label" string="Merchant Name"/>
                            <div class="col-lg-9">
                                <field name="pos_upi_merchant_name"
                                       placeholder="Name shown on customer's UPI app"/>
                            </div>
                        </div>
                    </div>
                </setting>

            </xpath>

        </field>
    </record>
</odoo>
