<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_config_form_upi_qr" model="ir.ui.view">
        <field name="name">pos.config.form.upi.qr</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">

            <!--
                Anchor on the 'qr_code_at_bottom' field (the "Need an invoice?" QR toggle).
                This field is confirmed present in Odoo 19 CE since it already shows on the receipt.
                We add our UPI QR settings block directly after it.
            -->
            <xpath expr="//field[@name='qr_code_at_bottom']" position="after">

                <!-- UPI QR toggle -->
                <field name="upi_qr_on_receipt" widget="boolean_toggle"/>
                <label for="upi_qr_on_receipt" string="UPI QR Code on Receipt"/>

                <!-- UPI sub-fields, shown only when the toggle is ON -->
                <div invisible="not upi_qr_on_receipt" class="ms-3 mt4">
                    <label for="upi_vpa" string="UPI ID (VPA)"/>
                    <field name="upi_vpa"
                           placeholder="e.g. yourstore@paytm or 9876543210@ybl"/>
                    <label for="upi_merchant_name" string="Merchant Name (shown on UPI app)"/>
                    <field name="upi_merchant_name"
                           placeholder="Name customers see when they scan"/>
                </div>

            </xpath>

        </field>
    </record>
</odoo>
