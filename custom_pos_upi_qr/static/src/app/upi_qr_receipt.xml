<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <!--
        The UPI QR block is now rendered inside custom_pos_receipt's custom_receipt.xml
        inside the .receipt-qr-row (right cell), using the same upiQrSrc / upiAmount / upiVpa
        getters from upi_qr_receipt.js.

        This file intentionally renders nothing on its own to avoid a duplicate QR block.
        The JS patch (upi_qr_receipt.js) still runs and provides the getter properties
        to the OrderReceipt component, which custom_receipt.xml consumes directly.
    -->
    <t t-name="custom_pos_upi_qr.UpiQrBlock"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">
        <!-- No xpath here — layout is owned by custom_pos_receipt/custom_receipt.xml -->
    </t>
</templates>



