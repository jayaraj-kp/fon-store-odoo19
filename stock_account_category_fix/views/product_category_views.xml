<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_category_form_view_stock_account_fix" model="ir.ui.view">
            <field name="name">product.category.form.stock.account.fix</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="product.product_category_form_view"/>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group name="account_stock_properties" string="Account Stock Properties" invisible="property_valuation != 'real_time'">
                        <field name="property_stock_valuation_account_id"/>
                        <field name="property_stock_journal"/>
                        <field name="property_stock_account_input_categ_id"/>
                        <field name="property_stock_account_output_categ_id"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
