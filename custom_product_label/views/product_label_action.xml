<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Add Instagram Handle to Product Template Form -->
    <record id="view_product_template_form_instagram" model="ir.ui.view">
        <field name="name">product.template.form.instagram</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="instagram_handle"
                       string="Instagram Handle"
                       placeholder="@yourshop or https://instagram.com/yourshop"/>
            </xpath>
        </field>
    </record>

    <!-- Add Instagram Handle to Company Settings -->
    <record id="view_res_company_form_instagram" model="ir.ui.view">
        <field name="name">res.company.form.instagram</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='phone']" position="after">
                <field name="instagram_handle"
                       string="Instagram Handle (for labels)"
                       placeholder="@yourshop"/>
            </xpath>
        </field>
    </record>

    <!-- Server Action for product.product (list + form) -->
    <record id="action_server_print_fon_label" model="ir.actions.server">
        <field name="name">Print FON Label 50x25mm</field>
        <field name="model_id" ref="product.model_product_product"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.report',
    'report_name': 'custom_product_label.report_fon_label',
    'report_type': 'qweb-pdf',
    'context': {'active_ids': records.ids},
}
        </field>
    </record>

    <!-- Server Action for product.template (POS view) -->
    <record id="action_server_print_fon_label_tmpl" model="ir.actions.server">
        <field name="name">Print FON Label 50x25mm</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
products = records.product_variant_ids
action = {
    'type': 'ir.actions.report',
    'report_name': 'custom_product_label.report_fon_label',
    'report_type': 'qweb-pdf',
    'context': {'active_ids': products.ids},
}
        </field>
    </record>

</odoo>
