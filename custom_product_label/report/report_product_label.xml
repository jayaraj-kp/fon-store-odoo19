<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="paperformat_label_50x25" model="report.paperformat">
        <field name="name">Label 50x25mm Roll</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">25</field>
        <field name="page_width">50</field>
        <field name="orientation">Landscape</field>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_custom_product_label" model="ir.actions.report">
        <field name="name">Custom Product Label 50x25</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_product_label.report_product_label_template</field>
        <field name="report_file">custom_product_label.report_product_label_template</field>
        <field name="paperformat_id" ref="paperformat_label_50x25"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_product_label_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-set="barcode_img" t-value="product.get_barcode_image_b64()"/>
                <t t-set="qr_img" t-value="product.get_instagram_qr_b64()"/>
                <t t-set="logo_b64" t-value="product.get_company_logo_b64()"/>

                <!--
                    PAGE IS 50mm x 25mm with 0 margins = full usable area
                    All images are base64 embedded - no network calls needed
                    Layout:
                    ┌───────┬──────────────────────────┬───────┐
                    │       │  Product Name       MRP  │       │
                    │  LOGO │                          │  QR   │
                    │       │  ▐▌▐▐▌▌▐▌ (barcode)     │       │
                    └───────┴──────────────────────────┴───────┘
                -->
                <div style="width:100%; height:100vh; display:flex; flex-direction:row; overflow:hidden; background:#fff; box-sizing:border-box; page-break-after:always; border:0.4px solid #000;">

                    <!-- LEFT: Logo B&amp;W vertical -->
                    <div style="width:14%; min-width:14%; height:100%; display:flex; align-items:center; justify-content:center; border-right:0.4px solid #000; overflow:hidden; padding:1%; box-sizing:border-box; flex-shrink:0;">
                        <t t-if="logo_b64">
                            <img t-att-src="'data:image/png;base64,' + logo_b64"
                                 style="max-width:100%; max-height:80%; object-fit:contain; filter:grayscale(100%) contrast(1.3); transform:rotate(-90deg);"
                                 alt=""/>
                        </t>
                    </div>

                    <!-- CENTER: Name + Barcode -->
                    <div style="flex:1; display:flex; flex-direction:column; height:100%; padding:3% 2% 2% 3%; box-sizing:border-box; overflow:hidden;">

                        <!-- TOP: Item name left, MRP right -->
                        <div style="display:flex; flex-direction:row; align-items:flex-start; justify-content:space-between; flex-shrink:0; overflow:hidden; height:38%;">
                            <div style="flex:1; font-family:'Arial Narrow',Arial,sans-serif; font-size:7pt; font-weight:bold; line-height:1.25; color:#000; word-break:break-word; overflow:hidden; padding-right:2%;">
                                <t t-esc="product.name"/>
                                <t t-if="product.product_template_attribute_value_ids">
                                    <br/>
                                    <span style="font-size:5pt; font-weight:normal;">
                                        <t t-esc="', '.join(product.product_template_attribute_value_ids.mapped('name'))"/>
                                    </span>
                                </t>
                            </div>
                            <div style="text-align:right; flex-shrink:0; white-space:nowrap;">
                                <span style="font-size:4.5pt; font-weight:bold; display:block; line-height:1.1; font-family:Arial,sans-serif;">MRP</span>
                                <span style="font-size:7pt; font-weight:bold; display:block; line-height:1.2; font-family:Arial,sans-serif;">
                                    <t t-esc="product.get_label_price()"/>
                                </span>
                            </div>
                        </div>

                        <!-- SPACER -->
                        <div style="flex:1;"/>

                        <!-- BOTTOM: Barcode centered, no number -->
                        <div style="display:flex; align-items:flex-end; justify-content:center; height:56%; overflow:hidden;">
                            <t t-if="barcode_img">
                                <img t-att-src="'data:image/png;base64,' + barcode_img"
                                     style="max-width:100%; max-height:95%; object-fit:contain;"
                                     alt=""/>
                            </t>
                            <t t-elif="product.barcode">
                                <!-- fallback text barcode if library not installed -->
                                <div style="text-align:center; font-family:monospace; font-size:5pt; letter-spacing:1px; color:#000;">
                                    <div style="font-size:18pt; letter-spacing:-1px; line-height:1;">
                                        <t t-esc="product.barcode"/>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <span style="font-size:4pt; color:#aaa; font-family:Arial,sans-serif;">No Barcode</span>
                            </t>
                        </div>

                    </div>

                    <!-- RIGHT: Instagram QR -->
                    <div style="width:22%; min-width:22%; height:100%; display:flex; align-items:center; justify-content:center; border-left:0.4px solid #000; overflow:hidden; padding:1%; box-sizing:border-box; flex-shrink:0;">
                        <t t-if="qr_img">
                            <img t-att-src="'data:image/png;base64,' + qr_img"
                                 style="width:100%; max-height:90%; object-fit:contain;"
                                 alt=""/>
                        </t>
                        <t t-else="">
                            <div style="width:90%; padding-bottom:90%; border:0.4px dashed #bbb; position:relative; box-sizing:border-box;">
                                <span style="position:absolute; top:50%; left:0; right:0; transform:translateY(-50%); font-size:3.5pt; color:#bbb; text-align:center; font-family:Arial,sans-serif;">Set Instagram</span>
                            </div>
                        </t>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
