<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Paper Format: 50mm wide x 25mm tall -->
    <record id="paperformat_label_50x25" model="report.paperformat">
        <field name="name">Label 50x25mm Roll</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">25</field>
        <field name="page_width">50</field>
        <field name="orientation">Landscape</field>
        <field name="dpi">96</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_custom_product_label" model="ir.actions.report">
        <field name="name">Custom Product Label 50x25</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_product_label.report_product_label_template</field>
        <field name="report_file">custom_product_label.report_product_label_template</field>
        <field name="paperformat_id" ref="paperformat_label_50x25"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_product_label_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-set="company" t-value="product.company_id or res_company"/>
                <t t-set="barcode_img" t-value="product.get_barcode_image_b64()"/>
                <t t-set="qr_img" t-value="product.get_instagram_qr_b64()"/>

                <!--
                    LABEL LAYOUT (50mm x 25mm = 188px x 94px at 96dpi)
                    ┌──────┬──────────────────────────────────────────┐
                    │      │  Item Name (Arial Narrow)    MRP ₹189.52 │
                    │ LOGO │                                           │
                    │ (rot)│  ▐▌▐▐▌▌▐▐▌▌▌▐▐▌ (barcode)    [QR CODE]  │
                    └──────┴──────────────────────────────────────────┘
                -->
                <div style="width:188px; height:94px; display:flex; flex-direction:row; overflow:hidden; background:#fff; box-sizing:border-box; page-break-after:always; margin:0; padding:0; border:1px solid #000;">

                    <!-- ══ LEFT STRIP: Company Logo vertical ══ -->
                    <div style="width:24px; min-width:24px; height:92px; display:flex; align-items:center; justify-content:center; border-right:1px solid #000; overflow:hidden; background:#fff;">
                        <img t-att-src="'/web/image/res.company/%s/logo' % company.id"
                             style="height:20px; width:80px; object-fit:contain; filter:grayscale(100%) contrast(1.3); transform:rotate(-90deg); transform-origin:center center;"
                             alt=""/>
                    </div>

                    <!-- ══ MAIN AREA ══ -->
                    <div style="flex:1; display:flex; flex-direction:column; height:92px; box-sizing:border-box; padding:3px 3px 3px 4px;">

                        <!-- TOP ROW: Item Name | MRP -->
                        <div style="display:flex; flex-direction:row; align-items:flex-start; justify-content:space-between; height:32px; overflow:hidden;">

                            <!-- Item Name - top left/center -->
                            <div style="flex:1; font-family:'Arial Narrow',Arial,sans-serif; font-size:7.5pt; font-weight:bold; line-height:1.25; color:#000; overflow:hidden; padding-right:4px; max-height:32px;">
                                <t t-esc="product.name"/>
                                <t t-if="product.product_template_attribute_value_ids">
                                    <br/>
                                    <span style="font-size:5.5pt; font-weight:normal;">
                                        <t t-esc="', '.join(product.product_template_attribute_value_ids.mapped('name'))"/>
                                    </span>
                                </t>
                            </div>

                            <!-- MRP - top right -->
                            <div style="text-align:right; white-space:nowrap; min-width:40px; flex-shrink:0;">
                                <span style="font-size:5pt; font-weight:bold; color:#000; display:block; line-height:1.1; font-family:Arial,sans-serif;">MRP</span>
                                <span style="font-size:7.5pt; font-weight:bold; color:#000; display:block; line-height:1.2; font-family:Arial,sans-serif;">
                                    <t t-esc="product.get_label_price()"/>
                                </span>
                            </div>
                        </div>

                        <!-- SPACER -->
                        <div style="flex:1;"></div>

                        <!-- BOTTOM ROW: Barcode (center) + QR (right) -->
                        <div style="display:flex; flex-direction:row; align-items:flex-end; height:54px; overflow:hidden;">

                            <!-- Barcode - bottom center, no number -->
                            <div style="flex:1; display:flex; align-items:flex-end; justify-content:center; overflow:hidden;">
                                <t t-if="barcode_img">
                                    <img t-att-src="'data:image/png;base64,' + barcode_img"
                                         style="max-width:100%; height:48px; object-fit:contain;"
                                         alt=""/>
                                </t>
                                <t t-elif="product.barcode">
                                    <img t-att-src="'/report/barcode/Code128/%s?width=200&amp;height=70&amp;humanreadable=0' % product.barcode"
                                         style="max-width:100%; height:48px; object-fit:contain;"
                                         alt=""/>
                                </t>
                                <t t-else="">
                                    <span style="font-size:5pt; color:#aaa;">No Barcode</span>
                                </t>
                            </div>

                            <!-- QR Code - bottom right -->
                            <div style="width:48px; min-width:48px; height:52px; display:flex; align-items:flex-end; justify-content:flex-end; flex-shrink:0; overflow:hidden;">
                                <t t-if="qr_img">
                                    <img t-att-src="'data:image/png;base64,' + qr_img"
                                         style="width:46px; height:46px; object-fit:contain;"
                                         alt=""/>
                                </t>
                                <t t-else="">
                                    <div style="width:46px; height:46px; border:1px dashed #bbb; display:flex; align-items:center; justify-content:center; font-size:4pt; color:#bbb; font-family:Arial,sans-serif;">
                                        Set Instagram
                                    </div>
                                </t>
                            </div>

                        </div>
                    </div>
                </div>

            </t>
        </t>
    </template>

</odoo>
