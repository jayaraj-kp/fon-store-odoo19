<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Paper Format: 50mm wide x 25mm tall -->
    <record id="paperformat_label_50x25" model="report.paperformat">
        <field name="name">Label 50x25mm Roll</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">25</field>
        <field name="page_width">50</field>
        <field name="orientation">Landscape</field>
        <field name="dpi">96</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_custom_product_label" model="ir.actions.report">
        <field name="name">Custom Product Label 50x25</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_product_label.report_product_label_template</field>
        <field name="report_file">custom_product_label.report_product_label_template</field>
        <field name="paperformat_id" ref="paperformat_label_50x25"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Standalone HTML template - NOT using web.html_container to avoid A4 override -->
    <template id="report_product_label_template">
<html>
<head>
    <meta charset="UTF-8"/>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        @page { size: 50mm 25mm; margin: 0mm; }
        html, body { width: 50mm; height: 25mm; margin: 0; padding: 0; background: #fff; }

        .label {
            width: 50mm;
            height: 25mm;
            display: flex;
            flex-direction: row;
            overflow: hidden;
            border: 0.3mm solid #000;
            background: #fff;
            page-break-after: always;
        }
        .logo-col {
            width: 7mm;
            min-width: 7mm;
            height: 25mm;
            display: flex;
            align-items: center;
            justify-content: center;
            border-right: 0.3mm solid #000;
            overflow: hidden;
            padding: 0.5mm;
        }
        .logo-col img {
            width: 5mm;
            max-height: 20mm;
            object-fit: contain;
            filter: grayscale(100%) contrast(1.3);
            transform: rotate(-90deg);
        }
        .content-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 25mm;
            padding: 1mm 1mm 1mm 1.5mm;
            overflow: hidden;
        }
        .top-row {
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            justify-content: space-between;
            height: 9mm;
            overflow: hidden;
        }
        .item-name {
            flex: 1;
            font-family: 'Arial Narrow', Arial, sans-serif;
            font-size: 6pt;
            font-weight: bold;
            line-height: 1.2;
            color: #000;
            overflow: hidden;
            padding-right: 1mm;
            max-height: 9mm;
            word-break: break-word;
        }
        .item-variant { font-size: 4.5pt; font-weight: normal; }
        .mrp-box { text-align: right; white-space: nowrap; flex-shrink: 0; min-width: 12mm; }
        .mrp-label { font-family: Arial, sans-serif; font-size: 4pt; font-weight: bold; color: #000; display: block; line-height: 1.1; }
        .mrp-price { font-family: Arial, sans-serif; font-size: 6.5pt; font-weight: bold; color: #000; display: block; line-height: 1.2; }
        .bottom-row {
            display: flex;
            flex-direction: row;
            align-items: flex-end;
            height: 14mm;
            margin-top: auto;
            overflow: hidden;
        }
        .barcode-box { flex: 1; display: flex; align-items: flex-end; justify-content: center; overflow: hidden; height: 14mm; }
        .barcode-box img { max-width: 100%; height: 13mm; object-fit: contain; }
        .qr-box { width: 13mm; height: 13mm; min-width: 13mm; flex-shrink: 0; display: flex; align-items: flex-end; justify-content: flex-end; overflow: hidden; }
        .qr-box img { width: 13mm; height: 13mm; object-fit: contain; }
        .qr-placeholder { width: 13mm; height: 13mm; border: 0.3mm dashed #bbb; display: flex; align-items: center; justify-content: center; font-size: 3.5pt; color: #bbb; font-family: Arial, sans-serif; text-align: center; }
        .no-barcode { font-size: 4pt; color: #aaa; font-family: Arial, sans-serif; }
    </style>
</head>
<body>
    <t t-foreach="docs" t-as="product">
        <t t-set="company" t-value="product.company_id or res_company"/>
        <t t-set="barcode_img" t-value="product.get_barcode_image_b64()"/>
        <t t-set="qr_img" t-value="product.get_instagram_qr_b64()"/>

        <div class="label">
            <div class="logo-col">
                <img t-att-src="'/web/image/res.company/%s/logo' % company.id" alt=""/>
            </div>
            <div class="content-col">
                <div class="top-row">
                    <div class="item-name">
                        <t t-esc="product.name"/>
                        <t t-if="product.product_template_attribute_value_ids">
                            <br/><span class="item-variant"><t t-esc="', '.join(product.product_template_attribute_value_ids.mapped('name'))"/></span>
                        </t>
                    </div>
                    <div class="mrp-box">
                        <span class="mrp-label">MRP</span>
                        <span class="mrp-price"><t t-esc="product.get_label_price()"/></span>
                    </div>
                </div>
                <div class="bottom-row">
                    <div class="barcode-box">
                        <t t-if="barcode_img">
                            <img t-att-src="'data:image/png;base64,' + barcode_img" alt=""/>
                        </t>
                        <t t-elif="product.barcode">
                            <img t-att-src="'/report/barcode/Code128/%s?width=200&amp;height=70&amp;humanreadable=0' % product.barcode" alt=""/>
                        </t>
                        <t t-else=""><span class="no-barcode">No Barcode</span></t>
                    </div>
                    <div class="qr-box">
                        <t t-if="qr_img">
                            <img t-att-src="'data:image/png;base64,' + qr_img" alt=""/>
                        </t>
                        <t t-else="">
                            <div class="qr-placeholder">Set<br/>Instagram</div>
                        </t>
                    </div>
                </div>
            </div>
        </div>

    </t>
</body>
</html>
    </template>

</odoo>
