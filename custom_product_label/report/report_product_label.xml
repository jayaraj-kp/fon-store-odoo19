<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Paper Format: 50mm wide x 25mm tall -->
    <record id="paperformat_label_50x25" model="report.paperformat">
        <field name="name">Label 50x25mm Roll</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">25</field>
        <field name="page_width">50</field>
        <field name="orientation">Landscape</field>
        <field name="dpi">96</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_custom_product_label" model="ir.actions.report">
        <field name="name">Custom Product Label 50x25</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_product_label.report_product_label_template</field>
        <field name="report_file">custom_product_label.report_product_label_template</field>
        <field name="paperformat_id" ref="paperformat_label_50x25"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb Template using web.report_call_no_service (minimal wrapper with main tag) -->
    <template id="report_product_label_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-set="company" t-value="product.company_id or res_company"/>
                <t t-set="barcode_img" t-value="product.get_barcode_image_b64()"/>
                <t t-set="qr_img" t-value="product.get_instagram_qr_b64()"/>
                <div style="
                    width: 50mm;
                    height: 25mm;
                    display: flex;
                    flex-direction: row;
                    overflow: hidden;
                    border: 0.3mm solid #000;
                    background: #fff;
                    page-break-after: always;
                    font-family: Arial, sans-serif;
                    box-sizing: border-box;
                ">
                    <!-- LEFT: Logo vertical B&amp;W -->
                    <div style="width:7mm; min-width:7mm; height:25mm; display:flex; align-items:center; justify-content:center; border-right:0.3mm solid #000; overflow:hidden; padding:0.5mm; box-sizing:border-box;">
                        <img t-att-src="'/web/image/res.company/%s/logo' % company.id"
                             style="width:5mm; max-height:20mm; object-fit:contain; filter:grayscale(100%) contrast(1.3); transform:rotate(-90deg);"
                             alt=""/>
                    </div>

                    <!-- RIGHT: Content -->
                    <div style="flex:1; display:flex; flex-direction:column; height:25mm; padding:1mm 1mm 1mm 1.5mm; overflow:hidden; box-sizing:border-box;">

                        <!-- TOP: Name + MRP -->
                        <div style="display:flex; flex-direction:row; align-items:flex-start; justify-content:space-between; height:9mm; overflow:hidden;">
                            <div style="flex:1; font-family:'Arial Narrow',Arial,sans-serif; font-size:6pt; font-weight:bold; line-height:1.2; color:#000; overflow:hidden; padding-right:1mm; max-height:9mm; word-break:break-word;">
                                <t t-esc="product.name"/>
                                <t t-if="product.product_template_attribute_value_ids">
                                    <br/><span style="font-size:4.5pt; font-weight:normal;"><t t-esc="', '.join(product.product_template_attribute_value_ids.mapped('name'))"/></span>
                                </t>
                            </div>
                            <div style="text-align:right; white-space:nowrap; flex-shrink:0; min-width:12mm;">
                                <span style="font-size:4pt; font-weight:bold; color:#000; display:block; line-height:1.1;">MRP</span>
                                <span style="font-size:6.5pt; font-weight:bold; color:#000; display:block; line-height:1.2;"><t t-esc="product.get_label_price()"/></span>
                            </div>
                        </div>

                        <!-- SPACER -->
                        <div style="flex:1;"></div>

                        <!-- BOTTOM: Barcode + QR -->
                        <div style="display:flex; flex-direction:row; align-items:flex-end; height:14mm; overflow:hidden;">
                            <!-- Barcode center, no number -->
                            <div style="flex:1; display:flex; align-items:flex-end; justify-content:center; overflow:hidden; height:14mm;">
                                <t t-if="barcode_img">
                                    <img t-att-src="'data:image/png;base64,' + barcode_img"
                                         style="max-width:100%; height:13mm; object-fit:contain;" alt=""/>
                                </t>
                                <t t-elif="product.barcode">
                                    <img t-att-src="'/report/barcode/Code128/%s?width=200&amp;height=70&amp;humanreadable=0' % product.barcode"
                                         style="max-width:100%; height:13mm; object-fit:contain;" alt=""/>
                                </t>
                                <t t-else=""><span style="font-size:4pt;color:#aaa;">No Barcode</span></t>
                            </div>
                            <!-- QR bottom right -->
                            <div style="width:13mm; height:13mm; min-width:13mm; flex-shrink:0; display:flex; align-items:flex-end; justify-content:flex-end; overflow:hidden;">
                                <t t-if="qr_img">
                                    <img t-att-src="'data:image/png;base64,' + qr_img"
                                         style="width:13mm; height:13mm; object-fit:contain;" alt=""/>
                                </t>
                                <t t-else="">
                                    <div style="width:13mm;height:13mm;border:0.3mm dashed #bbb;display:flex;align-items:center;justify-content:center;font-size:3.5pt;color:#bbb;text-align:center;">Set<br/>Instagram</div>
                                </t>
                            </div>
                        </div>

                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
