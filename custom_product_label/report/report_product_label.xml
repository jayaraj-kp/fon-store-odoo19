<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Paper Format: 50mm wide x 25mm tall -->
    <record id="paperformat_label_50x25" model="report.paperformat">
        <field name="name">Label 50x25mm Roll</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">25</field>
        <field name="page_width">50</field>
        <field name="orientation">Landscape</field>
        <field name="dpi">96</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_custom_product_label" model="ir.actions.report">
        <field name="name">Custom Product Label 50x25</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_product_label.report_product_label_template</field>
        <field name="report_file">custom_product_label.report_product_label_template</field>
        <field name="paperformat_id" ref="paperformat_label_50x25"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb Report Template - fully inline styles, no external CSS -->
    <template id="report_product_label_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-set="company" t-value="product.company_id or res_company"/>
                <t t-set="barcode_img" t-value="product.get_barcode_image_b64()"/>
                <t t-set="qr_img" t-value="product.get_instagram_qr_b64()"/>

                <!-- One label per page -->
                <div style="
                    width: 188px;
                    height: 94px;
                    display: flex;
                    flex-direction: row;
                    overflow: hidden;
                    background: #fff;
                    box-sizing: border-box;
                    page-break-after: always;
                    margin: 0;
                    padding: 0;
                    font-family: Arial, sans-serif;
                ">
                    <!-- LEFT: Company Logo column (B&amp;W vertical) -->
                    <div style="
                        width: 28px;
                        min-width: 28px;
                        height: 94px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        border-right: 1px solid #ccc;
                        overflow: hidden;
                        padding: 2px;
                        box-sizing: border-box;
                    ">
                        <img t-att-src="'/web/image/res.company/%s/logo' % company.id"
                             style="
                                width: 22px;
                                max-height: 75px;
                                object-fit: contain;
                                filter: grayscale(100%);
                                transform: rotate(-90deg);
                             "
                             alt="Logo"/>
                    </div>

                    <!-- RIGHT: Main content -->
                    <div style="
                        flex: 1;
                        display: flex;
                        flex-direction: column;
                        height: 94px;
                        padding: 2px 3px 2px 3px;
                        box-sizing: border-box;
                        overflow: hidden;
                    ">
                        <!-- TOP: Item name + MRP -->
                        <div style="
                            display: flex;
                            flex-direction: row;
                            align-items: flex-start;
                            justify-content: space-between;
                            min-height: 32px;
                            max-height: 36px;
                            overflow: hidden;
                        ">
                            <!-- Item Name -->
                            <div style="
                                flex: 1;
                                font-family: 'Arial Narrow', Arial, sans-serif;
                                font-size: 7pt;
                                font-weight: bold;
                                line-height: 1.2;
                                color: #000;
                                overflow: hidden;
                                max-height: 36px;
                                word-break: break-word;
                                padding-right: 3px;
                            ">
                                <t t-esc="product.name"/>
                                <t t-if="product.product_template_attribute_value_ids">
                                    <br/>
                                    <span style="font-size:5.5pt; font-weight:normal; color:#444;">
                                        <t t-esc="', '.join(product.product_template_attribute_value_ids.mapped('name'))"/>
                                    </span>
                                </t>
                            </div>
                            <!-- MRP -->
                            <div style="
                                text-align: right;
                                white-space: nowrap;
                                font-family: Arial, sans-serif;
                                min-width: 38px;
                            ">
                                <span style="font-size:5pt; font-weight:bold; color:#000; display:block; line-height:1.1;">MRP</span>
                                <span style="font-size:7pt; font-weight:bold; color:#000; display:block; line-height:1.2;">
                                    <t t-esc="product.get_label_price()"/>
                                </span>
                            </div>
                        </div>

                        <!-- SPACER -->
                        <div style="flex:1;"></div>

                        <!-- BOTTOM: QR + Barcode -->
                        <div style="
                            display: flex;
                            flex-direction: row;
                            align-items: flex-end;
                            height: 52px;
                            overflow: hidden;
                        ">
                            <!-- Instagram QR - bottom left -->
                            <div style="width:46px; height:46px; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                                <t t-if="qr_img">
                                    <img t-att-src="'data:image/png;base64,' + qr_img"
                                         style="width:44px; height:44px; object-fit:contain;"
                                         alt="QR"/>
                                </t>
                                <t t-else="">
                                    <div style="width:44px;height:44px;border:1px dashed #aaa;display:flex;align-items:center;justify-content:center;font-size:4pt;color:#aaa;">QR</div>
                                </t>
                            </div>

                            <!-- Barcode - bottom center, no number -->
                            <div style="flex:1; display:flex; align-items:flex-end; justify-content:center; overflow:hidden; padding: 0 2px;">
                                <t t-if="barcode_img">
                                    <img t-att-src="'data:image/png;base64,' + barcode_img"
                                         style="max-width:100%; height:44px; object-fit:contain;"
                                         alt="Barcode"/>
                                </t>
                                <t t-elif="product.barcode">
                                    <img t-att-src="'/report/barcode/Code128/%s?width=180&amp;height=60&amp;humanreadable=0' % product.barcode"
                                         style="max-width:100%; height:44px; object-fit:contain;"
                                         alt="Barcode"/>
                                </t>
                                <t t-else="">
                                    <span style="font-size:5pt;color:#aaa;">No Barcode</span>
                                </t>
                            </div>
                        </div>

                    </div>
                </div>

            </t>
        </t>
    </template>

</odoo>
