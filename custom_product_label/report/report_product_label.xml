<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- 50mm wide x 25mm tall. Portrait orientation set intentionally.
         Width=50 > Height=25 so wkhtmltopdf renders it wide naturally.
         The Python override strips the orientation flag completely. -->
    <record id="paperformat_label_50x25" model="report.paperformat">
        <field name="name">Label 50x25mm Roll</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">25</field>
        <field name="page_width">50</field>
        <field name="orientation">Portrait</field>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_custom_product_label" model="ir.actions.report">
        <field name="name">Custom Product Label 50x25</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_product_label.report_product_label_template</field>
        <field name="report_file">custom_product_label.report_product_label_template</field>
        <field name="paperformat_id" ref="paperformat_label_50x25"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_product_label_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-set="barcode_img" t-value="product.get_barcode_image_b64()"/>
                <t t-set="qr_img"     t-value="product.get_instagram_qr_b64()"/>
                <t t-set="logo_b64"   t-value="product.get_company_logo_b64()"/>


                <div style="
                    width: 100vw;
                    height: 100vh;
                    max-width: 100vw;
                    max-height: 100vh;
                    display: flex;
                    flex-direction: row;
                    overflow: hidden;
                    background: #ffffff;
                    border: 0.5px solid #000000;
                    box-sizing: border-box;
                    page-break-after: always;
                    font-family: Arial, sans-serif;
                ">

                    <!-- ═══ LEFT: Company Logo (B&amp;W, rotated -90°) ═══ -->
                    <div style="
                        width: 14%;
                        flex-shrink: 0;
                        height: 100%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        border-right: 0.5px solid #000000;
                        overflow: hidden;
                        padding: 1%;
                        box-sizing: border-box;
                    ">
                        <t t-if="logo_b64">
                            <img t-att-src="'data:image/png;base64,' + logo_b64"
                                 style="max-width:100%; max-height:80%; object-fit:contain; filter:grayscale(100%) contrast(1.3); transform:rotate(-90deg);"
                                 alt=""/>
                        </t>
                    </div>

                    <!-- ═══ CENTER: Name top, Barcode bottom ═══ -->
                    <div style="
                        flex: 1;
                        height: 100%;
                        display: flex;
                        flex-direction: column;
                        padding: 4% 3% 2% 4%;
                        box-sizing: border-box;
                        overflow: hidden;
                    ">
                        <!-- TOP: Product name + MRP -->
                        <div style="
                            display: flex;
                            flex-direction: row;
                            align-items: flex-start;
                            justify-content: space-between;
                            height: 40%;
                            overflow: hidden;
                            flex-shrink: 0;
                        ">
                            <!-- Product name (Arial Narrow, bold, 2 lines max) -->
                            <div style="
                                flex: 1;
                                font-family: 'Arial Narrow', Arial, sans-serif;
                                font-size: 7.5pt;
                                font-weight: bold;
                                line-height: 1.25;
                                color: #000000;
                                overflow: hidden;
                                word-break: break-word;
                                padding-right: 2%;
                            ">
                                <t t-esc="product.name"/>
                                <t t-if="product.product_template_attribute_value_ids">
                                    <br/>
                                    <span style="font-size:5pt; font-weight:normal;">
                                        <t t-esc="', '.join(product.product_template_attribute_value_ids.mapped('name'))"/>
                                    </span>
                                </t>
                            </div>
                            <!-- MRP top right -->
                            <div style="
                                text-align: right;
                                flex-shrink: 0;
                                white-space: nowrap;
                            ">
                                <span style="font-size:5pt; font-weight:bold; display:block; line-height:1.1;">MRP</span>
                                <span style="font-size:7pt; font-weight:bold; display:block; line-height:1.2;">
                                    <t t-esc="product.get_label_price()"/>
                                </span>
                            </div>
                        </div>

                        <!-- SPACER -->
                        <div style="flex:1;"/>

                        <!-- BOTTOM: Barcode (no number) -->
                        <div style="
                            height: 55%;
                            display: flex;
                            align-items: flex-end;
                            justify-content: center;
                            overflow: hidden;
                            flex-shrink: 0;
                        ">
                            <t t-if="barcode_img">
                                <img t-att-src="'data:image/png;base64,' + barcode_img"
                                     style="max-width:100%; max-height:100%; object-fit:contain;"
                                     alt=""/>
                            </t>
                            <t t-elif="product.barcode">
                                <img t-att-src="'/report/barcode/Code128/%s?width=250&amp;height=80&amp;humanreadable=0' % product.barcode"
                                     style="max-width:100%; max-height:100%; object-fit:contain;"
                                     alt=""/>
                            </t>
                            <t t-else="">
                                <span style="font-size:5pt; color:#aaa;">No Barcode Set</span>
                            </t>
                        </div>
                    </div>

                    <!-- ═══ RIGHT: Instagram QR Code ═══ -->
                    <div style="
                        width: 22%;
                        flex-shrink: 0;
                        height: 100%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        border-left: 0.5px solid #000000;
                        overflow: hidden;
                        padding: 2%;
                        box-sizing: border-box;
                    ">
                        <t t-if="qr_img">
                            <img t-att-src="'data:image/png;base64,' + qr_img"
                                 style="width:100%; max-height:90%; object-fit:contain;"
                                 alt=""/>
                        </t>
                        <t t-else="">
                            <div style="
                                width:90%; padding-bottom:90%;
                                border:0.5px dashed #cccccc;
                                position:relative;
                                box-sizing:border-box;
                            ">
                                <span style="
                                    position:absolute; top:50%; left:0; right:0;
                                    transform:translateY(-50%);
                                    font-size:3.5pt; color:#cccccc;
                                    text-align:center;
                                ">Set<br/>Instagram</span>
                            </div>
                        </t>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
