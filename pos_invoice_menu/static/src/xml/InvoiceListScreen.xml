<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_invoice_menu.InvoiceListScreen" owl="1">
        <div class="pos-invoice-screen">

            <!-- ─── Top Header ─────────────────────────────────────────────────── -->
            <div class="pos-invoice-screen__header">
                <button class="pos-invoice-back-btn" t-on-click="goBack">
                    &#8592; Back
                </button>
                <div class="pos-invoice-screen__title">
                    <span class="pos-invoice-title-icon">&#xf15c;</span>
                    Session Invoices
                </div>
                <div class="pos-invoice-header-right">
                    <input
                        class="pos-invoice-search"
                        type="text"
                        placeholder="&#128269; Search by order or customer..."
                        t-model="state.searchQuery"
                    />
                    <button class="pos-invoice-refresh-btn" t-on-click="loadOrders">
                        &#8635; Refresh
                    </button>
                </div>
            </div>

            <!-- ─── Summary Bar ────────────────────────────────────────────────── -->
            <div class="pos-invoice-summary">
                <div class="pos-invoice-summary__item">
                    <span class="pos-invoice-summary__label">Total Orders</span>
                    <span class="pos-invoice-summary__value" t-esc="filteredOrders.length"/>
                </div>
                <div class="pos-invoice-summary__item">
                    <span class="pos-invoice-summary__label">Total Amount</span>
                    <span class="pos-invoice-summary__value"
                          t-esc="formatCurrency(totalAmount)"/>
                </div>
                <div t-if="state.searchQuery" class="pos-invoice-summary__item">
                    <span class="pos-invoice-summary__label">Showing results for</span>
                    <span class="pos-invoice-summary__value pos-invoice-summary__query"
                          t-esc="state.searchQuery"/>
                </div>
            </div>

            <!-- ─── Body ───────────────────────────────────────────────────────── -->
            <div class="pos-invoice-screen__body">

                <!-- Loading State -->
                <t t-if="state.loading">
                    <div class="pos-invoice-state-box">
                        <div class="pos-invoice-spinner"/>
                        <p>Loading orders...</p>
                    </div>
                </t>

                <!-- Error State -->
                <t t-elif="state.errorMessage">
                    <div class="pos-invoice-state-box pos-invoice-state-box--error">
                        <span class="pos-invoice-state-icon">&#9888;</span>
                        <p t-esc="state.errorMessage"/>
                        <button class="pos-invoice-retry-btn" t-on-click="loadOrders">
                            Retry
                        </button>
                    </div>
                </t>

                <!-- Empty State -->
                <t t-elif="filteredOrders.length === 0">
                    <div class="pos-invoice-state-box">
                        <span class="pos-invoice-state-icon">&#128196;</span>
                        <p>No orders found for this session.</p>
                    </div>
                </t>

                <!-- Orders Table -->
                <t t-else="">
                    <div class="pos-invoice-table-wrapper">
                        <table class="pos-invoice-table">
                            <thead>
                                <tr>
                                    <th>Order Ref</th>
                                    <th>Date &amp; Time</th>
                                    <th>Customer</th>
                                    <th>Tax</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="filteredOrders" t-as="order" t-key="order.id">
                                    <!-- Main Row -->
                                    <tr
                                        t-attf-class="pos-invoice-row #{isSelected(order) ? 'pos-invoice-row--active' : ''}"
                                        t-on-click="() => selectOrder(order)"
                                    >
                                        <td class="pos-invoice-cell--ref">
                                            <span t-esc="order.name"/>
                                        </td>
                                        <td t-esc="formatDate(order.date_order)"/>
                                        <td>
                                            <span class="pos-invoice-customer" t-esc="order.partner_name"/>
                                        </td>
                                        <td t-esc="formatCurrency(order.amount_tax)"/>
                                        <td class="pos-invoice-cell--total">
                                            <strong t-esc="formatCurrency(order.amount_total)"/>
                                        </td>
                                        <td>
                                            <span t-attf-class="pos-invoice-badge #{getStateBadgeClass(order.state)}"
                                                  t-esc="order.state"/>
                                        </td>
                                    </tr>

                                    <!-- Expandable Order Lines Row -->
                                    <tr t-if="isSelected(order)" class="pos-invoice-detail-row">
                                        <td colspan="6">
                                            <div class="pos-invoice-lines">
                                                <h4>Order Lines</h4>
                                                <table class="pos-invoice-lines-table">
                                                    <thead>
                                                        <tr>
                                                            <th>Product</th>
                                                            <th>Qty</th>
                                                            <th>Unit Price</th>
                                                            <th>Subtotal</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-foreach="order.lines" t-as="line" t-key="line_index">
                                                            <tr>
                                                                <td t-esc="line.product_name"/>
                                                                <td t-esc="line.qty"/>
                                                                <td t-esc="formatCurrency(line.price_unit)"/>
                                                                <td t-esc="formatCurrency(line.price_subtotal)"/>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </div>

        </div>
    </t>

</templates>
