<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- ─── Invoice Button Component Template ───────────────────────────────── -->
    <t t-name="pos_invoice_menu.InvoiceButton" owl="1">
        <button class="pos-invoice-topbar-btn btn btn-light" t-on-click="openInvoiceScreen">
            <i class="fa fa-file-text-o me-1"/>
            <span>Invoices</span>
        </button>
    </t>

    <!--
        Confirmed from odoo.loader:
          Navbar module: @point_of_sale/app/components/navbar/navbar
          Navbar template: point_of_sale.Navbar
          Top bar class: pos-topheader (outer wrapper)
          Inner navbar class: navbar-menu

        We inject BEFORE the navbar-menu buttons (Register / Orders)
        so our button sits in the top header bar.
    -->
    <t t-name="pos_invoice_menu.NavbarPatch" owl="1"
       t-inherit="point_of_sale.Navbar"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('navbar-menu')]" position="before">
            <InvoiceButton />
        </xpath>
    </t>

</templates>
