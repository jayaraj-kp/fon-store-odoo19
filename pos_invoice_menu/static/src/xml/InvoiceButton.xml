<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        InvoiceButton component template.
        Registered via pos_widget registry — no Navbar patching needed.
        Rendered by the POS shell automatically.
    -->
    <t t-name="pos_invoice_menu.InvoiceButton" owl="1">
        <button class="pos-invoice-topbar-btn" t-on-click="openInvoiceScreen">
            <i class="fa fa-file-text-o"/>
            <span> Invoices</span>
        </button>
    </t>

</templates>
