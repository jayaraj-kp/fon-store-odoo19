<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- ─── Invoice Button Component ─────────────────────────────────────────── -->
    <t t-name="pos_invoice_menu.InvoiceButton" owl="1">
        <button class="pos-invoice-topbar-btn" t-on-click="openInvoiceScreen">
            <i class="fa fa-file-text-o"/>
            <span class="pos-invoice-btn-label"> Invoices</span>
        </button>
    </t>

    <!--
    ═══════════════════════════════════════════════════════════════════════════
    ODOO 19 CE — POS Chrome Top Bar Patch
    ═══════════════════════════════════════════════════════════════════════════

    In Odoo 17/18/19 the top bar lives in `point_of_sale.Chrome` (NOT ProductScreen).
    The template structure is:

        <div class="pos-top-bar">
            <div class="menus-buttons"> ... </div>
            <div class="pos-title-section"> ... </div>
            <div class="pos-top-bar-buttons"> ... </div>
        </div>

    We inject our button inside the right-side buttons area.
    ═══════════════════════════════════════════════════════════════════════════
    -->
    <t t-name="point_of_sale.Chrome" owl="1"
       t-inherit="point_of_sale.Chrome"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-top-bar-buttons')]" position="inside">
            <InvoiceButton />
        </xpath>
    </t>

</templates>
