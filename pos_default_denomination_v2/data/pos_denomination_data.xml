<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        noupdate="1" means these records are created on first install
        but NOT overwritten on module upgrade — safe for production.

        These seed all Indian denominations into pos.bill globally.
        The post_init_hook also handles this for safety (double coverage).
    -->

    <!-- Notes -->
    <record id="pos_bill_inr_500" model="pos.bill">
        <field name="value">500</field>
    </record>

    <record id="pos_bill_inr_200" model="pos.bill">
        <field name="value">200</field>
    </record>

    <record id="pos_bill_inr_100" model="pos.bill">
        <field name="value">100</field>
    </record>

    <record id="pos_bill_inr_50" model="pos.bill">
        <field name="value">50</field>
    </record>

    <record id="pos_bill_inr_20" model="pos.bill">
        <field name="value">20</field>
    </record>

    <!-- Coins -->
    <record id="pos_bill_inr_10" model="pos.bill">
        <field name="value">10</field>
    </record>

    <record id="pos_bill_inr_5" model="pos.bill">
        <field name="value">5</field>
    </record>

    <record id="pos_bill_inr_2" model="pos.bill">
        <field name="value">2</field>
    </record>

    <record id="pos_bill_inr_1" model="pos.bill">
        <field name="value">1</field>
    </record>

</odoo>
