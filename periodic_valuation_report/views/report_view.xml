<odoo>
    <record id="view_periodic_valuation_list" model="ir.ui.view">
        <field name="name">periodic.valuation.list</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="display_name" string="Product"/>
                <field name="qty_available" string="Quantity"/>
                <field name="standard_price" string="Unit Value"/>
                <field name="custom_inventory_value" string="Total Value" sum="Total"/>
            </list>
        </field>
    </record>

    <record id="action_periodic_valuation" model="ir.actions.act_window">
        <field name="name">Inventory Valuation</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_periodic_valuation_list"/>
        <!--
            Odoo 19: 'detailed_type' and 'type' on product.product are removed.
            Filter by qty_available > 0 only — non-storable products have no stock
            so they will never appear anyway. This is safe and works in all versions.
        -->
        <field name="domain">[('qty_available', '>', 0)]</field>
    </record>

    <menuitem id="menu_periodic_valuation_custom"
              name="Inventory Valuation (Periodic)"
              parent="stock.menu_warehouse_report"
              action="action_periodic_valuation"
              sequence="100"/>
</odoo>