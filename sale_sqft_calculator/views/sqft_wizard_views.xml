<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sqft_calculator_wizard_form" model="ir.ui.view">
        <field name="name">sqft.calculator.wizard.form</field>
        <field name="model">sqft.calculator.wizard</field>
        <field name="arch" type="xml">
            <form string="Square Feet Calculator">
                <sheet>
                    <!-- Product Banner -->
                    <div class="oe_title">
                        <h4 class="text-muted">Calculating area for:</h4>
                        <h2>
                            <field name="product_id" readonly="1"/>
                        </h2>
                    </div>

                    <separator string="Enter Dimensions"/>

                    <group col="2">
                        <group string="Width">
                            <field name="width"
                                   widget="float"
                                   placeholder="e.g. 10.5"
                                   options="{'precision': 4}"/>
                        </group>
                        <group string="Height">
                            <field name="height"
                                   widget="float"
                                   placeholder="e.g. 8.0"
                                   options="{'precision': 4}"/>
                        </group>
                    </group>

                    <separator string="Result"/>

                    <group>
                        <div class="alert alert-info text-center" role="alert">
                            <h3>
                                <strong>Area = Width × Height</strong>
                            </h3>
                            <h2 class="text-success">
                                <field name="sqft_display" readonly="1"/>
                            </h2>
                            <p class="text-muted">
                                This value will be set as the <strong>Quantity</strong> on the order line.
                            </p>
                        </div>
                    </group>
                </sheet>

                <footer>
                    <button name="action_apply"
                            string="✔ Apply to Order Line"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
