<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Allowed POS tab to User form -->
    <record id="view_users_form_pos_restriction" model="ir.ui.view">
        <field name="name">res.users.form.pos.restriction</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Allowed POS" name="allowed_pos">
                    <group>
                        <field name="allowed_pos_ids"
                               widget="many2many_tags"
                               options="{'no_create': True}"
                               string="Allowed Point of Sale Terminals"
                               help="Select the POS terminals this user is allowed to access. Leave empty to allow access to ALL terminals (only applicable for POS Managers or Admins)."/>
                    </group>
                    <div class="alert alert-info" role="alert" style="margin-top: 8px;">
                        <strong>Note:</strong>
                        If one or more POS terminals are selected, this user will
                        <strong>only</strong> see and be able to open those terminals.
                        POS Managers always have access to all terminals regardless of this setting.
                    </div>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
