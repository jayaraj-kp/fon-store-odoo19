<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Record Rule: POS Config User Restriction
        =========================================
        Applied ONLY to the "POS User" group (cashiers).
        POS Managers and Administrators are NOT in this group exclusively —
        they have their own groups and are excluded from this rule.

        Logic for POS Users:
          - If a POS has NO allowed_user_ids set  → everyone can see it
          - If a POS HAS allowed_user_ids set     → only those users see it
    -->
    <record id="pos_config_rule_user_restriction" model="ir.rule">
        <field name="name">POS Config: Restrict to Allowed POS per User</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">[
            '|',
            ('allowed_user_ids', '=', False),
            ('allowed_user_ids', 'in', [user.id])
        ]</field>
        <!-- Apply ONLY to POS User group (cashiers), NOT to POS Manager or Admin -->
        <field name="groups" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!--
        Explicit global rule for POS Manager: no restriction, see everything.
        This overrides the above for users who are POS Managers.
    -->
    <record id="pos_config_rule_manager_all_access" model="ir.rule">
        <field name="name">POS Config: POS Manager sees all terminals</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('point_of_sale.group_pos_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
