<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Record Rule: POS Config User Restriction
        
        Applied to group_pos_user AND group_pos_manager.
        
        Domain logic:
          - If this POS has NO allowed_user_ids set at all → everyone sees it  (no restriction configured)
          - If this POS HAS allowed_user_ids set → only users in that list see it
        
        This means:
          - Unrestricted POS (allowed_user_ids empty) → visible to all
          - Restricted POS (allowed_user_ids has entries) → only those users see it
          - Admins (group_system / superuser) are excluded via separate global rule
    -->
    <record id="pos_config_rule_user_restriction" model="ir.rule">
        <field name="name">POS Config: Restrict to Allowed POS per User</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">[
            '|',
            ('allowed_user_ids', '=', False),
            ('allowed_user_ids', 'in', [user.id])
        ]</field>
        <field name="groups" eval="[
            (4, ref('point_of_sale.group_pos_user')),
            (4, ref('point_of_sale.group_pos_manager')),
        ]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!--
        Global rule (no group = applies to ALL users including admin/superuser).
        Admins always see everything — this overrides the group rule above for admins.
        
        In Odoo, global rules (no groups field) are combined with AND with group rules.
        So we need to ensure admins are NOT subject to the group rule above.
        We do this by checking: if user has group_system, skip the filter.
    -->
    <record id="pos_config_rule_admin_all_access" model="ir.rule">
        <field name="name">POS Config: Admin sees all terminals</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
