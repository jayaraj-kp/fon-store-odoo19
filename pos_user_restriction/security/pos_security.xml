<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Record Rule for POS Users (cashiers only).
        
        Logic:
          - POS has no allowed_user_ids at all  → visible to everyone  (OR left side)
          - POS has allowed_user_ids set        → visible only if current user is in the list (OR right side)
        
        This rule is scoped to group_pos_user ONLY.
        POS Managers get a separate unrestricted rule below.
    -->
    <record id="pos_config_rule_user_restriction" model="ir.rule">
        <field name="name">POS Config: Restrict to Allowed POS per User</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">[
            '|',
            ('allowed_user_ids', '=', False),
            ('allowed_user_ids', 'in', [user.id])
        ]</field>
        <field name="groups" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!--
        POS Manager: unrestricted access to all terminals.
        Odoo applies record rules per group — a user in BOTH groups
        gets the UNION (most permissive), so managers always see everything.
    -->
    <record id="pos_config_rule_manager_all_access" model="ir.rule">
        <field name="name">POS Config: POS Manager sees all terminals</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('point_of_sale.group_pos_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
