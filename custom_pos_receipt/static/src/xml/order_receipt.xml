<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
    ==========================================================================
    ODOO 17/18/19 CE - Custom POS Receipt Template
    Inherits: point_of_sale.OrderReceipt
    File path in Odoo source:
      point_of_sale/static/src/app/screens/receipt_screen/receipt/order_receipt.xml

    HOW THIS WORKS:
    - t-inherit="point_of_sale.OrderReceipt" → inherits the OWL receipt component
    - t-inherit-mode="extension" → extends (doesn't replace) it
    - Use xpath to target elements inside the receipt

    AVAILABLE DATA (use as props.data.XXXX):
    - props.data.headerData.company.name      → Company name
    - props.data.headerData.company.street    → Company address
    - props.data.headerData.company.phone     → Company phone
    - props.data.name                         → Order reference
    - props.data.orderlines                   → List of order lines
    - props.data.paymentlines                 → Payment info
    - props.data.total_with_tax               → Total amount
    - props.data.client                       → Customer object (if set)
    ==========================================================================
    -->

    <t t-name="custom_pos_receipt.OrderReceipt"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">

        <!-- ==============================================================
             CUSTOMIZATION 1: Welcome banner below the shop contact info
             ============================================================== -->
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="after">
            <div style="text-align:center;
                        border-top: 1px dashed #000;
                        border-bottom: 1px dashed #000;
                        padding: 5px 0;
                        margin: 6px 0;
                        font-size: 13px;
                        font-weight: bold;">
                ★ WELCOME TO OUR STORE ★
            </div>
        </xpath>

        <!-- ==============================================================
             CUSTOMIZATION 2: Thank-you message before the QR code / footer
             Add above the pos-receipt-order-data section
             ============================================================== -->
        <xpath expr="//div[hasclass('pos-receipt-order-data')]" position="before">
            <div style="text-align:center; margin: 8px 0 4px 0; font-size: 12px;">
                <div>Thank you for shopping with us!</div>
                <div>Exchange within 7 days with original receipt.</div>
            </div>
        </xpath>

        <!-- ==============================================================
             CUSTOMIZATION 3: Extra footer note at the very bottom
             ============================================================== -->
        <xpath expr="//div[hasclass('pos-receipt-order-data')]" position="after">
            <div style="text-align:center;
                        border-top: 1px dashed #ccc;
                        margin-top: 8px;
                        padding-top: 6px;
                        font-size: 11px;
                        color: #555;">
                <div>For support: your@email.com</div>
                <div>Visit us again!</div>
            </div>
        </xpath>

    </t>

</templates>
