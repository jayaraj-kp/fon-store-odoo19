<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Inherit POS Receipt -->
    <t t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">

        <!-- REMOVE DEFAULT TOTAL SECTION -->
        <xpath expr="//div[contains(@class,'order-summary')]" position="replace">

            <!-- GST TABLE -->
            <t t-set="gstLines" t-value="order.getGstBreakdown()"/>
            <t t-if="gstLines and gstLines.length">

                <div class="gst-table-wrapper">
                    <table class="gst-breakdown-table">
                        <thead>
                            <tr>
                                <th>GST Rate</th>
                                <th class="text-right">Taxable</th>
                                <th class="text-right">CGST</th>
                                <th class="text-right">SGST</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="gstLines" t-as="gline" t-key="gline.rate">
                                <tr>
                                    <td><t t-esc="gline.label"/></td>
                                    <td class="text-right">
                                        <t t-esc="formatCurrency(gline.taxable)"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="formatCurrency(gline.cgst)"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="formatCurrency(gline.sgst)"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

            </t>

            <!-- CUSTOM TOTAL SECTION -->
            <div class="custom-total-section">

                <div class="line">
                    <span>Before Grand Total</span>
                    <span>
                        <t t-esc="formatCurrency(order.getBeforeGrandTotal())"/>
                    </span>
                </div>

                <div class="line">
                    <span>Taxable Total</span>
                    <span>
                        <t t-esc="formatCurrency(order.getTotalTaxableAmount())"/>
                    </span>
                </div>

                <div class="line">
                    <span>CGST</span>
                    <span>
                        <t t-esc="formatCurrency(order.getTotalCgst())"/>
                    </span>
                </div>

                <div class="line">
                    <span>SGST</span>
                    <span>
                        <t t-esc="formatCurrency(order.getTotalSgst())"/>
                    </span>
                </div>

                <div class="line total">
                    <span>Grand Total</span>
                    <span>
                        <t t-esc="formatCurrency(order.getGrandTotal())"/>
                    </span>
                </div>

                <div class="amount-words">
                    <t t-esc="order.getAmountInWords()"/>
                </div>

            </div>

        </xpath>

    </t>

</templates>