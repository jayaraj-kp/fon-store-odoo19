<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<!-- ==================== TEMPLATE 1: RECEIPT HEADER ==================== -->
<t t-name="point_of_sale.ReceiptHeader"
   t-inherit="point_of_sale.ReceiptHeader"
   t-inherit-mode="extension">

    <!-- Replace entire header with our custom layout -->
    <xpath expr="//img[@class='pos-receipt-logo']" position="replace">

        <!-- ROW 1: Logo (left) + Company Info (right) -->
        <div class="receipt-header-row">
            <div class="receipt-logo-cell">
                <img t-att-src="logoUrl" alt="Logo" class="receipt-company-logo"/>
            </div>
            <div class="receipt-company-cell">
                <t t-set="co" t-value="order.company"/>
                <div class="company-name"><t t-esc="co.name"/></div>
                <t t-if="co.street"><div><t t-esc="co.street"/></div></t>
                <t t-if="co.city">
                    <div><t t-esc="co.city"/><t t-if="co.zip">, <t t-esc="co.zip"/></t></div>
                </t>
                <t t-if="co.vat"><div>GSTIN: <t t-esc="co.vat"/></div></t>
                <t t-if="co.phone"><div>Tel: <t t-esc="co.phone"/></div></t>
                <t t-if="co.email"><div><t t-esc="co.email"/></div></t>
            </div>
        </div>

    </xpath>

    <!-- Hide the default date/reference block that comes after logo -->
    <xpath expr="//div[@class='text-center pt-3']" position="replace"/>

    <!-- Hide default cashier/contact block -->
    <xpath expr="//div[@class='d-flex flex-column align-items-center']" position="replace">

        <!-- ROW 2: Invoice No (left) + Invoice Date (right) -->
        <div class="receipt-meta-row" style="border-top:1px dashed #000; padding-top:4px; margin-top:4px;">
            <div>
                <strong>Invoice: </strong><t t-esc="order.pos_reference"/>
            </div>
            <div>
                <t t-esc="order.formatDateOrTime('date_order', 'date')"/>
            </div>
        </div>

        <!-- ROW 3: Customer Details (left aligned) -->
        <t t-if="order.partner_id">
            <div class="receipt-customer-block">
                <div><strong><t t-esc="order.partner_id.name"/></strong></div>
                <t t-if="order.partner_id.pos_contact_address">
                    <div><t t-esc="order.partner_id.pos_contact_address"/></div>
                </t>
                <t t-if="order.partner_id.phone">
                    <div>Phone: <t t-esc="order.partner_id.phone"/></div>
                </t>
                <t t-if="order.partner_id.vat">
                    <div>GSTIN: <t t-esc="order.partner_id.vat"/></div>
                </t>
            </div>
        </t>

    </xpath>

</t>

<!-- ==================== TEMPLATE 2: ORDER RECEIPT ==================== -->
<t t-name="point_of_sale.OrderReceipt"
   t-inherit="point_of_sale.OrderReceipt"
   t-inherit-mode="extension">

    <!-- Replace the OrderDisplay (item lines) with our custom SN/ITEM/QTY/RATE/TOTAL table -->
    <xpath expr="//OrderDisplay" position="replace">
        <table class="receipt-items-table" style="width:100%; border-collapse:collapse; font-size:10px; font-family:monospace; margin: 6px 0;">
            <thead>
                <tr style="border-bottom:1px solid #000; border-top:1px solid #000;">
                    <th style="text-align:left; padding:2px 1px;">SN</th>
                    <th style="text-align:left; padding:2px 1px;">ITEM</th>
                    <th style="text-align:right; padding:2px 1px;">QTY</th>
                    <th style="text-align:right; padding:2px 1px;">RATE</th>
                    <th style="text-align:right; padding:2px 1px;">TOTAL</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="order.lines" t-as="line" t-key="line.uuid">
                    <tr>
                        <td style="text-align:left; padding:2px 1px; vertical-align:top;">
                            <t t-esc="line_index + 1"/>
                        </td>
                        <td style="text-align:left; padding:2px 1px; word-break:break-word; max-width:80px;">
                            <t t-esc="line.product_id.display_name"/>
                            <t t-if="line.customerNote">
                                <div style="font-style:italic; font-size:9px;"><t t-esc="line.customerNote"/></div>
                            </t>
                        </td>
                        <td style="text-align:right; padding:2px 1px; vertical-align:top;">
                            <t t-esc="line.qty"/>
                        </td>
                        <td style="text-align:right; padding:2px 1px; vertical-align:top;">
                            <t t-esc="formatCurrency(line.price_unit)"/>
                        </td>
                        <td style="text-align:right; padding:2px 1px; vertical-align:top;">
                            <t t-esc="formatCurrency(line.price_subtotal_incl)"/>
                        </td>
                    </tr>
                </t>
            </tbody>
        </table>
    </xpath>

    <!-- Hide Subtotal/GST tax groups block -->
    <xpath expr="//div[@class='pos-receipt-taxes pt-3']" position="replace"/>

    <!-- Hide Total bold row -->
    <xpath expr="//div[@class='pos-receipt-amount receipt-total fw-bolder']" position="replace"/>

    <!-- Hide Payment lines (Cash etc) -->
    <xpath expr="//div[@class='paymentlines text-start pt-1']" position="replace"/>

    <!-- Hide Change row -->
    <xpath expr="//div[@class='pos-receipt-amount receipt-change']" position="replace"/>

    <!-- Hide default invoice QR block -->
    <xpath expr="//div[@class='gap-2 d-flex flex-row pt-3']" position="replace"/>

    <!-- Inject our custom section before before-footer -->
    <xpath expr="//div[@class='before-footer']" position="before">

        <!-- GST BREAKDOWN TABLE (centered) -->
        <div style="margin-top:6px; border-top:1px dashed #000; padding-top:4px;">
            <t t-set="gstLines" t-value="order.getGstBreakdown()"/>
            <t t-if="gstLines and gstLines.length">
                <table style="width:100%; border-collapse:collapse; font-size:10px; font-family:monospace; margin-bottom:4px;">
                    <thead>
                        <tr style="border-bottom:1px solid #000;">
                            <th style="text-align:left; padding:2px;">GST%</th>
                            <th style="text-align:right; padding:2px;">Taxable</th>
                            <th style="text-align:right; padding:2px;">CGST</th>
                            <th style="text-align:right; padding:2px;">SGST</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="gstLines" t-as="gline" t-key="gline.rate">
                            <tr>
                                <td style="text-align:left; padding:2px;"><t t-esc="gline.rate"/>%</td>
                                <td style="text-align:right; padding:2px;"><t t-esc="formatCurrency(gline.taxable)"/></td>
                                <td style="text-align:right; padding:2px;"><t t-esc="formatCurrency(gline.cgst)"/></td>
                                <td style="text-align:right; padding:2px;"><t t-esc="formatCurrency(gline.sgst)"/></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr style="border-top:1px solid #000; font-weight:bold;">
                            <td style="padding:2px;">Total</td>
                            <td style="text-align:right; padding:2px;"><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></td>
                            <td style="text-align:right; padding:2px;"><t t-esc="formatCurrency(order.getTotalCgst())"/></td>
                            <td style="text-align:right; padding:2px;"><t t-esc="formatCurrency(order.getTotalSgst())"/></td>
                        </tr>
                    </tfoot>
                </table>
            </t>

            <!-- Grand Total + Amount in Words -->
            <div class="custom-total-section" style="margin-top:4px;">
                <div class="line">
                    <span>Taxable Amount</span>
                    <span><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></span>
                </div>
                <div class="line">
                    <span>CGST</span>
                    <span><t t-esc="formatCurrency(order.getTotalCgst())"/></span>
                </div>
                <div class="line">
                    <span>SGST</span>
                    <span><t t-esc="formatCurrency(order.getTotalSgst())"/></span>
                </div>
                <div class="line total">
                    <span>Grand Total</span>
                    <span><t t-esc="formatCurrency(order.getGrandTotal())"/></span>
                </div>
                <div class="amount-words">
                    <t t-esc="order.getAmountInWords()"/>
                </div>
                <t t-if="order.getTotalSaved()">
                    <div class="saved-line">
                        <span>&#127881; You Have Saved &#127881;</span>
                        <span><t t-esc="formatCurrency(order.getTotalSaved())"/></span>
                    </div>
                </t>
            </div>
        </div>

        <!-- QR CODES side by side -->
        <div class="receipt-qr-row">
            <div class="receipt-qr-cell">
                <t t-if="order.company.point_of_sale_use_ticket_qr_code and order.finalized and qrCode">
                    <div class="qr-cell-label">Need an invoice?</div>
                    <img t-att-src="qrCode" class="qr-code" alt="Invoice QR"/>
                    <t t-if="order.ticket_code">
                        <div class="qr-cell-code">Code: <t t-out="order.ticket_code"/></div>
                    </t>
                </t>
            </div>
            <div class="receipt-qr-cell">
                <t t-if="upiQrSrc">
                    <div class="qr-cell-label">Scan &amp; Pay &#x20B9;</div>
                    <div class="upi-qr-image-container">
                        <img t-att-src="upiQrSrc" class="upi-qr-image" alt="UPI QR Code"/>
                    </div>
                </t>
            </div>
        </div>

        <!-- Loyalty Points -->
        <t t-if="order.loyalty_points">
            <div class="loyalty-points-block">
                <span>&#127942; Loyalty Points Earned:</span>
                <span><t t-esc="order.loyalty_points"/></span>
            </div>
        </t>

        <!-- SERVED BY (left) + DATE WITH TIME (right) -->
        <div class="receipt-footer-row" style="border-top:1px dashed #000; padding-top:4px; margin-top:6px;">
            <div>Served by: <t t-esc="order.getCashierName() or ''"/></div>
            <div><t t-esc="order.formatDateOrTime('date_order')"/></div>
        </div>

    </xpath>

    <!-- Hide bottom duplicate company address block -->
    <xpath expr="//div[@class='d-flex gap-2 pt-3']" position="replace"/>

    <!-- Hide "Powered by Odoo" -->
    <xpath expr="//div[@class='pos-receipt-order-data text-center pt-3']" position="replace"/>

</t>
</templates>