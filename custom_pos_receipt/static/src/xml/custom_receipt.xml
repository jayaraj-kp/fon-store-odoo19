<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">

    <!-- ===================================================== -->
    <!-- 1️⃣ CUSTOM HEADER (Logo Left, Company Right)          -->
    <!-- ===================================================== -->

    <xpath expr="//div[contains(@class,'pos-receipt-header')]" position="replace">

        <div class="receipt-header-row">

            <div class="receipt-logo-cell">
                <img t-if="header.company_logo"
                     t-att-src="header.company_logo"
                     class="receipt-company-logo"/>
            </div>

            <div class="receipt-company-cell">
                <div class="company-name">
                    <t t-esc="header.company.name"/>
                </div>
                <div t-esc="header.company.street"/>
                <div t-esc="header.company.city"/>
                <div t-esc="header.company.phone"/>
            </div>

        </div>

    </xpath>

    <!-- ===================================================== -->
    <!-- 2️⃣ INVOICE META ROW                                  -->
    <!-- ===================================================== -->

    <xpath expr="//div[contains(@class,'pos-receipt-contact')]" position="before">

        <div class="receipt-meta-row">

            <div class="receipt-invoice-no">
                Invoice: <t t-esc="order.name"/>
            </div>

            <div class="receipt-invoice-date">
                <t t-esc="order.date_order"/>
            </div>

        </div>

    </xpath>

    <!-- ===================================================== -->
    <!-- 3️⃣ REMOVE DEFAULT TOTAL BLOCK                        -->
    <!-- ===================================================== -->

    <xpath expr="//div[contains(@class,'pos-receipt-amount')]" position="replace"/>

    <!-- ===================================================== -->
    <!-- 4️⃣ CUSTOM TOTAL + GST (KEEP before-footer class)     -->
    <!-- ===================================================== -->

    <xpath expr="//div[contains(@class,'before-footer')]" position="replace">

        <div class="before-footer">

            <!-- ===== Custom Total ===== -->

            <div class="custom-total-section">

                <div class="line">
                    <span>Taxable</span>
                    <span>
                        <t t-esc="formatCurrency(order.getTotalTaxableAmount())"/>
                    </span>
                </div>

                <div class="line">
                    <span>CGST</span>
                    <span>
                        <t t-esc="formatCurrency(order.getTotalCgst())"/>
                    </span>
                </div>

                <div class="line">
                    <span>SGST</span>
                    <span>
                        <t t-esc="formatCurrency(order.getTotalSgst())"/>
                    </span>
                </div>

                <div class="line total">
                    <span>Grand Total</span>
                    <span>
                        <t t-esc="formatCurrency(order.getGrandTotal())"/>
                    </span>
                </div>

                <div class="amount-words">
                    <t t-esc="order.getAmountInWords()"/>
                </div>

            </div>

            <!-- ===== QR ROW ===== -->

            <div class="receipt-qr-row">

                <!-- Left: Invoice QR -->
                <div class="receipt-qr-cell">
                    <div class="qr-cell-label">Need Invoice?</div>

                    <img t-if="receipt.qr_code_data"
                         t-att-src="receipt.qr_code_data"
                         class="qr-code"/>

                    <div class="qr-cell-code">
                        <t t-esc="receipt.ticket_code"/>
                    </div>
                </div>

                <!-- Right: Payment QR (from your other module) -->
                <div class="receipt-qr-cell"
                     t-if="receipt.upi_qr_code">

                    <div class="qr-cell-label">Scan &amp; Pay</div>

                    <div class="upi-qr-image-container">
                        <img t-att-src="receipt.upi_qr_code"
                             class="upi-qr-image"/>
                    </div>

                    <div class="upi-qr-vpa">
                        <t t-esc="receipt.upi_id"/>
                    </div>

                </div>

            </div>

            <!-- ===== GST Table ===== -->

            <div class="gst-table-wrapper">

                <t t-set="gstLines"
                   t-value="order.getGstBreakdown()"/>

                <table class="gst-breakdown-table"
                       t-if="gstLines and gstLines.length">

                    <thead>
                        <tr>
                            <th>GST%</th>
                            <th class="text-right">Taxable</th>
                            <th class="text-right">CGST</th>
                            <th class="text-right">SGST</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-foreach="gstLines"
                           t-as="gline"
                           t-key="gline.rate">

                            <tr>
                                <td><t t-esc="gline.rate"/>%</td>
                                <td class="text-right">
                                    <t t-esc="formatCurrency(gline.taxable)"/>
                                </td>
                                <td class="text-right">
                                    <t t-esc="formatCurrency(gline.cgst)"/>
                                </td>
                                <td class="text-right">
                                    <t t-esc="formatCurrency(gline.sgst)"/>
                                </td>
                            </tr>

                        </t>
                    </tbody>

                </table>

            </div>

        </div>

    </xpath>

    <!-- ===================================================== -->
    <!-- 5️⃣ FOOTER (Served By Left | Date Right)              -->
    <!-- ===================================================== -->

    <xpath expr="//div[contains(@class,'pos-receipt-footer')]" position="replace">

        <div class="receipt-footer-row">

            <div>
                Served By:
                <t t-esc="order.get_cashier().name"/>
            </div>

            <div>
                <t t-esc="order.date_order"/>
            </div>

        </div>

    </xpath>

</t>

</templates>



