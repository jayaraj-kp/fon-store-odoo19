<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">

    <xpath expr="//ReceiptHeader" position="replace">
        <t t-set="co" t-value="receiptCompany"/>
        <div class="receipt-header-row">
            <div class="receipt-logo-cell">
                <img t-att-src="logoUrl" class="receipt-company-logo" alt="Logo"/>
            </div>
            <div class="receipt-company-cell">
                <div class="company-name"><t t-esc="co.name"/></div>
                <t t-if="co.street"><div><t t-esc="co.street"/></div></t>
                <t t-if="co.city">
                    <div><t t-esc="co.city"/><t t-if="co.zip">, <t t-esc="co.zip"/></t></div>
                </t>
                <t t-if="co.vat"><div>GSTIN: <t t-esc="co.vat"/></div></t>
                <t t-if="co.phone"><div>Tel: <t t-esc="co.phone"/></div></t>
                <t t-if="co.email"><div><t t-esc="co.email"/></div></t>
            </div>
        </div>
        <div class="receipt-meta-row">
            <div class="receipt-invoice-no"><strong>Invoice: </strong><t t-esc="receiptRef"/></div>
            <div class="receipt-invoice-date"><t t-esc="receiptDate"/></div>
        </div>
        <t t-set="partner" t-value="receiptPartner"/>
        <t t-if="partner">
            <div class="receipt-customer-block">
                <div class="customer-name">
                    <t t-if="partner.parent_name"><span t-esc="partner.parent_name"/>, </t>
                    <span t-esc="partner.name"/>
                </div>
                <t t-if="partner.pos_contact_address">
                    <div><t t-esc="partner.pos_contact_address"/></div>
                </t>
                <t t-if="partner.phone"><div>Phone: <t t-esc="partner.phone"/></div></t>
            </div>
        </t>
    </xpath>

    <xpath expr="//span[@class='label-discount']" position="replace" optional="hide">
        <span class="label-discount">🎉 You Have Saved 🎉</span>
    </xpath>

    <xpath expr="//div[hasclass('receipt-total')]" position="replace"/>
    <xpath expr="//div[hasclass('receipt-rounding')]" position="replace" optional="hide"/>
    <xpath expr="//div[hasclass('receipt-to-pay')]" position="replace" optional="hide"/>
    <xpath expr="//div[hasclass('paymentlines')]" position="replace"/>
    <xpath expr="//div[hasclass('receipt-change')]" position="replace" optional="hide"/>
    <xpath expr="//div[hasclass('pos-receipt-taxes')]" position="replace" optional="hide"/>
    <xpath expr="//t[@t-set='company']" position="replace"/>
    <xpath expr="//div[hasclass('pos-config-name')]/.." position="replace"/>
    <xpath expr="//div[hasclass('pos-receipt-order-data')]" position="replace" optional="hide"/>
    <xpath expr="//img[@id='posqrcode']" position="replace" optional="hide"/>

    <xpath expr="//div[@class='before-footer']" position="before">

        <div class="custom-total-section">
            <div class="line">
                <span>Before Grand Total</span>
                <span><t t-esc="formatCurrency(order.getBeforeGrandTotal())"/></span>
            </div>
            <div class="line">
                <span>Taxable Total</span>
                <span><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></span>
            </div>
            <div class="line">
                <span>CGST</span>
                <span><t t-esc="formatCurrency(order.getTotalCgst())"/></span>
            </div>
            <div class="line">
                <span>SGST</span>
                <span><t t-esc="formatCurrency(order.getTotalSgst())"/></span>
            </div>
            <div class="line total">
                <span>Grand Total</span>
                <span><t t-esc="formatCurrency(order.getGrandTotal())"/></span>
            </div>
            <div class="amount-words">
                <t t-esc="order.getAmountInWords()"/>
            </div>
            <div class="saved-line">
                <span>🎉 You Have Saved 🎉</span>
                <span><t t-esc="formatCurrency(order.getTotalSaved())"/></span>
            </div>
        </div>

        <div class="receipt-qr-row">
            <div class="receipt-qr-cell">
                <t t-if="receiptCompany.point_of_sale_use_ticket_qr_code and order.finalized">
                    <div class="qr-cell-label">Need an invoice?</div>
                    <img t-att-src="qrCode" class="qr-code" alt="Invoice QR"/>
                    <div class="qr-cell-code">Code: <t t-out="order.ticket_code"/></div>
                </t>
            </div>
            <div class="receipt-qr-cell">
                <t t-if="upiQrSrc">
                    <div class="qr-cell-label">
                        <span class="upi-logo-text">UPI</span>
                        Scan &amp; Pay &#x20B9;<t t-esc="upiAmount"/>
                    </div>
                    <div class="upi-qr-image-container">
                        <img t-att-src="upiQrSrc" class="upi-qr-image" alt="UPI QR Code"/>
                    </div>
                    <div class="upi-qr-vpa"><t t-esc="upiVpa"/></div>
                    <div class="upi-qr-apps">GPay · PhonePe · Paytm · BHIM</div>
                </t>
            </div>
        </div>

        <t t-set="gstLines" t-value="order.getGstBreakdown()"/>
        <t t-if="gstLines and gstLines.length">
            <div class="gst-table-wrapper">
                <table class="gst-breakdown-table">
                    <thead>
                        <tr>
                            <th>GST Rate</th>
                            <th class="text-right">Taxable</th>
                            <th class="text-right">CGST</th>
                            <th class="text-right">SGST</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="gstLines" t-as="gline" t-key="gline.rate">
                            <tr>
                                <td><t t-esc="gline.label"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.taxable)"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.cgst)"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.sgst)"/></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td><strong>Total</strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalCgst())"/></strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalSgst())"/></strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </t>

        <t t-if="order.loyalty_points">
            <div class="loyalty-points-block">
                <span>🏆 Loyalty Points Earned:</span>
                <span><t t-esc="order.loyalty_points"/></span>
            </div>
        </t>

        <div class="receipt-footer-row">
            <div>Served by: <t t-esc="receiptCashier"/></div>
            <div><t t-esc="receiptDate"/></div>
        </div>

    </xpath>

</t>

</templates>