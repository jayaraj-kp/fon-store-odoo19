<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ===================================================== -->
    <!-- OVERRIDE SCREEN RECEIPT -->
    <!-- ===================================================== -->

    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">

        <xpath expr="//div[contains(@class,'pos-receipt-amount')]" position="replace">
            <div class="custom-total-section">
                <div class="line total">
                    <span>Grand Total</span>
                    <span>
                        <t t-esc="formatCurrency(order.amount_total)"/>
                    </span>
                </div>
            </div>
        </xpath>

    </t>


    <!-- ===================================================== -->
    <!-- OVERRIDE PRINT RECEIPT (IMPORTANT PART) -->
    <!-- ===================================================== -->

    <t t-inherit="point_of_sale.PosTicket" t-inherit-mode="extension">

        <!-- Remove default totals -->
        <xpath expr="//div[contains(@class,'pos-receipt-amount')]" position="replace">
            <div class="custom-total-section">
                <div class="line total">
                    <span>Grand Total</span>
                    <span>
                        <t t-esc="formatCurrency(props.data.amount_total)"/>
                    </span>
                </div>
            </div>
        </xpath>

        <!-- Remove payment lines -->
        <xpath expr="//div[contains(@class,'paymentlines')]" position="replace"/>

    </t>

</templates>