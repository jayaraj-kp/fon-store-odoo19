<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- ========================= EXTEND ORDER RECEIPT ========================= -->
    <t t-name="CustomPosReceipt" t-extend="point_of_sale.OrderReceipt">

        <!-- ================= HEADER ================= -->
        <t t-jquery=".receipt-header-row" t-operation="replace">
            <div class="receipt-header-row">
                <div class="receipt-logo-cell">
                    <img t-if="header.company_logo" t-att-src="header.company_logo" class="receipt-company-logo"/>
                </div>
                <div class="receipt-company-cell">
                    <div class="company-name"><t t-esc="header.company.name"/></div>
                    <div><t t-esc="header.company.street"/></div>
                    <div><t t-esc="header.company.city"/></div>
                    <div><t t-esc="header.company.phone"/></div>
                </div>
            </div>
        </t>

        <!-- ================= ORDER LINES ================= -->
        <t t-jquery=".receipt-orderline" t-operation="after">
            <t t-if="line.l10n_in_hsn_code && header.company.country_id?.code === 'IN'">
                <div class="pos-receipt-left-padding">
                    <span>HSN Code: </span>
                    <t t-esc="line.l10n_in_hsn_code"/>
                </div>
            </t>
        </t>

        <!-- ================= GST BREAKDOWN ================= -->
        <t t-jquery=".receipt-totals" t-operation="after">
            <div class="receipt-gst-breakdown">
                <t t-foreach="order.getGstBreakdown()" t-as="gst">
                    <div>
                        <span><t t-esc="gst.label"/>:</span>
                        <span>Taxable: <t t-esc="gst.taxable.toFixed(2)"/></span>,
                        <span>CGST: <t t-esc="gst.cgst.toFixed(2)"/></span>,
                        <span>SGST: <t t-esc="gst.sgst.toFixed(2)"/></span>
                    </div>
                </t>
            </div>
        </t>

        <!-- ================= TOTALS ================= -->
        <t t-jquery=".receipt-total" t-operation="replace">
            <div class="receipt-total">
                <div><span>Subtotal:</span> <span><t t-esc="order.getBeforeGrandTotal().toFixed(2)"/></span></div>
                <div><span>Discount:</span> <span><t t-esc="order.getTotalSaved().toFixed(2)"/></span></div>
                <div><span>CGST Total:</span> <span><t t-esc="order.getTotalCgst().toFixed(2)"/></span></div>
                <div><span>SGST Total:</span> <span><t t-esc="order.getTotalSgst().toFixed(2)"/></span></div>
                <div><span>Grand Total:</span> <span><t t-esc="order.getGrandTotal().toFixed(2)"/></span></div>
                <div><span>In Words:</span> <span><t t-esc="order.getAmountInWords()"/></span></div>
            </div>
        </t>

    </t>
</templates>



