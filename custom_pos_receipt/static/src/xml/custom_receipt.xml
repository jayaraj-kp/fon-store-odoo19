<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">

        <!-- Replace FULL template -->
        <xpath expr="." position="replace">

            <div class="pos-receipt">

                <!-- HEADER -->
                <div class="receipt-header">
                    <h3>
                        <t t-esc="header.company.name"/>
                    </h3>
                </div>

                <hr/>

                <!-- ORDER LINES -->
                <t t-foreach="order.get_orderlines()" t-as="line" t-key="line.id">
                    <div class="receipt-line">
                        <span>
                            <t t-esc="line.get_product().display_name"/>
                        </span>
                        <span class="text-right">
                            <t t-esc="formatCurrency(line.get_display_price())"/>
                        </span>
                    </div>

                    <!-- HSN SAFE DISPLAY -->
                    <t t-if="line.l10n_in_hsn_code">
                        <div style="font-size:12px; padding-left:10px;">
                            HSN: <t t-esc="line.l10n_in_hsn_code"/>
                        </div>
                    </t>

                </t>

                <hr/>

                <!-- CUSTOM TOTAL SECTION -->
                <div class="custom-total-section">

                    <div>
                        Before Grand Total:
                        <t t-esc="formatCurrency(order.getBeforeGrandTotal?.() || 0)"/>
                    </div>

                    <div>
                        Taxable Total:
                        <t t-esc="formatCurrency(order.getTotalTaxableAmount?.() || 0)"/>
                    </div>

                    <div>
                        CGST:
                        <t t-esc="formatCurrency(order.getTotalCgst?.() || 0)"/>
                    </div>

                    <div>
                        SGST:
                        <t t-esc="formatCurrency(order.getTotalSgst?.() || 0)"/>
                    </div>

                    <div style="font-weight:bold;">
                        Grand Total:
                        <t t-esc="formatCurrency(order.get_total_with_tax())"/>
                    </div>

                </div>

            </div>

        </xpath>

    </t>

</templates>