<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">

    <!-- Remove Grand Total block (pos-receipt-amount div) -->
    <xpath expr="//div[hasclass('pos-receipt-amount')]" position="replace"/>

    <!-- Remove payment lines block -->
    <xpath expr="//div[hasclass('paymentlines')]" position="replace"/>

    <!--
        HIDE: Subtotal + GST default rows.
        In Odoo 17/18/19 these live inside the t-if="!isTaxIncluded" block.
        Replacing this node removes both the Subtotal and GST lines at once.
    -->
    <xpath expr="//t[@t-if='!isTaxIncluded']" position="replace" optional="hide"/>

    <!--
        HIDE: You Have Saved / discount line.
        In Odoo 19 the discount total is shown in a t-if block on total_discount.
    -->
    <xpath expr="//t[@t-if='receipt.total_discount']" position="replace" optional="hide"/>

    <!--
        HIDE: Need an invoice? and Code: text shown above the QR.
        Using hasclass() as required by Odoo 17+.
    -->
    <xpath expr="//div[hasclass('ask-for-invoice')]" position="replace" optional="hide"/>

    <!-- Fallback for older structure where ask-for-invoice is a t-if -->
    <xpath expr="//t[@t-if='receipt.ask_for_invoice']" position="replace" optional="hide"/>

    <!-- Remove QR description paragraph (Code: fsfdk line) -->
    <xpath expr="//div[hasclass('pos-receipt-qrcode')]//p" position="replace" optional="hide"/>

    <!-- Resize QR code -->
    <xpath expr="//img[@id='posqrcode']" position="attributes" optional="hide">
        <attribute name="style">width:90px;height:90px;display:block;margin:0 auto;</attribute>
    </xpath>

    <!-- Insert GST table and custom totals before footer -->
    <xpath expr="//div[@class='before-footer']" position="before">

        <t t-set="gstLines" t-value="order.getGstBreakdown()"/>
        <t t-if="gstLines and gstLines.length">
            <div class="gst-table-wrapper">
                <table class="gst-breakdown-table">
                    <thead>
                        <tr>
                            <th>GST Rate</th>
                            <th class="text-right">Taxable</th>
                            <th class="text-right">CGST</th>
                            <th class="text-right">SGST</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="gstLines" t-as="gline" t-key="gline.rate">
                            <tr>
                                <td><t t-esc="gline.label"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.taxable)"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.cgst)"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.sgst)"/></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td><strong>Total</strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalCgst())"/></strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalSgst())"/></strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </t>

        <div class="custom-total-section">

            <div class="line">
                <span>Before Grand Total</span>
                <span><t t-esc="formatCurrency(order.getBeforeGrandTotal())"/></span>
            </div>

            <div class="line">
                <span>Taxable Total</span>
                <span><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></span>
            </div>

            <div class="line">
                <span>CGST</span>
                <span><t t-esc="formatCurrency(order.getTotalCgst())"/></span>
            </div>

            <div class="line">
                <span>SGST</span>
                <span><t t-esc="formatCurrency(order.getTotalSgst())"/></span>
            </div>

            <div class="line total">
                <span>Grand Total</span>
                <span><t t-esc="formatCurrency(order.getGrandTotal())"/></span>
            </div>

            <div class="amount-words">
                <t t-esc="order.getAmountInWords()"/>
            </div>

            <div class="saved-line">
                <span>&#127881; You Have Saved &#127881;</span>
                <span><t t-esc="formatCurrency(order.getTotalSaved())"/></span>
            </div>

        </div>

    </xpath>

</t>

</templates>