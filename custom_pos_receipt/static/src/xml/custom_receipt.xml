<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">

    <!-- ===================================================== -->
    <!-- 1️⃣ INSERT CUSTOM HEADER AT TOP (SAFE)                 -->
    <!-- ===================================================== -->

    <xpath expr="//div[contains(@class,'pos-receipt')]" position="inside">

        <div class="receipt-header-row">

            <div class="receipt-logo-cell">
                <img t-if="header.company_logo"
                     t-att-src="header.company_logo"
                     class="receipt-company-logo"/>
            </div>

            <div class="receipt-company-cell">
                <div class="company-name">
                    <t t-esc="header.company.name"/>
                </div>
                <div t-esc="header.company.street"/>
                <div t-esc="header.company.city"/>
                <div t-esc="header.company.phone"/>
            </div>

        </div>

        <div class="receipt-meta-row">
            <div>Invoice: <t t-esc="order.name"/></div>
            <div><t t-esc="order.date_order"/></div>
        </div>

    </xpath>

    <!-- ===================================================== -->
    <!-- 2️⃣ REMOVE DEFAULT TOTAL BLOCK SAFELY                 -->
    <!-- ===================================================== -->

    <xpath expr="//div[contains(@class,'pos-receipt-amount')]" position="replace"/>

    <!-- ===================================================== -->
    <!-- 3️⃣ REPLACE before-footer (SAFE ANCHOR)               -->
    <!-- ===================================================== -->

    <xpath expr="//div[contains(@class,'before-footer')]" position="replace">

        <div class="before-footer">

            <!-- ===== Custom Totals ===== -->

            <div class="custom-total-section">

                <div class="line">
                    <span>Taxable</span>
                    <span>
                        <t t-esc="formatCurrency(order.get_total_with_tax() - order.get_total_tax())"/>
                    </span>
                </div>

                <div class="line">
                    <span>Total Tax</span>
                    <span>
                        <t t-esc="formatCurrency(order.get_total_tax())"/>
                    </span>
                </div>

                <div class="line total">
                    <span>Grand Total</span>
                    <span>
                        <t t-esc="formatCurrency(order.get_total_with_tax())"/>
                    </span>
                </div>

            </div>

            <!-- ===== QR Section ===== -->

            <div class="receipt-qr-row">

                <div class="receipt-qr-cell">
                    <img t-if="receipt.qr_code_data"
                         t-att-src="receipt.qr_code_data"
                         style="width:80px;"/>
                </div>

                <div class="receipt-qr-cell"
                     t-if="receipt.upi_qr_code">

                    <img t-att-src="receipt.upi_qr_code"
                         style="width:80px;"/>

                </div>

            </div>

        </div>

    </xpath>

</t>

</templates>



