<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<!-- ==================== TEMPLATE 1: RECEIPT HEADER ==================== -->
<t t-name="point_of_sale.ReceiptHeader"
   t-inherit="point_of_sale.ReceiptHeader"
   t-inherit-mode="extension">

    <xpath expr="//img[@class='pos-receipt-logo']" position="replace">
        <div class="receipt-header-row">
            <div class="receipt-logo-cell">
                <img t-att-src="logoUrl" alt="Logo" class="receipt-company-logo"/>
            </div>
            <div class="receipt-company-cell">
                <t t-set="co" t-value="order.company"/>
                <!-- Company name split at first space onto two lines -->
                <t t-set="nameLines" t-value="order.getCompanyNameLines()"/>
                <div class="company-name">
                    <t t-esc="nameLines[0]"/>
                    <t t-if="nameLines.length > 1">
                        <br/><t t-esc="nameLines.slice(1).join(' ')"/>
                    </t>
                </div>
                <t t-if="co.street"><div><t t-esc="co.street"/></div></t>
                <t t-if="co.city">
                    <div><t t-esc="co.city"/><t t-if="co.zip">, <t t-esc="co.zip"/></t></div>
                </t>
                <t t-if="co.vat"><div>GSTIN: <t t-esc="co.vat"/></div></t>
                <t t-if="co.phone"><div>Tel: <t t-esc="co.phone"/></div></t>
                <!-- Email intentionally omitted -->
            </div>
        </div>
    </xpath>

</t>

<!-- ==================== TEMPLATE 2: ORDER RECEIPT ==================== -->
<t t-name="point_of_sale.OrderReceipt"
   t-inherit="point_of_sale.OrderReceipt"
   t-inherit-mode="extension">

    <!-- Invoice # + Date + Customer block -->
    <xpath expr="//div[@class='pt-3']" position="replace">
        <div style="border-top:1px dashed #000; margin-top:4px; padding-top:4px;">
            <div class="receipt-meta-row">
                <div><strong>Invoice# <t t-esc="order.pos_reference"/></strong></div>
                <div><t t-esc="order.getReceiptDateFormatted()"/></div>
            </div>
            <t t-if="order.partner_id">
                <div class="receipt-customer-inline">
                    <strong><t t-esc="order.partner_id.name"/></strong>
                    <t t-if="order.partner_id.phone">
                        <div>Phone: <t t-esc="order.partner_id.phone"/></div>
                    </t>
                    <t t-if="order.partner_id.vat">
                        <div>GSTIN: <t t-esc="order.partner_id.vat"/></div>
                    </t>
                </div>
            </t>
        </div>
    </xpath>

    <!-- Custom items table (RATE removed, GST column added) -->
    <xpath expr="//OrderDisplay" position="before">
        <table class="custom-items-table">
            <thead>
                <tr class="items-thead">
                    <th class="col-sn">SN</th>
                    <th class="col-item">ITEM</th>
                    <th class="col-qty">QTY</th>
                    <th class="col-gst">GST</th>
                    <th class="col-total">TOTAL</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="order.getReceiptLines()" t-as="line" t-key="line.sn">
                    <tr class="items-row">
                        <td class="col-sn"><t t-esc="line.sn"/></td>
                        <td class="col-item">
                            <t t-esc="line.name"/>
                            <t t-if="line.note">
                                <div class="item-note"><t t-esc="line.note"/></div>
                            </t>
                        </td>
                        <td class="col-qty"><t t-esc="line.qty"/></td>
                        <td class="col-gst"><t t-esc="line.gst"/>%</td>
                        <td class="col-total"><t t-esc="formatCurrency(line.total)"/></td>
                    </tr>
                </t>
            </tbody>
        </table>
    </xpath>

    <!-- Keep OrderDisplay hidden for l10n_in_pos compatibility -->
    <xpath expr="//OrderDisplay" position="replace">
        <div style="display:none;">
            <OrderDisplay order="order" t-slot-scope="scope" mode="'receipt'">
                <t t-set="line" t-value="scope.line"/>
                <Orderline line="line" mode="'receipt'"/>
            </OrderDisplay>
        </div>
    </xpath>

    <!-- Hide default Odoo blocks -->
    <xpath expr="//div[@class='pos-receipt-taxes pt-3']" position="replace"/>
    <xpath expr="//div[@class='pos-receipt-amount receipt-total fw-bolder']" position="replace"/>
    <xpath expr="//div[@class='paymentlines text-start pt-1']" position="replace"/>
    <xpath expr="//div[@class='pos-receipt-amount receipt-change']" position="replace"/>
    <xpath expr="//div[@class='text-start']" position="replace"/>
    <xpath expr="//div[@class='gap-2 d-flex flex-row pt-3']" position="replace"/>

    <!-- ============================================================
         CUSTOM BOTTOM SECTION — ORDER:
         ① Grand Total summary
         ② QR codes (Scan for Invoice  |  UPI Pay)
         ③ GST breakdown table
         ④ Amount in words
         ⑤ Loyalty points + expiry
         ⑥ Salutation
         ⑦ Footer — date/time only (Served by removed)
    ============================================================ -->
    <xpath expr="//div[@class='before-footer']" position="before">

        <!-- ① GRAND TOTAL SUMMARY -->
        <div class="custom-total-section">
            <div class="line">
                <span>Taxable Amount</span>
                <span><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></span>
            </div>
            <div class="line">
                <span>CGST</span>
                <span><t t-esc="formatCurrency(order.getTotalCgst())"/></span>
            </div>
            <div class="line">
                <span>SGST</span>
                <span><t t-esc="formatCurrency(order.getTotalSgst())"/></span>
            </div>
            <div class="line total">
                <span>Grand Total</span>
                <span><t t-esc="formatCurrency(order.getGrandTotal())"/></span>
            </div>
            <t t-if="order.getTotalSaved()">
                <div class="saved-line">
                    <span>&#127881; You Have Saved &#127881;</span>
                    <span><t t-esc="formatCurrency(order.getTotalSaved())"/></span>
                </div>
            </t>
        </div>

        <!-- ② QR CODES — left: Scan for Invoice (small) | right: UPI Pay -->
        <div class="receipt-qr-row">
            <div class="receipt-qr-cell">
                <t t-if="order.company.point_of_sale_use_ticket_qr_code and order.finalized and this.qrCode">
                    <div class="qr-cell-label">Scan for Invoice</div>
                    <img t-att-src="this.qrCode" class="qr-code qr-invoice-small" alt="Invoice QR"/>
                    <t t-if="order.ticket_code">
                        <div class="qr-cell-code">Code: <t t-out="order.ticket_code"/></div>
                    </t>
                </t>
            </div>
            <div class="receipt-qr-cell">
                <t t-if="upiQrSrc">
                    <div class="qr-cell-label">Scan &amp; Pay &#x20B9;</div>
                    <div class="upi-qr-image-container">
                        <img t-att-src="upiQrSrc" class="upi-qr-image" alt="UPI QR Code"/>
                    </div>
                </t>
            </div>
        </div>

        <!-- ③ GST BREAKDOWN TABLE — between QR codes and amount-in-words -->
        <t t-set="gstLines" t-value="order.getGstBreakdown()"/>
        <t t-if="gstLines and gstLines.length">
            <div class="gst-section">
                <table class="gst-table">
                    <thead>
                        <tr>
                            <th style="text-align:left;">GST%</th>
                            <th style="text-align:right;">Taxable</th>
                            <th style="text-align:right;">CGST</th>
                            <th style="text-align:right;">SGST</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="gstLines" t-as="gline" t-key="gline.rate">
                            <tr>
                                <td><t t-esc="gline.rate"/>%</td>
                                <td style="text-align:right;"><t t-esc="formatCurrency(gline.taxable)"/></td>
                                <td style="text-align:right;"><t t-esc="formatCurrency(gline.cgst)"/></td>
                                <td style="text-align:right;"><t t-esc="formatCurrency(gline.sgst)"/></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr class="gst-total-row">
                            <td><strong>Total</strong></td>
                            <td style="text-align:right;"><strong><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></strong></td>
                            <td style="text-align:right;"><strong><t t-esc="formatCurrency(order.getTotalCgst())"/></strong></td>
                            <td style="text-align:right;"><strong><t t-esc="formatCurrency(order.getTotalSgst())"/></strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </t>

        <!-- ④ AMOUNT IN WORDS -->
        <div class="amount-words">
            <t t-esc="order.getAmountInWords()"/>
        </div>

        <!-- ⑤ LOYALTY POINTS + EXPIRY -->
        <t t-set="loyaltyInfo" t-value="order.getLoyaltyInfo()"/>
        <t t-if="loyaltyInfo and loyaltyInfo.length">
            <div class="loyalty-block">
                <t t-foreach="loyaltyInfo" t-as="lp" t-key="lp_index">
                    <div class="loyalty-row">
                        <div class="loyalty-program">&#127942; <t t-esc="lp.program"/></div>
                        <div class="loyalty-detail">
                            <span>Points Earned: <strong><t t-esc="lp.points"/></strong></span>
                            <t t-if="lp.balance !== null and lp.balance !== undefined">
                                <span> &nbsp;|&nbsp; Total Balance: <strong><t t-esc="lp.balance"/></strong></span>
                            </t>
                        </div>
                        <t t-if="lp.expiry">
                            <div class="loyalty-expiry">Expires on: <strong><t t-esc="lp.expiry"/></strong></div>
                        </t>
                    </div>
                </t>
            </div>
        </t>

        <!-- ⑥ SALUTATION -->
        <div class="receipt-salutation">
            Thank you for shopping with us!
        </div>

        <!-- ⑦ FOOTER — date/time only, Served by removed -->
        <div class="receipt-footer-row">
            <div><t t-esc="order.formatDateOrTime('date_order')"/></div>
        </div>

    </xpath>

    <xpath expr="//div[@class='d-flex gap-2 pt-3']" position="replace"/>
    <xpath expr="//div[@class='pos-receipt-order-data text-center pt-3']" position="replace"/>

</t>
</templates>