<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">

    <!--
        CONFIRMED ODOO 18/19 approach:
        - Replace //div[@class='pos-receipt p-2'] with our full layout
        - Keep the outer div with EXACT same class "pos-receipt p-2"
        - All data via props.data.headerData (company info) and props.data (order info)
        - orderlines rendered via <OrderWidget> component — keeps l10n_in HSN working
    -->
    <xpath expr="//div[@class='pos-receipt p-2']" position="replace">
    <div class="pos-receipt p-2">

        <!-- ======================================================= -->
        <!-- ROW 1: Logo (left) + Company Details (right)            -->
        <!-- ======================================================= -->
        <t t-if="props.data and props.data.headerData">
        <div class="receipt-header-row">

            <div class="receipt-logo-cell">
                <img t-attf-src="/web/image?model=res.company&amp;id={{ props.data.headerData.company.id }}&amp;field=logo"
                     class="receipt-company-logo"
                     alt="Logo"/>
            </div>

            <div class="receipt-company-cell">
                <div class="company-name">
                    <t t-esc="props.data.headerData.company.name"/>
                </div>
                <t t-if="props.data.headerData.company.street">
                    <div><t t-esc="props.data.headerData.company.street"/></div>
                </t>
                <t t-if="props.data.headerData.company.city">
                    <div>
                        <t t-esc="props.data.headerData.company.city"/>
                        <t t-if="props.data.headerData.company.zip">, <t t-esc="props.data.headerData.company.zip"/></t>
                    </div>
                </t>
                <t t-if="props.data.headerData.company.vat">
                    <div>GSTIN: <t t-esc="props.data.headerData.company.vat"/></div>
                </t>
                <t t-if="props.data.headerData.company.phone">
                    <div>Tel: <t t-esc="props.data.headerData.company.phone"/></div>
                </t>
                <t t-if="props.data.headerData.company.email">
                    <div><t t-esc="props.data.headerData.company.email"/></div>
                </t>
            </div>

        </div>
        </t>

        <!-- ======================================================= -->
        <!-- ROW 2: Invoice No (left) + Date (right)                 -->
        <!-- ======================================================= -->
        <t t-if="props.data">
        <div class="receipt-meta-row">
            <div class="receipt-invoice-no">
                <strong>Invoice: </strong><t t-esc="props.data.name"/>
            </div>
            <div class="receipt-invoice-date">
                <t t-esc="props.data.date"/>
            </div>
        </div>
        </t>

        <!-- ======================================================= -->
        <!-- ROW 3: Customer Details                                  -->
        <!-- ======================================================= -->
        <t t-if="props.data and props.data.partner">
            <div class="receipt-customer-block">
                <div class="customer-name"><t t-esc="props.data.partner.name"/></div>
                <t t-if="props.data.partner.street">
                    <div><t t-esc="props.data.partner.street"/></div>
                </t>
                <t t-if="props.data.partner.city">
                    <div>
                        <t t-esc="props.data.partner.city"/>
                        <t t-if="props.data.partner.zip"> <t t-esc="props.data.partner.zip"/></t>
                    </div>
                </t>
                <t t-if="props.data.partner.phone">
                    <div>Phone: <t t-esc="props.data.partner.phone"/></div>
                </t>
            </div>
        </t>

        <!-- ======================================================= -->
        <!-- ROW 4: Order Lines — keep OrderWidget intact             -->
        <!-- l10n_in extends Orderline inside this, must stay         -->
        <!-- ======================================================= -->
        <OrderWidget
            lines="props.data.orderlines"
            formatCurrency="props.formatCurrency"
            />

        <!-- ======================================================= -->
        <!-- ROW 5: Custom Total Section                             -->
        <!-- ======================================================= -->
        <div class="custom-total-section">

            <div class="line">
                <span>Before Grand Total</span>
                <span><t t-esc="formatCurrency(order.getBeforeGrandTotal())"/></span>
            </div>

            <div class="line">
                <span>Taxable Total</span>
                <span><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></span>
            </div>

            <div class="line">
                <span>CGST</span>
                <span><t t-esc="formatCurrency(order.getTotalCgst())"/></span>
            </div>

            <div class="line">
                <span>SGST</span>
                <span><t t-esc="formatCurrency(order.getTotalSgst())"/></span>
            </div>

            <div class="line total">
                <span>Grand Total</span>
                <span><t t-esc="formatCurrency(order.getGrandTotal())"/></span>
            </div>

            <div class="amount-words">
                <t t-esc="order.getAmountInWords()"/>
            </div>

            <div class="saved-line">
                <span>🎉 You Have Saved 🎉</span>
                <span><t t-esc="formatCurrency(order.getTotalSaved())"/></span>
            </div>

        </div>

        <!-- ======================================================= -->
        <!-- ROW 6: QR Codes — Invoice QR (left) + UPI QR (right)   -->
        <!-- ======================================================= -->
        <div class="receipt-qr-row">

            <div class="receipt-qr-cell">
                <t t-if="props.qrCode">
                    <div class="qr-cell-label">Need an invoice?</div>
                    <img t-att-src="props.qrCode"
                         id="posqrcode"
                         class="qr-code"
                         alt="Invoice QR"/>
                    <t t-if="props.data and props.data.ticket_code">
                        <div class="qr-cell-code">Code: <t t-esc="props.data.ticket_code"/></div>
                    </t>
                </t>
            </div>

            <div class="receipt-qr-cell">
                <t t-if="upiQrSrc">
                    <div class="qr-cell-label">
                        <span class="upi-logo-text">UPI</span>
                        Scan &amp; Pay ₹<t t-esc="upiAmount"/>
                    </div>
                    <div class="upi-qr-image-container">
                        <img t-att-src="upiQrSrc"
                             class="upi-qr-image"
                             alt="UPI QR Code"/>
                    </div>
                    <div class="upi-qr-vpa"><t t-esc="upiVpa"/></div>
                    <div class="upi-qr-apps">GPay · PhonePe · Paytm · BHIM</div>
                </t>
            </div>

        </div>

        <!-- ======================================================= -->
        <!-- ROW 7: GST Table                                        -->
        <!-- ======================================================= -->
        <t t-set="gstLines" t-value="order.getGstBreakdown()"/>
        <t t-if="gstLines and gstLines.length">
            <div class="gst-table-wrapper">
                <table class="gst-breakdown-table">
                    <thead>
                        <tr>
                            <th>GST Rate</th>
                            <th class="text-right">Taxable</th>
                            <th class="text-right">CGST</th>
                            <th class="text-right">SGST</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="gstLines" t-as="gline" t-key="gline.rate">
                            <tr>
                                <td><t t-esc="gline.label"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.taxable)"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.cgst)"/></td>
                                <td class="text-right"><t t-esc="formatCurrency(gline.sgst)"/></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td><strong>Total</strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalTaxableAmount())"/></strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalCgst())"/></strong></td>
                            <td class="text-right"><strong><t t-esc="formatCurrency(order.getTotalSgst())"/></strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </t>

        <!-- ======================================================= -->
        <!-- ROW 8: Loyalty Points                                   -->
        <!-- ======================================================= -->
        <t t-if="props.data and props.data.loyalty_points">
            <div class="loyalty-points-block">
                <span>🏆 Loyalty Points Earned:</span>
                <span><t t-esc="props.data.loyalty_points"/></span>
            </div>
        </t>

        <!-- ======================================================= -->
        <!-- ROW 9: Footer — Served By (left) + Date (right)        -->
        <!-- ======================================================= -->
        <t t-if="props.data and props.data.headerData">
            <div class="receipt-footer-row">
                <div>Served by: <t t-esc="props.data.headerData.cashier"/></div>
                <div><t t-esc="props.data.date"/></div>
            </div>
        </t>

        <!-- Keep before/after footer for Powered by Odoo etc -->
        <div class="before-footer"/>
        <div class="after-footer"/>

    </div>
    </xpath>

</t>

</templates>