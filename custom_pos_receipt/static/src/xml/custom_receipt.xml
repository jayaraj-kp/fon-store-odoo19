<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-name="CustomOrderReceipt" owl="1">

    <!-- HEADER: Logo + Company Details -->
    <div class="receipt-header-row">
        <div class="receipt-logo-cell">
            <img t-att-src="props.order.pos.company.logo" class="receipt-company-logo" alt="Logo"/>
        </div>
        <div class="receipt-company-cell">
            <div t-esc="props.order.pos.company.name"/>
            <div t-esc="props.order.pos.company.street"/>
            <div t-esc="props.order.pos.company.city"/>
            <div t-if="props.order.pos.company.vat">GSTIN: <t t-esc="props.order.pos.company.vat"/></div>
            <div t-if="props.order.pos.company.phone">Tel: <t t-esc="props.order.pos.company.phone"/></div>
            <div t-if="props.order.pos.company.email"><t t-esc="props.order.pos.company.email"/></div>
        </div>
    </div>

    <!-- Invoice Number + Date -->
    <div class="receipt-meta-row">
        <div class="receipt-invoice-no">Invoice: <t t-esc="props.order.name"/></div>
        <div class="receipt-invoice-date"><t t-esc="props.order.creation_date"/></div>
    </div>

    <!-- Customer Details -->
    <t t-if="props.order.partner">
        <div class="receipt-customer-block">
            <div class="customer-name"><t t-esc="props.order.partner.name"/></div>
            <div t-if="props.order.partner.phone">Phone: <t t-esc="props.order.partner.phone"/></div>
        </div>
    </t>

    <!-- CUSTOM TOTALS -->
    <div class="custom-total-section">
        <div class="line">
            <span>Before Grand Total</span>
            <span><t t-esc="props.order.getBeforeGrandTotal()"/></span>
        </div>
        <div class="line">
            <span>Taxable Total</span>
            <span><t t-esc="props.order.getTotalTaxableAmount()"/></span>
        </div>
        <div class="line">
            <span>CGST</span>
            <span><t t-esc="props.order.getTotalCgst()"/></span>
        </div>
        <div class="line">
            <span>SGST</span>
            <span><t t-esc="props.order.getTotalSgst()"/></span>
        </div>
        <div class="line total">
            <span>Grand Total</span>
            <span><t t-esc="props.order.getGrandTotal()"/></span>
        </div>
        <div class="amount-words">
            <t t-esc="props.order.getAmountInWords()"/>
        </div>
        <div class="saved-line">
            <span>🎉 You Have Saved 🎉</span>
            <span><t t-esc="props.order.getTotalSaved()"/></span>
        </div>
    </div>

    <!-- GST Table -->
    <t t-set="gstLines" t-value="props.order.getGstBreakdown()"/>
    <t t-if="gstLines and gstLines.length">
        <div class="gst-table-wrapper">
            <table class="gst-breakdown-table">
                <thead>
                    <tr>
                        <th>GST Rate</th>
                        <th class="text-right">Taxable</th>
                        <th class="text-right">CGST</th>
                        <th class="text-right">SGST</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="gstLines" t-as="gline" t-key="gline.rate">
                        <tr>
                            <td><t t-esc="gline.label"/></td>
                            <td class="text-right"><t t-esc="gline.taxable"/></td>
                            <td class="text-right"><t t-esc="gline.cgst"/></td>
                            <td class="text-right"><t t-esc="gline.sgst"/></td>
                        </tr>
                    </t>
                </tbody>
                <tfoot>
                    <tr>
                        <td><strong>Total</strong></td>
                        <td class="text-right"><strong><t t-esc="props.order.getTotalTaxableAmount()"/></strong></td>
                        <td class="text-right"><strong><t t-esc="props.order.getTotalCgst()"/></strong></td>
                        <td class="text-right"><strong><t t-esc="props.order.getTotalSgst()"/></strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </t>

    <!-- QR Codes and Footer -->
    <div class="receipt-qr-row">
        <!-- Invoice QR -->
        <div class="receipt-qr-cell">
            <t t-if="props.order.finalized">
                <div class="qr-cell-label">Need an invoice?</div>
                <img t-att-src="props.order.qrCode" class="qr-code"/>
                <div class="qr-cell-code">Code: <t t-esc="props.order.ticket_code"/></div>
            </t>
        </div>

        <!-- UPI QR -->
        <div class="receipt-qr-cell">
            <t t-if="props.order.upiQrSrc">
                <div class="qr-cell-label">
                    <span class="upi-logo-text">UPI</span>
                    Scan Pay &#x20B9;<t t-esc="props.order.upiAmount"/>
                </div>
                <div class="upi-qr-image-container">
                    <img t-att-src="props.order.upiQrSrc" class="upi-qr-image"/>
                </div>
                <div class="upi-qr-vpa"><t t-esc="props.order.upiVpa"/></div>
                <div class="upi-qr-apps">GPay · PhonePe · Paytm · BHIM</div>
            </t>
        </div>
    </div>

    <!-- Loyalty Points -->
    <t t-if="props.order.loyalty_points">
        <div class="loyalty-points-block">
            <span>🏆 Loyalty Points Earned:</span>
            <span><t t-esc="props.order.loyalty_points"/></span>
        </div>
    </t>

    <!-- Footer -->
    <div class="receipt-footer-row">
        <div>Served by: <t t-esc="props.order.cashier"/></div>
        <div><t t-esc="props.order.creation_date"/></div>
    </div>

</t>

</templates>


