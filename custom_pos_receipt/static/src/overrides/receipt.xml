<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Override the QR code + add GST table section -->
    <t t-name="pos_receipt_custom.GstTableSection" owl="1">
        <div class="pos-receipt-gst-qr-row">
            <!-- Reduced QR Code -->
            <div class="pos-receipt-qr-small">
                <t t-if="props.data.qr_code">
                    <img t-att-src="props.data.qr_code" class="qr-code-small"/>
                </t>
            </div>

            <!-- GST Summary Table -->
            <div class="pos-receipt-gst-table">
                <table>
                    <thead>
                        <tr>
                            <th>GST Rate</th>
                            <th>Taxable</th>
                            <th>CGST</th>
                            <th>SGST</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="props.gstRows" t-as="row" t-key="row_index">
                            <tr>
                                <td><t t-esc="row.rate"/></td>
                                <td class="text-right"><t t-esc="row.taxable"/></td>
                                <td class="text-right"><t t-esc="row.cgst"/></td>
                                <td class="text-right"><t t-esc="row.sgst"/></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr class="gst-total-row">
                            <td><strong>Total</strong></td>
                            <td class="text-right"><strong><t t-esc="props.gstTotals.taxable"/></strong></td>
                            <td class="text-right"><strong><t t-esc="props.gstTotals.cgst"/></strong></td>
                            <td class="text-right"><strong><t t-esc="props.gstTotals.sgst"/></strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </t>

    <t t-name="pos_receipt_custom.OrderReceipt" owl="1"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">

        <!-- Replace QR code node with our custom section -->
        <xpath expr="//div[hasclass('pos-receipt-qrcode')]" position="replace">
            <pos_receipt_custom.GstTableSection
                data="props.data"
                gstRows="getGstRows()"
                gstTotals="getGstTotals()"
            />
        </xpath>

    </t>

</templates>