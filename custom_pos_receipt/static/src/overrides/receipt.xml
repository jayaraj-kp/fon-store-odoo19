<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pos_receipt_custom.GstTableSection" owl="1">
        <div class="pos-receipt-gst-qr-row">
            <!-- Reduced QR Code -->
            <div class="pos-receipt-qr-small">
                <t t-if="props.data and props.data.qr_code">
                    <img t-att-src="props.data.qr_code" class="qr-code-small"/>
                </t>
            </div>

            <!-- GST Summary Table -->
            <div class="pos-receipt-gst-table">
                <table>
                    <thead>
                        <tr>
                            <th>GST Rate</th>
                            <th>Taxable</th>
                            <th>CGST</th>
                            <th>SGST</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="gstRows" t-as="row" t-key="row_index">
                            <tr>
                                <td><t t-esc="row.rate"/></td>
                                <td class="amt"><t t-esc="row.taxable"/></td>
                                <td class="amt"><t t-esc="row.cgst"/></td>
                                <td class="amt"><t t-esc="row.sgst"/></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr class="gst-total-row">
                            <td><b>Total</b></td>
                            <td class="amt"><b><t t-esc="gstTotals.taxable"/></b></td>
                            <td class="amt"><b><t t-esc="gstTotals.cgst"/></b></td>
                            <td class="amt"><b><t t-esc="gstTotals.sgst"/></b></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </t>

    <t t-name="point_of_sale.OrderReceipt" owl="1"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-qrcode')]" position="replace">
            <GstTableSection data="props.data"/>
        </xpath>
    </t>

</templates>