<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         Extend the POS Configuration form to add "Receipt Address" fields.
         Uses a safe xpath targeting the 'name' field which always exists.
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_pos_config_form_receipt_address" model="ir.ui.view">
        <field name="name">pos.config.form.receipt.address</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">

            <!-- Append our fields after the 'name' field at the top of the form -->
            <xpath expr="//field[@name='name']" position="after">
                <group string="Receipt Address (overrides company address on receipt)"
                       col="2" colspan="2">
                    <field name="pos_address_place"
                           placeholder="e.g.  MELE CHELARI"/>
                    <field name="pos_address_city_pin"
                           placeholder="e.g.  MALAPPURAM, 673636"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
