<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         SEARCH VIEW — filters, group-bys, favourites
    ═══════════════════════════════════════════════════════ -->
    <record id="view_pos_order_line_report_search" model="ir.ui.view">
        <field name="name">pos.order.line.report.search</field>
        <field name="model">pos.order.line</field>
        <field name="arch" type="xml">
            <search string="POS Sales Analysis">

                <!-- Quick search fields -->
                <field name="product_id" string="Product"/>
                <field name="product_category_id" string="Category"/>
                <field name="customer_id" string="Customer"/>
                <field name="session_id" string="Session"/>

                <!-- Filters -->
                <filter string="Done / Paid Orders" name="filter_done"
                        domain="[('order_state', 'in', ['done', 'paid', 'invoiced'])]"/>
                <filter string="Today" name="filter_today"
                        domain="[('order_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="filter_this_month"
                        domain="[('order_date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Positive Margin" name="filter_positive_margin"
                        domain="[('margin', '&gt;', 0)]"/>
                <filter string="Negative Margin (Loss)" name="filter_negative_margin"
                        domain="[('margin', '&lt;', 0)]"/>

                <separator/>

                <!-- Group-by -->
                <filter string="Product" name="group_product"
                        context="{'group_by': 'product_id'}"/>
                <filter string="Product Category" name="group_category"
                        context="{'group_by': 'product_category_id'}"/>
                <filter string="Order Date" name="group_date"
                        context="{'group_by': 'order_date:day'}"/>
                <filter string="Month" name="group_month"
                        context="{'group_by': 'order_date:month'}"/>
                <filter string="Session" name="group_session"
                        context="{'group_by': 'session_id'}"/>
                <filter string="Customer" name="group_customer"
                        context="{'group_by': 'customer_id'}"/>
                <filter string="Pricelist" name="group_pricelist"
                        context="{'group_by': 'pricelist_id'}"/>
                <filter string="Order State" name="group_state"
                        context="{'group_by': 'order_state'}"/>

            </search>
        </field>
    </record>


    <!-- ═══════════════════════════════════════════════════════
         PIVOT VIEW
    ═══════════════════════════════════════════════════════ -->
    <record id="view_pos_order_line_report_pivot" model="ir.ui.view">
        <field name="name">pos.order.line.report.pivot</field>
        <field name="model">pos.order.line</field>
        <field name="arch" type="xml">
            <pivot string="POS Sales &amp; Margin Analysis" disable_linking="False">

                <!-- Default row grouping: Product Category → Product -->
                <field name="product_category_id" type="row"/>
                <field name="product_id"          type="row"/>

                <!-- Default col grouping: Order Date by month -->
                <field name="order_date" interval="month" type="col"/>

                <!-- Measures -->
                <field name="qty"                string="Qty Sold"      type="measure"/>
                <field name="price_subtotal_incl" string="Revenue (incl. tax)" type="measure"/>
                <field name="cost_price_total"   string="Total Cost"    type="measure"/>
                <field name="margin"             string="Gross Margin"  type="measure"/>
                <field name="margin_percent"     string="Margin %"      type="measure"/>
                <field name="price_unit"         string="Unit Price"    type="measure"/>

            </pivot>
        </field>
    </record>


    <!-- ═══════════════════════════════════════════════════════
         GRAPH VIEW
    ═══════════════════════════════════════════════════════ -->
    <record id="view_pos_order_line_report_graph" model="ir.ui.view">
        <field name="name">pos.order.line.report.graph</field>
        <field name="model">pos.order.line</field>
        <field name="arch" type="xml">
            <graph string="POS Sales &amp; Margin" type="bar" stacked="False">
                <field name="product_id"          type="row"/>
                <field name="price_subtotal_incl" string="Revenue"      type="measure"/>
                <field name="margin"              string="Gross Margin" type="measure"/>
            </graph>
        </field>
    </record>


    <!-- ═══════════════════════════════════════════════════════
         LIST VIEW
    ═══════════════════════════════════════════════════════ -->
    <record id="view_pos_order_line_report_list" model="ir.ui.view">
        <field name="name">pos.order.line.report.list</field>
        <field name="model">pos.order.line</field>
        <field name="arch" type="xml">
            <list string="POS Sales Analysis" create="false" edit="false" delete="false"
                  default_order="order_date desc">

                <field name="order_date"          string="Date"         optional="show"/>
                <field name="order_id"            string="Order"        optional="show"/>
                <field name="session_id"          string="Session"      optional="hide"/>
                <field name="customer_id"         string="Customer"     optional="show"/>
                <field name="product_category_id" string="Category"     optional="show"/>
                <field name="product_id"          string="Product"      optional="show"/>
                <field name="qty"                 string="Qty"          optional="show"/>
                <field name="price_unit"          string="Unit Price"   optional="show"/>
                <field name="price_subtotal_incl" string="Revenue"      optional="show"/>
                <field name="cost_price_total"    string="Total Cost"   optional="show"/>
                <field name="margin"              string="Margin"       optional="show"
                       decoration-danger="margin &lt; 0"
                       decoration-warning="margin &gt;= 0 and margin_percent &lt; 10"
                       decoration-success="margin_percent &gt;= 30"/>
                <field name="margin_percent"      string="Margin %"     optional="show"
                       decoration-danger="margin_percent &lt; 0"
                       decoration-warning="margin_percent &gt;= 0 and margin_percent &lt; 10"
                       decoration-success="margin_percent &gt;= 30"/>
                <field name="order_state"         string="State"        optional="hide"/>

            </list>
        </field>
    </record>


    <!-- ═══════════════════════════════════════════════════════
         ACTION
    ═══════════════════════════════════════════════════════ -->
    <record id="action_pos_order_line_report" model="ir.actions.act_window">
        <field name="name">Sales &amp; Margin Analysis</field>
        <field name="res_model">pos.order.line</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="domain">[('order_state', 'in', ['done', 'paid', 'invoiced'])]</field>
        <field name="context">{
            'search_default_filter_done': 1,
            'search_default_group_product': 1
        }</field>
        <field name="view_ids" eval="[
            (ref('view_pos_order_line_report_pivot'), 'pivot'),
            (ref('view_pos_order_line_report_graph'), 'graph'),
            (ref('view_pos_order_line_report_list'),  'list'),
        ]"/>
        <field name="search_view_id" ref="view_pos_order_line_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No POS order lines found.
            </p>
            <p>
                Complete a POS session to see product-wise sales and margin data here.
            </p>
        </field>
    </record>

</odoo>
