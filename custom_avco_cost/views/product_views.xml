<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Product Template Form ── -->
    <record id="product_template_custom_cost_view" model="ir.ui.view">
        <field name="name">product.template.custom.cost.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Add the toggle right after the Cost field in General Info tab -->
            <xpath expr="//field[@name='standard_price']" position="after">
                <field name="use_custom_cost"
                       widget="boolean_toggle"
                       string="Custom Cost (Value ÷ Latest PO Price)"
                       invisible="type == 'service'"/>
            </xpath>

        </field>
    </record>

    <!-- ── Product Product (variant) Form ── -->
    <record id="product_product_custom_cost_view" model="ir.ui.view">
        <field name="name">product.product.custom.cost.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">

            <!--
                Add manual recompute button in the header.
                We anchor to the <div class="oe_button_box"> block which is
                stable across Odoo 16-19.  If that too is absent, fall back to
                inserting before the first field in the form (position="inside"
                on the sheet).  The xpath below targets the button box div.
            -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_recompute_custom_cost"
                        type="object"
                        string="Recompute Custom Cost"
                        icon="fa-calculator"
                        invisible="not use_custom_cost"
                        class="oe_stat_button"/>
            </xpath>

        </field>
    </record>

</odoo>