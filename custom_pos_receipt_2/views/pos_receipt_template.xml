<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Inherit pos.config form to add QR size field -->
        <record id="pos_config_form_view_inherit" model="ir.ui.view">
            <field name="name">pos.config.form.inherit.qr.size</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='iface_print_auto']" position="after">
                    <field name="qr_code_size" string="QR Code Size (px)"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>