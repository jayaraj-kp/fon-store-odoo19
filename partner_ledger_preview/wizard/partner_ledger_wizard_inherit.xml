<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherits the Partner Ledger wizard view from accounting_pdf_reports.
        Adds:
          1. A "Partners" Many2many field so the user can scope the report
             to one or more specific partners.
          2. The existing "Preview" button in the footer.
    -->
    <record id="view_partner_ledger_wizard_inherit" model="ir.ui.view">
        <field name="name">account.report.partner.ledger.wizard.inherit</field>
        <field name="model">account.report.partner.ledger</field>
        <field name="inherit_id" ref="accounting_pdf_reports.account_report_partner_ledger_view"/>
        <field name="arch" type="xml">

            <!-- Inject the Partners filter field just before the footer -->
            <xpath expr="//footer" position="before">
                <group string="Partner Filter" col="2">
                    <field name="partner_ids"
                           widget="many2many_tags"
                           string="Filter by Partners"
                           placeholder="Leave empty for all partners…"
                           options="{'no_create': True}"
                           colspan="2"/>
                </group>
            </xpath>

            <!-- Inject the Preview button into the footer -->
            <xpath expr="//footer" position="inside">
                <button name="action_preview_report"
                        string="Preview"
                        type="object"
                        class="btn-secondary"
                        data-hotkey="v"
                        icon="fa-eye"/>
            </xpath>

        </field>
    </record>

</odoo>

