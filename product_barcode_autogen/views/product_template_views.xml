<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         STRATEGY: Add a brand-new "Barcode" tab into the notebook.

         WHY: In Odoo 19 CE, barcode/default_code are NOT in the BASE
         arch of product_template_form_view. They're added by inherited
         views. Targeting them via xpath fails "cannot be located".

         <notebook position="inside"> is guaranteed to work because
         <notebook> IS always in the base product form view arch.
    ================================================================ -->

    <record id="product_template_form_barcode_autogen" model="ir.ui.view">
        <field name="name">product.template.form.barcode.autogen</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Barcode" name="barcode_autogen_page">
                    <group string="Auto-Generated Barcode">
                        <field name="barcode" string="Barcode"/>
                    </group>
                    <div class="o_row mt-2">
                        <button
                            name="action_regenerate_barcode"
                            string="↻ Regenerate Barcode"
                            type="object"
                            class="btn btn-secondary"
                            invisible="not id"
                        />
                    </div>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Settings: configure prefix and length -->
    <record id="res_config_settings_view_barcode_autogen" model="ir.ui.view">
        <field name="name">res.config.settings.view.barcode.autogen</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('app_settings_block')]" position="before">
                <app string="Barcode Auto-Gen" name="product_barcode_autogen">
                    <block title="Auto-Generated Barcode Settings">
                        <setting string="Barcode Prefix"
                                 help="Prefix for auto-generated barcodes (e.g. BC → BC-A3F7K2M9X1Q5).">
                            <field name="barcode_prefix" placeholder="BC"/>
                        </setting>
                        <setting string="Random Part Length"
                                 help="Number of random alphanumeric characters after the prefix (4-20).">
                            <field name="barcode_length"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
