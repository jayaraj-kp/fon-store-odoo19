<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Product Template Form — Adds a "Barcode" tab with:
           - barcode field (auto-filled on product creation)
           - Regenerate button to get a new barcode anytime

         Uses <notebook position="inside"> which is guaranteed to exist
         in Odoo 19 CE base product form view.
    ================================================================ -->

    <record id="product_template_form_barcode_autogen" model="ir.ui.view">
        <field name="name">product.template.form.barcode.autogen</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Barcode" name="barcode_autogen_page">
                    <group string="Auto-Generated Barcode">
                        <field name="barcode" string="Barcode"/>
                    </group>
                    <div class="o_row mt-2">
                        <button
                            name="action_regenerate_barcode"
                            string="↻ Regenerate Barcode"
                            type="object"
                            class="btn btn-secondary"
                            invisible="not id"
                        />
                    </div>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
