<odoo>
    <record id="product_template_form_barcode_autogen" model="ir.ui.view">
        <field name="name">product.template.form.barcode.autogen</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- PASTE HERE -->
            <xpath expr="//sheet" position="inside">

                <separator string="Package Barcodes, Quantities &amp; Combo Limits"/>

<!--                <group string="Package 1 (e.g. 1 Dozen = 12 units)" col="2">-->
<!--                    <field name="barcode2"/>-->
<!--                    <field name="custom_qty1"/>-->
<!--                    <field name="custom_price1" widget="monetary"-->
<!--                           options="{'currency_field': 'currency_id'}"/>-->
<!--                    <field name="max_combo_qty1"/>-->
<!--                </group>-->

                <group string="Package 2 (e.g. 10 Dozen = 120 units)" col="2">
                    <field name="barcode3"/>
                    <field name="custom_qty2"/>
                    <field name="custom_price2" widget="monetary"
                           options="{'currency_field': 'currency_id'}"/>
                    <field name="max_combo_qty2"/>
                </group>

                <button
                        name="action_regenerate_barcode"
                        string="Regenerate Barcode"
                        type="object"
                        class="btn btn-secondary"
                        invisible="id == False"
                />

            </xpath>

        </field>
    </record>
</odoo>


