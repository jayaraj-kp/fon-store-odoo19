<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Default system parameters for barcode generation -->
    <record id="param_barcode_prefix" model="ir.config_parameter">
        <field name="key">product_barcode_autogen.barcode_prefix</field>
        <field name="value"></field>
    </record>

    <record id="param_barcode_length" model="ir.config_parameter">
        <field name="key">product_barcode_autogen.barcode_length</field>
        <field name="value">13</field>
    </record>
</odoo>


