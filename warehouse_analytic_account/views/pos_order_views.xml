<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!--
            POS Order Lines - Show Analytic Distribution
            This is optional but recommended for visibility
        -->
        <record id="pos_order_line_view_tree_inherit_analytic" model="ir.ui.view">
            <field name="name">pos.order.line.tree.inherit.analytic</field>
            <field name="model">pos.order.line</field>
            <field name="inherit_id" ref="point_of_sale.pos_order_line_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="attributes">
                    <attribute name="decoration-muted">state == 'refunded'</attribute>
                </xpath>
                <xpath expr="//field[@name='qty']" position="after">
                    <field name="analytic_distribution" optional="hide" widget="analytic_distribution"/>
                </xpath>
            </field>
        </record>

        <!--
            POS Order Form - Show Analytics Tab
            Helps users verify analytic accounts on POS orders
        -->
        <record id="pos_order_view_form_inherit_analytic" model="ir.ui.view">
            <field name="name">pos.order.form.inherit.analytic</field>
            <field name="model">pos.order</field>
            <field name="inherit_id" ref="point_of_sale.pos_order_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[@name='extra']" position="after">
                    <page name="analytics" string="Analytics">
                        <group>
                            <field name="lines" nolabel="1" mode="tree">
                                <tree create="false" edit="false" delete="false">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal_incl"/>
                                    <field name="analytic_distribution" widget="analytic_distribution"/>
                                </tree>
                            </field>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>