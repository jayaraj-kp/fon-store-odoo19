<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!--
            MINIMAL SAFE VERSION
            This approach avoids referencing potentially non-existent views
            and simply ensures the analytic_distribution field is available
        -->

        <!-- Inherit pos.order form to ensure analytic_distribution is editable -->
        <record id="pos_order_form_analytic_inherit" model="ir.ui.view">
            <field name="name">pos.order.form.analytic.inherit</field>
            <field name="model">pos.order</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_order_form"/>
            <field name="arch" type="xml">
                <!-- Ensure order lines show analytic distribution -->
                <xpath expr="//field[@name='lines']" position="before">
                    <!-- Info message about analytics -->
                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle"/> Analytic Account: This order's analytic account is set based on your default warehouse.
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>