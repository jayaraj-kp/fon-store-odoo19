<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Sale Settings to add Auto-Manufacture toggle -->
    <!-- Odoo 19 CE uses <app><block><setting> structure inside //form -->
    <record id="res_config_settings_view_form_auto_manufacture" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.auto.manufacture</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='sale_management']//block[@name='quotation_order_setting_container']" position="after">
                <block title="Auto Manufacturing" name="auto_manufacture_setting_container">
                    <setting string="Auto-Manufacture on Sale Confirm"
                             help="Automatically create, confirm and produce a Manufacturing Order when a Sale Order is confirmed. Components are consumed and finished product stock is updated immediately.">
                        <field name="auto_manufacture_on_confirm"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

    <!-- Add smart button on Sale Order to view auto-created MOs -->
    <record id="view_order_form_auto_manufacture_button" model="ir.ui.view">
        <field name="name">sale.order.form.auto.manufacture.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    type="object"
                    name="action_view_auto_manufacture_orders"
                    class="oe_stat_button"
                    icon="fa-industry"
                    invisible="auto_manufacture_count == 0"
                >
                    <field name="auto_manufacture_count" widget="statinfo" string="MOs"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Add indicator column in sale order lines -->
    <record id="view_order_form_auto_manufacture_lines" model="ir.ui.view">
        <field name="name">sale.order.form.auto.manufacture.lines</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list//field[@name='product_uom_qty']" position="after">
                <field
                    name="has_bom"
                    string="Auto MFG"
                    optional="show"
                    readonly="1"
                    help="This product has a Bill of Materials and will be auto-manufactured on confirm"
                />
            </xpath>
        </field>
    </record>

</odoo>
