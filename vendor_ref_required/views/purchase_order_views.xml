<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_date_only" model="ir.ui.view">
        <field name="name">purchase.order.form.date.only</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Replace Confirmation Date datetime with computed Date field -->
            <xpath expr="//field[@name='date_approve']" position="replace">
                <field name="date_approve_date" string="Confirmation Date"/>
            </xpath>

            <!-- Replace Expected Arrival datetime with computed Date field -->
            <xpath expr="//field[@name='date_planned']" position="replace">
                <field name="date_planned_date" string="Expected Arrival"/>
            </xpath>

        </field>
    </record>
</odoo>
