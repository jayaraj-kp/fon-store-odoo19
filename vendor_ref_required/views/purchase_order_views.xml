<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_date_only" model="ir.ui.view">
        <field name="name">purchase.order.form.date.only</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Make Vendor Reference required in the view -->
            <xpath expr="//field[@name='partner_ref']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>

            <!-- Replace label for Confirmation Date -->
            <xpath expr="//label[@for='date_approve']" position="replace">
                <label for="date_approve_date" string="Confirmation Date"/>
            </xpath>
            <!-- Replace Confirmation Date datetime with Date field -->
            <xpath expr="//field[@name='date_approve']" position="replace">
                <field name="date_approve_date" string="Confirmation Date"/>
            </xpath>

            <!-- Replace label for Expected Arrival -->
            <xpath expr="//label[@for='date_planned']" position="replace">
                <label for="date_planned_date" string="Expected Arrival"/>
            </xpath>
            <!-- Replace Expected Arrival datetime with Date field -->
            <xpath expr="//field[@name='date_planned']" position="replace">
                <field name="date_planned_date" string="Expected Arrival"/>
            </xpath>

        </field>
    </record>
</odoo>
