<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend POS Config form to add Charity settings tab -->
    <record id="view_pos_config_form_charity" model="ir.ui.view">
        <field name="name">pos.config.form.charity</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='connected_devices']" position="after">
                <page string="Charity" name="charity_settings">
                    <group>
                        <group string="Charity Donation Settings">
                            <field name="charity_enabled"/>
                            <field name="charity_account_id"
                                   attrs="{'required': [('charity_enabled', '=', True)],
                                           'invisible': [('charity_enabled', '=', False)]}"/>
                            <field name="charity_button_label"
                                   attrs="{'invisible': [('charity_enabled', '=', False)]}"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- POS Session form: show charity totals -->
    <record id="view_pos_session_form_charity" model="ir.ui.view">
        <field name="name">pos.session.form.charity</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Charity Donations" attrs="{'invisible': [('charity_donation_count', '=', 0)]}">
                    <field name="charity_donation_total" widget="monetary"/>
                    <field name="charity_donation_count"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
