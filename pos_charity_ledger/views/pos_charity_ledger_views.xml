<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== pos.charity.account views ==================== -->
    <record id="view_pos_charity_account_tree" model="ir.ui.view">
        <field name="name">pos.charity.account.tree</field>
        <field name="model">pos.charity.account</field>
        <field name="arch" type="xml">
            <tree string="Charity Accounts">
                <field name="name"/>
                <field name="description"/>
                <field name="total_donated" widget="monetary"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_pos_charity_account_form" model="ir.ui.view">
        <field name="name">pos.charity.account.form</field>
        <field name="model">pos.charity.account</field>
        <field name="arch" type="xml">
            <form string="Charity Account">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Charity Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="description"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="total_donated" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Donations">
                            <field name="donation_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="pos_config_id"/>
                                    <field name="pos_order_id"/>
                                    <field name="cashier_id"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'confirmed'"
                                           decoration-warning="state == 'draft'"
                                           decoration-danger="state == 'cancelled'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pos_charity_account" model="ir.actions.act_window">
        <field name="name">Charity Accounts</field>
        <field name="res_model">pos.charity.account</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first charity account
            </p>
        </field>
    </record>

    <!-- ==================== pos.charity.donation views ==================== -->
    <record id="view_pos_charity_donation_tree" model="ir.ui.view">
        <field name="name">pos.charity.donation.tree</field>
        <field name="model">pos.charity.donation</field>
        <field name="arch" type="xml">
            <tree string="Charity Donations"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="date"/>
                <field name="charity_account_id"/>
                <field name="pos_config_id"/>
                <field name="pos_order_id"/>
                <field name="cashier_id"/>
                <field name="amount" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record id="view_pos_charity_donation_form" model="ir.ui.view">
        <field name="name">pos.charity.donation.form</field>
        <field name="model">pos.charity.donation</field>
        <field name="arch" type="xml">
            <form string="Charity Donation">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            attrs="{'invisible': [('state', 'in', ['cancelled'])]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="charity_account_id"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="pos_session_id"/>
                            <field name="pos_order_id"/>
                            <field name="cashier_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_charity_donation_search" model="ir.ui.view">
        <field name="name">pos.charity.donation.search</field>
        <field name="model">pos.charity.donation</field>
        <field name="arch" type="xml">
            <search string="Search Donations">
                <field name="name"/>
                <field name="charity_account_id"/>
                <field name="pos_config_id"/>
                <filter name="confirmed" string="Confirmed" domain="[('state','=','confirmed')]"/>
                <filter name="today" string="Today"
                        domain="[('date','&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_charity" string="Charity Account"
                            context="{'group_by': 'charity_account_id'}"/>
                    <filter name="group_session" string="POS Session"
                            context="{'group_by': 'pos_session_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pos_charity_donation" model="ir.actions.act_window">
        <field name="name">Charity Donations</field>
        <field name="res_model">pos.charity.donation</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No charity donations yet
            </p>
            <p>Donations will appear here once customers donate from POS.</p>
        </field>
    </record>

    <!-- ==================== Menu Items ==================== -->
    <menuitem id="menu_pos_charity_root"
              name="Charity"
              parent="point_of_sale.menu_point_of_sale"
              sequence="50"/>

    <menuitem id="menu_pos_charity_accounts"
              name="Charity Accounts"
              parent="menu_pos_charity_root"
              action="action_pos_charity_account"
              sequence="10"/>

    <menuitem id="menu_pos_charity_donations"
              name="Donations Ledger"
              parent="menu_pos_charity_root"
              action="action_pos_charity_donation"
              sequence="20"/>
</odoo>
