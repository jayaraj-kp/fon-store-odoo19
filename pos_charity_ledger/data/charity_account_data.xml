<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for donation reference numbers -->
    <record id="seq_pos_charity_donation" model="ir.sequence">
        <field name="name">POS Charity Donation</field>
        <field name="code">pos.charity.donation</field>
        <field name="prefix">CHR/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Default Charity Account -->
    <record id="pos_charity_account_default" model="pos.charity.account">
        <field name="name">General Charity Fund</field>
        <field name="description">Default charity fund for POS customer donations</field>
        <field name="active">True</field>
    </record>
</odoo>
