<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- ═══════════════════════════════════════════════════════════════
         Order / Product Screen – Charity button
         Inserted into ControlButtons (the row above Payment/Cash/Card)
    ════════════════════════════════════════════════════════════════ -->
    <t t-name="pos_charity_ledger.CharityOrderButton">
        <div t-if="charityEnabled" class="charity-order-section w-100">
            <t t-if="!charityState.isDonating">
                <button class="btn btn-charity btn-charity-order w-100"
                    t-on-click="openOrderCharityPopup">
                    <span>❤ <t t-esc="charityButtonLabel"/></span>
                    <t t-if="orderRoundOffAmount > 0">
                        <span class="charity-roundoff-hint ms-1">
                            (Round off <t t-esc="currencySymbol"/><t t-esc="orderRoundOffAmount.toFixed(2)"/>)
                        </span>
                    </t>
                </button>
            </t>
            <t t-else="">
                <div class="charity-active-donation d-flex align-items-center justify-content-between w-100 px-3 py-2">
                    <span>
                        ❤ Donating
                        <strong>
                            <t t-esc="currencySymbol"/>
                            <t t-esc="charityState.donationAmount.toFixed(2)"/>
                        </strong>
                        to Charity
                    </span>
                    <button class="btn btn-sm btn-charity-remove" t-on-click="removeOrderCharityDonation">
                        ✕ Remove
                    </button>
                </div>
            </t>
        </div>
    </t>

    <!-- Inject CharityOrderButton into the ControlButtons area -->
    <t t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="." position="inside">
            <CharityOrderButton/>
        </xpath>
    </t>

    <!-- ═══════════════════════════════════════════════════════════════
         Payment Screen – Charity button (below payment method buttons)
    ════════════════════════════════════════════════════════════════ -->
    <t t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-buttons')]" position="inside">
            <div t-if="charityEnabled" class="charity-donation-section d-flex flex-column gap-1 w-100 mt-1">
                <t t-if="!charityState.isDonating">
                    <button class="btn btn-charity btn-lg w-100 lh-lg"
                        t-on-click="openCharityPopup">
                        <span>❤ <t t-esc="charityButtonLabel"/></span>
                    </button>
                </t>
                <t t-else="">
                    <div class="charity-active-donation d-flex align-items-center justify-content-between w-100 px-3 py-2">
                        <span>
                            ❤ Donating
                            <strong>
                                <t t-esc="currencySymbol"/>
                                <t t-esc="charityState.donationAmount.toFixed(2)"/>
                            </strong>
                            to Charity
                        </span>
                        <button class="btn btn-sm btn-charity-remove" t-on-click="removeCharityDonation">
                            ✕ Remove
                        </button>
                    </div>
                </t>
            </div>
        </xpath>
    </t>

</templates>
