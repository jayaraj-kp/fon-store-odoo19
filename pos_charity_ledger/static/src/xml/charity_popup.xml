<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="pos_charity_ledger.CharityDonationPopup">
        <Dialog title="props.title" size="'md'">
            <div class="charity-popup-body">
                <p class="text-center mb-3" style="font-size:15px;">
                    Available Change: <strong style="color:#2ecc71;font-size:18px;">
                        <t t-esc="symbol"/><t t-esc="maxAmount.toFixed(2)"/>
                    </strong>
                </p>
                <div class="d-flex gap-2 mb-3">
                    <button class="btn btn-outline-danger flex-fill" t-on-click="() => this.setAmount(1)"><t t-esc="symbol"/>1</button>
                    <button class="btn btn-outline-danger flex-fill" t-on-click="() => this.setAmount(2)"><t t-esc="symbol"/>2</button>
                    <button class="btn btn-outline-danger flex-fill" t-on-click="() => this.setAmount(5)"><t t-esc="symbol"/>5</button>
                    <button class="btn btn-danger flex-fill" t-on-click="setFullChange">Full Change</button>
                </div>
                <div class="input-group mb-2">
                    <span class="input-group-text" style="font-size:20px;"><t t-esc="symbol"/></span>
                    <input type="number" class="form-control form-control-lg text-end"
                        t-att-value="state.inputAmount" t-on-input="onInputChange"
                        placeholder="0.00" min="0" t-att-max="maxAmount" step="0.01"/>
                </div>
                <div t-if="state.error" class="text-danger text-center mb-2" t-esc="state.error"/>
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:8px;">
                    <t t-foreach="['1','2','3','4','5','6','7','8','9','.','0','⌫']" t-as="key" t-key="key">
                        <button class="btn btn-light btn-lg" style="font-size:20px;font-weight:600;" t-on-click="() => this.pressKey(key)">
                            <t t-esc="key"/>
                        </button>
                    </t>
                </div>
            </div>
            <t t-set-slot="footer">
                <div class="d-flex gap-2 w-100">
                    <button class="btn btn-secondary btn-lg flex-fill" t-on-click="cancel">Cancel</button>
                    <button class="btn btn-danger btn-lg flex-fill" t-on-click="confirm">
                        ❤ Donate <t t-if="displayAmount"><t t-esc="symbol"/><t t-esc="displayAmount"/></t>
                    </button>
                </div>
            </t>
        </Dialog>
    </t>
</templates>
