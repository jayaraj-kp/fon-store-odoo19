<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="pos_charity_ledger.CharityDonationPopup">
        <Dialog title="props.title" size="'md'">
            <div class="charity-popup-body">

                <!-- ── ONE-TAP GREEN ROUND-UP BUTTON ──────────────────────────
                     Always shown at the top.
                     Shows the exact round-up amount (e.g. ₹3 for total ₹997).
                     Clicking it confirms IMMEDIATELY — no need to press Donate.
                ──────────────────────────────────────────────────────────── -->
                <div class="mb-3">
                    <button class="btn btn-charity-roundoff w-100"
                        t-on-click="confirmRoundOff"
                        style="font-size:16px; padding:14px;">
                        ❤ Donate <t t-esc="symbol"/><t t-esc="roundOff"/> to Round Up
                        <span class="ms-2" style="font-size:12px;opacity:0.85;">
                            (one tap — no confirmation needed)
                        </span>
                    </button>
                </div>

                <!-- ── QUICK FIXED AMOUNT BUTTONS ─────────────────────────────
                     Show ₹1 / ₹2 / ₹5 only when they are LESS THAN the cap.
                     Cap = roundOff (next multiple of 5).
                     e.g. roundOff=3 → show ₹1, ₹2 (not ₹5 since 5 > 3)
                          roundOff=5 → show ₹1, ₹2, ₹5
                          roundOff=1 → show nothing (all > 1)
                ──────────────────────────────────────────────────────────── -->
                <t t-if="maxAmount > 1">
                    <div class="d-flex gap-2 mb-3 flex-wrap">
                        <button class="btn btn-outline-danger flex-fill"
                            t-on-click="() => this.setAmount(1)">
                            <t t-esc="symbol"/>1
                        </button>
                        <t t-if="maxAmount > 2">
                            <button class="btn btn-outline-danger flex-fill"
                                t-on-click="() => this.setAmount(2)">
                                <t t-esc="symbol"/>2
                            </button>
                        </t>
                        <t t-if="maxAmount > 3">
                            <button class="btn btn-outline-danger flex-fill"
                                t-on-click="() => this.setAmount(3)">
                                <t t-esc="symbol"/>3
                            </button>
                        </t>
                        <t t-if="maxAmount > 4">
                            <button class="btn btn-outline-danger flex-fill"
                                t-on-click="() => this.setAmount(4)">
                                <t t-esc="symbol"/>4
                            </button>
                        </t>
                        <t t-if="maxAmount >= 5">
                            <button class="btn btn-outline-danger flex-fill"
                                t-on-click="() => this.setAmount(5)">
                                <t t-esc="symbol"/>5
                            </button>
                        </t>
                    </div>
                </t>

                <!-- ── MANUAL AMOUNT INPUT ────────────────────────────────── -->
                <div class="input-group mb-2">
                    <span class="input-group-text" style="font-size:20px;">
                        <t t-esc="symbol"/>
                    </span>
                    <input type="number" class="form-control form-control-lg text-end"
                        t-att-value="state.inputAmount"
                        t-on-input="onInputChange"
                        placeholder="0.00" min="0" step="0.01"/>
                </div>

                <div t-if="state.error" class="text-danger text-center mb-2"
                    t-esc="state.error"/>

                <!-- ── NUMPAD ─────────────────────────────────────────────── -->
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:8px;">
                    <t t-foreach="['1','2','3','4','5','6','7','8','9','.','0','⌫']"
                        t-as="key" t-key="key">
                        <button class="btn btn-light btn-lg"
                            style="font-size:20px;font-weight:600;"
                            t-on-click="() => this.pressKey(key)">
                            <t t-esc="key"/>
                        </button>
                    </t>
                </div>

            </div>

            <!-- Footer: Cancel + Donate -->
            <t t-set-slot="footer">
                <div class="d-flex gap-2 w-100">
                    <button class="btn btn-secondary btn-lg flex-fill"
                        t-on-click="cancel">Cancel</button>
                    <button class="btn btn-danger btn-lg flex-fill"
                        t-on-click="confirm">
                        ❤ Donate
                        <t t-if="displayAmount">
                            <t t-esc="symbol"/><t t-esc="displayAmount"/>
                        </t>
                    </button>
                </div>
            </t>
        </Dialog>
    </t>
</templates>



