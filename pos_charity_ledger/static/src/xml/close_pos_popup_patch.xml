<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!--
        Inject the session charity total into the Close Register (ClosePosPopup) screen.
        xpath targets the footer button row, inserting our banner just before it.
        The banner is only visible when charity is enabled AND a donation was collected.
    -->
    <t t-name="pos_charity_ledger.ClosePosPopup"
       t-inherit="point_of_sale.ClosePosPopup"
       t-inherit-mode="extension">

        <!-- Insert charity summary just before the close/discard footer buttons -->
        <xpath expr="//div[hasclass('modal-footer-right')]" position="before">
            <t t-if="charityEnabled and sessionCharityTotal > 0">
                <div style="
                    margin: 0 0 12px 0;
                    padding: 14px 18px;
                    background: linear-gradient(135deg, #fdf2f2, #fce4e4);
                    border: 2px solid #e74c3c;
                    border-radius: 10px;
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    font-size: 15px;
                    font-weight: 600;
                    color: #c0392b;
                ">
                    <span>❤ Total Charity Donations (this session)</span>
                    <span style="font-size: 18px;">
                        <t t-esc="currencySymbol"/>
                        <t t-esc="sessionCharityTotal.toFixed(2)"/>
                    </span>
                </div>
                <p style="margin: -8px 0 12px 0; font-size: 12px; color: #888; text-align: right;">
                    This amount will be posted to the Charity Account when the register closes.
                </p>
            </t>
        </xpath>

    </t>

</templates>
