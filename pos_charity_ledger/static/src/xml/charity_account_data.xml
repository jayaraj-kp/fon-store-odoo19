<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for donation reference numbers -->
    <record id="seq_pos_charity_donation" model="ir.sequence">
        <field name="name">POS Charity Donation</field>
        <field name="code">pos.charity.donation</field>
        <field name="prefix">CHR/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Default Charity Account -->
    <record id="pos_charity_account_default" model="pos.charity.account">
        <field name="name">General Charity Fund</field>
        <field name="description">Default charity fund for POS customer donations</field>
        <field name="active">True</field>
    </record>

    <!--
        Charity Round-Off Product
        ─────────────────────────
        A service product used ONLY by the charity module to add the donation
        amount as a separate order line. This ensures:

          INV/2026/00001
          ──────────────────────────────────────────
          400000 Product Sales   CREDIT  ₹997   (actual product revenue)
          201002 Charity GL      CREDIT  ₹3     (charity — via this product)
          121000 Receivable      DEBIT   ₹1,000 (total collected)

        Key settings:
          • type = service          → no stock movement, no inventory impact
          • taxes_id = False        → no tax on charity donation
          • available_in_pos = True → loads into POS so JS can find it
          • sale_ok = True          → can appear on invoices
          • The income account (201002 Charity) is set AFTER install via
            the pos.config charity_gl_account_id — see pos_order.py which
            writes the account onto the product's categ/account at first use.

        The cashier NEVER sees or selects this product manually.
        It is added programmatically by charity_button.js when the
        cashier clicks the round-off button.

        NOTE: After installing/upgrading the module, go to:
          Accounting → Configuration → Products → "Charity Round-Off"
          → Sales tab → Income Account → set to "201002 Charity"
        This maps the ₹3 line directly to the charity GL in the invoice.
    -->
    <record id="product_tmpl_charity_roundoff" model="product.template">
        <field name="name">Charity Round-Off</field>
        <field name="default_code">CHARITY_ROUNDOFF</field>
        <field name="type">service</field>
        <field name="list_price">0.00</field>
        <field name="taxes_id" eval="False"/>
        <field name="available_in_pos">True</field>
        <field name="sale_ok">True</field>
        <field name="purchase_ok">False</field>
        <field name="description_sale">Charity donation collected at Point of Sale</field>
        <field name="active">True</field>
    </record>

</odoo>