<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- Standalone CharityClosingSummary component template -->
    <t t-name="pos_charity_ledger.CharityClosingSummary">
        <t t-if="show">
            <div class="d-flex justify-content-between align-items-center py-1 px-2 mb-3"
                 style="background:#fdf2f2; border:1.5px solid #e74c3c; border-radius:8px;
                        color:#c0392b; font-weight:700; font-size:14px;">
                <span>
                    ❤ Charity Donations
                    <span t-if="count > 1"
                          style="font-weight:400; font-size:12px; margin-left:4px;">
                        (<t t-esc="count"/> orders)
                    </span>
                </span>
                <span>- <t t-esc="symbol"/><t t-esc="total.toFixed(2)"/></span>
            </div>
        </t>
    </t>

    <!--
        Inherit ClosePosPopup and inject CharityClosingSummary at the TOP
        of the payment-methods-overview div — which we confirmed exists in the DOM.
    -->
    <t t-inherit="point_of_sale.ClosePosPopup" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-methods-overview')]" position="inside">
            <CharityClosingSummary/>
        </xpath>
    </t>

</templates>