<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!--
        CharityClosingSummary — standalone template only.
        NO t-inherit, NO xpath.

        The JS file (charity_closing_patch.js) injects <CharityClosingSummary/>
        into ClosePosPopup's raw template string at runtime and adds this class
        to ClosePosPopup.components — so no XML inheritance is needed here.
    -->
    <t t-name="pos_charity_ledger.CharityClosingSummary">
        <t t-if="show">
            <div class="d-flex justify-content-between align-items-center py-1 px-2 mt-2 mb-1"
                 style="background:#fdf2f2; border:1.5px solid #e74c3c; border-radius:8px;
                        color:#c0392b; font-weight:700; font-size:14px;">
                <span>
                    ❤ Charity Donations
                    <span t-if="count > 1"
                          style="font-weight:400; font-size:12px; margin-left:4px;">
                        (<t t-esc="count"/> orders)
                    </span>
                </span>
                <span>- <t t-esc="symbol"/><t t-esc="total.toFixed(2)"/></span>
            </div>
        </t>
    </t>

</templates>