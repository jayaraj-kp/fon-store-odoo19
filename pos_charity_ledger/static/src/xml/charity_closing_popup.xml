<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!--
        Extend the standard POS Closing Register popup to show a charity
        donations summary above the "Closing note" textarea.

        What the cashier sees when charity > 0:
        ┌─────────────────────────────────────────────┐
        │ ❤  Charity Donations              ₹4.00 (1) │
        │ Physical cash in drawer is ₹4.00 higher.    │
        │ Remove ₹4.00 before counting cash.           │
        └─────────────────────────────────────────────┘

        The xpath targets the closing-note <textarea> which is always
        present in the ClosePosPopup in Odoo 17-19.
    -->
    <t t-inherit="point_of_sale.ClosePosPopup" t-inherit-mode="extension">
        <xpath expr="//textarea" position="before">
            <t t-if="charityData and charityData.total > 0">
                <div class="charity-closing-section">
                    <!-- Header row: title + badge -->
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="charity-closing-title">
                            <i class="fa fa-heart me-2"/>
                            Charity Donations
                        </span>
                        <span class="charity-closing-badge">
                            <t t-esc="charityAmountFormatted"/>
                            &amp;nbsp;
                            (<t t-esc="charityData.count"/>
                            <t t-if="charityData.count === 1"> donation</t>
                            <t t-else=""> donations</t>)
                        </span>
                    </div>

                    <!-- Hint row -->
                    <div class="charity-closing-hint">
                        <i class="fa fa-info-circle me-1"/>
                        Physical cash in drawer is
                        <strong><t t-esc="charityAmountFormatted"/></strong>
                        higher than expected.
                        Please remove <strong><t t-esc="charityAmountFormatted"/></strong>
                        from the drawer for charity <strong>before counting</strong>.
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>