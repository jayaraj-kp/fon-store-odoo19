<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- ── 1. The CharityClosingSummary sub-component template ── -->
    <t t-name="pos_charity_ledger.CharityClosingSummary">
        <t t-if="show">
            <div class="payment-method-detail d-flex justify-content-between align-items-center"
                 style="color:#c0392b; font-weight:700; padding: 2px 0;">
                <span>
                    ❤ Charity Donation
                    <t t-if="count > 1">
                        (<t t-esc="count"/> orders)
                    </t>
                </span>
                <span>- <t t-esc="symbol"/><t t-esc="total.toFixed(2)"/></span>
            </div>
        </t>
    </t>

    <!--
        ── 2. Inherit ClosePosPopup to inject <CharityClosingSummary/> ──

        We target the outermost <div> wrapper of the popup (class="close-pos-popup"
        or whatever the root is) and append our component at the TOP (before the
        payment details) using "inside" on a high-level stable element.

        IMPORTANT: We use the template NAME "point_of_sale.ClosePosPopup" which
        is always stable regardless of the JS module path.

        The xpath targets the first <section> or <div> that contains the payment
        method rows. We use a very broad "//table" or the known outer wrapper.

        Since we cannot be sure of the exact DOM structure without source access,
        we inject into the Dialog root content area which always exists.
    -->
    <t t-inherit="point_of_sale.ClosePosPopup" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('close-pos-popup')]" position="inside">
            <CharityClosingSummary/>
        </xpath>
    </t>

</templates>