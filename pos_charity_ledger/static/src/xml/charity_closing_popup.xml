<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!--
        Extend point_of_sale.ClosePosPopup (confirmed template name).
        Target: textarea.closing-notes (confirmed from DOM inspection).
        We insert the charity section before the closing notes label+textarea
        container div.
    -->
    <t t-inherit="point_of_sale.ClosePosPopup" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('notes-container')]" position="before">
            <t t-if="charityData and charityData.total > 0">
                <div class="charity-closing-section mb-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="charity-closing-title">
                            <i class="fa fa-heart me-2" style="color:#e74c3c;"/>
                            Charity Donations
                        </span>
                        <span class="charity-closing-badge">
                            <t t-esc="charityAmountFormatted"/>
                            &#160;(<t t-esc="charityData.count"/>
                            <t t-if="charityData.count === 1"> donation</t>
                            <t t-else=""> donations</t>)
                        </span>
                    </div>
                    <div class="charity-closing-hint">
                        <i class="fa fa-info-circle me-1"/>
                        Cash drawer contains
                        <strong><t t-esc="charityAmountFormatted"/></strong>
                        in charity donations.
                        Please remove <strong><t t-esc="charityAmountFormatted"/></strong>
                        from the drawer for charity <strong>before counting</strong>.
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>