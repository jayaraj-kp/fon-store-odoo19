<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_custom_label" model="report.paperformat">
        <field name="name">Custom Label 90x30mm</field>
        <field name="default">False</field>
        <field name="format">custom</field>
        <field name="page_height">30</field>
        <field name="page_width">90</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">2</field>
        <field name="margin_right">2</field>
        <field name="header_line">False</field>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_custom_label" model="ir.actions.report">
        <field name="name">Custom Product Label</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label.report_custom_label_document</field>
        <field name="report_file">custom_barcode_label.report_custom_label_document</field>
        <field name="binding_model_id" search="[('model','=','product.product')]" model="ir.model"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_barcode_label.paperformat_custom_label"/>
    </record>

    <record id="action_report_custom_label_tmpl" model="ir.actions.report">
        <field name="name">Custom Product Label</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label.report_custom_label_tmpl_document</field>
        <field name="report_file">custom_barcode_label.report_custom_label_tmpl_document</field>
        <field name="binding_model_id" search="[('model','=','product.template')]" model="ir.model"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_barcode_label.paperformat_custom_label"/>
    </record>

    <template id="report_custom_label_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <t t-call="custom_barcode_label.report_custom_label_content"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_custom_label_tmpl_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="tmpl">
                <t t-foreach="tmpl.product_variant_ids" t-as="product">
                    <t t-call="web.basic_layout">
                        <div class="page">
                            <t t-call="custom_barcode_label.report_custom_label_content"/>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <template id="report_custom_label_content">
        <style type="text/css">
            html, body {{ margin: 0 !important; padding: 0 !important; background: #fff; }}
            .page {{ margin: 0 !important; padding: 0 !important; }}
            * {{ box-sizing: border-box; }}

            .cl-label {{
                width: 86mm;
                height: 26mm;
                display: table;
                font-family: Arial, Helvetica, sans-serif;
                color: #000;
                background: #fff;
                border: 0.3mm solid #ccc;
                padding: 0;
                overflow: hidden;
            }}

            /* Use table layout — most reliable in wkhtmltopdf */
            .cl-top {{
                display: table-row;
                height: 10mm;
                background: #fff;
            }}
            .cl-mid {{
                display: table-row;
                height: 10mm;
                background: #fff;
            }}
            .cl-bottom {{
                display: table-row;
                height: 6mm;
                background: #fff;
            }}

            .cl-logo-cell {{
                display: table-cell;
                width: 24mm;
                padding: 1mm;
                vertical-align: middle;
                background: #fff;
            }}
            .cl-logo-cell img {{
                width: 22mm;
                height: auto;
                max-height: 8mm;
                display: block;
            }}

            .cl-name-cell {{
                display: table-cell;
                vertical-align: middle;
                text-align: center;
                font-size: 9pt;
                font-weight: bold;
                padding: 1mm 1mm 1mm 0;
                background: #fff;
                color: #000;
            }}

            .cl-barcode-cell {{
                display: table-cell;
                text-align: center;
                vertical-align: middle;
                padding: 0.5mm;
                background: #fff;
                colspan: 2;
            }}
            .cl-barcode-cell img {{
                width: 70mm;
                height: 9mm;
                display: inline-block;
            }}

            .cl-price-cell {{
                display: table-cell;
                text-align: right;
                vertical-align: middle;
                padding: 0.5mm 2mm 0.5mm 0;
                border-top: 0.2mm solid #ddd;
                background: #fff;
                colspan: 2;
            }}
            .cl-currency {{
                font-size: 8pt;
                font-weight: bold;
            }}
            .cl-amount {{
                font-size: 12pt;
                font-weight: bold;
            }}

            @media print {{
                * {{ -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }}
            }}
        </style>

        <div class="cl-label">

            <!-- ROW 1: Logo | Product Name -->
            <div class="cl-top">
                <div class="cl-logo-cell">
                    <img src="data:image/png;base64," alt="Logo"/>
                </div>
                <div class="cl-name-cell">
                    <t t-esc="product.name"/>
                </div>
            </div>

            <!-- ROW 2: Barcode spanning full width -->
            <div class="cl-mid">
                <div class="cl-barcode-cell" style="display:table-cell; width:86mm;">
                    <t t-if="product.barcode">
                        <img t-att-src="'/report/barcode/?type=Code128&amp;value=%s&amp;width=600&amp;height=100&amp;humanreadable=0' % product.barcode"
                             alt="barcode"/>
                    </t>
                    <t t-else="">
                        <span style="font-size:7pt;color:#aaa;font-style:italic;">No barcode</span>
                    </t>
                </div>
            </div>

            <!-- ROW 3: Price spanning full width -->
            <div class="cl-bottom">
                <div class="cl-price-cell" style="display:table-cell; width:86mm;">
                    <span class="cl-currency">
                        <t t-esc="product.currency_id.symbol if product.currency_id else '&#8377;'"/>
                    </span>
                    <span class="cl-amount">
                        <t t-esc="'%.2f' % (product.lst_price or 0.0)"/>
                    </span>
                </div>
            </div>

        </div>
    </template>

</odoo>