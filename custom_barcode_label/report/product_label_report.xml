<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_custom_label" model="report.paperformat">
        <field name="name">Custom Label 90x30mm</field>
        <field name="default">False</field>
        <field name="format">custom</field>
        <field name="page_height">30</field>
        <field name="page_width">90</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line">False</field>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_custom_label" model="ir.actions.report">
        <field name="name">Custom Product Label</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label.report_custom_label_document</field>
        <field name="report_file">custom_barcode_label.report_custom_label_document</field>
        <field name="binding_model_id" search="[('model','=','product.product')]" model="ir.model"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_barcode_label.paperformat_custom_label"/>
    </record>

    <record id="action_report_custom_label_tmpl" model="ir.actions.report">
        <field name="name">Custom Product Label</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label.report_custom_label_tmpl_document</field>
        <field name="report_file">custom_barcode_label.report_custom_label_tmpl_document</field>
        <field name="binding_model_id" search="[('model','=','product.template')]" model="ir.model"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_barcode_label.paperformat_custom_label"/>
    </record>

    <template id="report_custom_label_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-call="custom_barcode_label.report_custom_label_content"/>
            </t>
        </t>
    </template>

    <template id="report_custom_label_tmpl_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-call="custom_barcode_label.report_custom_label_content"/>
            </t>
        </t>
    </template>

    <template id="report_custom_label_content">
        <style type="text/css">
            @page { margin:0; padding:0; }
            html,body { margin:0 !important; padding:0 !important; }
            .page { margin:0 !important; padding:0 !important; }
            table { border-collapse:collapse !important; }
            tr { border:none !important; }
            td,th { border:none !important; border-top:none !important; border-bottom:none !important; border-left:none !important; border-right:none !important; }
        </style>

        <div style="width:338px;height:111px;border:2px solid #000;background:#fff;overflow:hidden;padding:0;margin:0;">
        <table width="338" height="111" border="0" cellspacing="0" cellpadding="0"
               style="width:338px;height:111px;border-collapse:collapse;border:none;background:#fff;table-layout:fixed;margin:0;padding:0;font-family:Arial,Helvetica,sans-serif;">
            <colgroup>
                <col width="55"/>
                <col width="228"/>
                <col width="55"/>
            </colgroup>
            <tr height="111">

                <!-- COL A: Logo rotated, fills full height top-to-bottom -->
                <td width="55" height="111" align="center" valign="middle"
                    style="width:55px;height:111px;border:none;padding:0;overflow:hidden;background:#fff;">
                    <!--
                        Image is 106px wide x 50px tall.
                        After rotate(-90deg): visually 50px wide x 106px tall.
                        Fits perfectly in 55px wide x 111px tall cell.
                        margin-left shifts it to center within 55px: (55-50)/2 = 2.5px
                    -->
                    <img src="data:image/png;base64,"
                         width="106" height="50"
                         style="display:block;
                                width:106px;height:50px;
                                margin-left:2px;margin-top:30px;
                                -webkit-transform:rotate(-90deg);
                                transform:rotate(-90deg);
                                transform-origin:center center;"
                         alt="Logo"/>
                </td>

                <!-- COL B: Name + Barcode -->
                <td width="228" height="111" valign="top"
                    style="width:228px;height:111px;border:none;padding:0;background:#fff;overflow:hidden;">
                    <table width="228" border="0" cellspacing="0" cellpadding="0"
                           style="width:228px;table-layout:fixed;border-collapse:collapse;border:none;">
                        <tr height="38">
                            <td width="228" height="38" align="center" valign="middle"
                                style="width:228px;height:38px;font-size:10pt;font-weight:bold;color:#000;border:none;padding:0 3px;overflow:hidden;white-space:nowrap;">
                                <t t-esc="product.name"/>
                            </td>
                        </tr>
                        <tr height="73">
                            <td width="228" height="73" align="center" valign="middle"
                                style="width:228px;height:73px;border:none;padding:1px 2px 0 2px;">
                                <t t-if="product.barcode">
                                    <t t-set="bc_src" t-value="get_barcode(product.barcode)"/>
                                    <t t-if="bc_src">
                                        <img t-att-src="bc_src" width="218" height="68"
                                             style="width:218px;height:68px;display:block;margin:0 auto;"
                                             alt="barcode"/>
                                    </t>
                                </t>
                                <t t-else="">
                                    <span style="font-size:7pt;color:#aaa;font-style:italic;">No barcode</span>
                                </t>
                            </td>
                        </tr>
                    </table>
                </td>

                <!-- COL C: MRP + QR -->
                <td width="55" height="111" align="center" valign="top"
                    style="width:55px;height:111px;border:none;padding:0;background:#fff;overflow:hidden;">
                    <table width="55" border="0" cellspacing="0" cellpadding="0"
                           style="width:55px;height:111px;table-layout:fixed;border-collapse:collapse;border:none;">
                        <tr height="40">
                            <td width="55" height="40" align="center" valign="middle"
                                style="width:55px;height:40px;border:none;padding:2px 1px 0 1px;">
                                <span style="display:block;font-size:5.5pt;font-weight:bold;color:#444;">MRP</span>
                                <span style="display:block;font-size:7.5pt;font-weight:bold;color:#000;line-height:1.3;">
                                    Rs. <t t-esc="'%.2f' % (product.lst_price or 0.0)"/>
                                </span>
                            </td>
                        </tr>
                        <tr height="71">
                            <td width="55" height="71" align="center" valign="middle"
                                style="width:55px;height:71px;border:none;padding:1px;">
                                <img src="data:image/png;base64," width="48" height="48"
                                     style="display:block;width:48px;height:48px;margin:0 auto 1px auto;"
                                     alt="Instagram"/>
                                <span style="display:block;font-size:4pt;color:#555;text-align:center;">Instagram</span>
                            </td>
                        </tr>
                    </table>
                </td>

            </tr>
        </table>
        </div>
    </template>

</odoo>