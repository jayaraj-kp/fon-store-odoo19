<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    ================================================================
      STEP 1 — Paper Format: 90 x 30 mm label
    ================================================================
    -->
    <record id="paperformat_custom_label" model="report.paperformat">
        <field name="name">Custom Label 90x30mm</field>
        <field name="default">False</field>
        <field name="format">custom</field>
        <field name="page_height">30</field>
        <field name="page_width">90</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">2</field>
        <field name="margin_right">2</field>
        <field name="header_line">False</field>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <!--
    ================================================================
      STEP 2a — Bound to product.product (Inventory list view)
    ================================================================
    -->
    <record id="action_report_custom_label" model="ir.actions.report">
        <field name="name">Custom Product Label</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label.report_custom_label_document</field>
        <field name="report_file">custom_barcode_label.report_custom_label_document</field>
        <field name="binding_model_id" search="[('model','=','product.product')]" model="ir.model"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_barcode_label.paperformat_custom_label"/>
    </record>

    <!--
    ================================================================
      STEP 2b — Bound to product.template (product form Print menu)
    ================================================================
    -->
    <record id="action_report_custom_label_tmpl" model="ir.actions.report">
        <field name="name">Custom Product Label</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label.report_custom_label_tmpl_document</field>
        <field name="report_file">custom_barcode_label.report_custom_label_tmpl_document</field>
        <field name="binding_model_id" search="[('model','=','product.template')]" model="ir.model"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_barcode_label.paperformat_custom_label"/>
    </record>

    <!--
    ================================================================
      STEP 3 — QWeb Templates
    ================================================================
    -->

    <!-- product.product context (Inventory list view) -->
    <template id="report_custom_label_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <t t-call="custom_barcode_label.report_custom_label_content"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- product.template context (product form view) -->
    <template id="report_custom_label_tmpl_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="tmpl">
                <t t-foreach="tmpl.product_variant_ids" t-as="product">
                    <t t-call="web.basic_layout">
                        <div class="page">
                            <t t-call="custom_barcode_label.report_custom_label_content"/>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- Single label card — variable in scope: product (product.product) -->
    <template id="report_custom_label_content">
        <div class="cl-label">

            <!-- ROW 1: Logo left + Product name centre -->
            <div class="cl-row cl-top">
                <div class="cl-logo">
                    <t t-if="product.company_id and product.company_id.logo">
                        <img t-att-src="image_data_uri(product.company_id.logo)"
                             class="cl-logo-img" alt="logo"/>
                    </t>
                    <t t-else="">
                        <span class="cl-company-name">
                            <t t-esc="product.company_id.name or ''"/>
                        </span>
                    </t>
                </div>
                <div class="cl-name">
                    <span t-field="product.display_name"/>
                </div>
            </div>

            <!-- ROW 2: Barcode image only (humanreadable=0 hides digits) -->
            <div class="cl-row cl-mid">
                <t t-if="product.barcode">
                    <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;humanreadable=%s' % ('Code128', product.barcode, 600, 100, 0)"
                         class="cl-barcode-img" alt="barcode"/>
                </t>
                <t t-else="">
                    <span class="cl-no-barcode">No barcode set</span>
                </t>
            </div>

            <!-- ROW 3: Price bottom-right -->
            <div class="cl-row cl-bottom">
                <div class="cl-price">
                    <span class="cl-currency">
                        <t t-esc="product.currency_id.symbol if product.currency_id else '&#8377;'"/>
                    </span>
                    <span class="cl-amount">
                        <t t-esc="'%.2f' % (product.lst_price or 0.0)"/>
                    </span>
                </div>
            </div>

        </div>

        <style type="text/css">
            * { box-sizing: border-box; margin: 0; padding: 0; }
            .cl-label {
                width: 86mm; height: 26mm;
                display: flex; flex-direction: column;
                justify-content: space-between;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 9px; color: #000; background: #fff;
                border: 0.3mm solid #bbb;
                padding: 1mm 1.5mm; overflow: hidden;
            }
            .cl-row { display: flex; align-items: center; width: 100%; }
            .cl-top { gap: 2mm; height: 9mm; }
            .cl-logo { flex: 0 0 auto; width: 20mm; height: 9mm; display: flex; align-items: center; }
            .cl-logo-img { max-width: 20mm; max-height: 9mm; object-fit: contain; }
            .cl-company-name { font-size: 7px; font-weight: bold; color: #444; word-break: break-word; }
            .cl-name { flex: 1; text-align: center; font-size: 10px; font-weight: bold; line-height: 1.2; overflow: hidden; word-break: break-word; }
            .cl-mid { justify-content: center; height: 10mm; overflow: hidden; }
            .cl-barcode-img { max-width: 62mm; height: 9mm; object-fit: contain; }
            .cl-no-barcode { font-size: 7px; color: #aaa; font-style: italic; }
            .cl-bottom { justify-content: flex-end; height: 6mm; border-top: 0.2mm solid #ddd; padding-top: 0.5mm; }
            .cl-price { display: flex; align-items: baseline; gap: 0.5mm; }
            .cl-currency { font-size: 8px; font-weight: bold; }
            .cl-amount { font-size: 13px; font-weight: bold; letter-spacing: -0.3px; }
            @media print {
                .cl-label { border-color: #999; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            }
        </style>

    </template>

</odoo>
