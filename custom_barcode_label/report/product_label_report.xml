<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_custom_label" model="report.paperformat">
        <field name="name">Custom Label 90x30mm</field>
        <field name="default">False</field>
        <field name="format">custom</field>
        <field name="page_height">30</field>
        <field name="page_width">90</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">2</field>
        <field name="margin_right">2</field>
        <field name="header_line">False</field>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_custom_label" model="ir.actions.report">
        <field name="name">Custom Product Label</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label.report_custom_label_document</field>
        <field name="report_file">custom_barcode_label.report_custom_label_document</field>
        <field name="binding_model_id" search="[('model','=','product.product')]" model="ir.model"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_barcode_label.paperformat_custom_label"/>
    </record>

    <record id="action_report_custom_label_tmpl" model="ir.actions.report">
        <field name="name">Custom Product Label</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label.report_custom_label_tmpl_document</field>
        <field name="report_file">custom_barcode_label.report_custom_label_tmpl_document</field>
        <field name="binding_model_id" search="[('model','=','product.template')]" model="ir.model"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_barcode_label.paperformat_custom_label"/>
    </record>

    <!-- product.product context -->
    <template id="report_custom_label_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <t t-call="custom_barcode_label.report_custom_label_content"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- product.template context -->
    <template id="report_custom_label_tmpl_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="tmpl">
                <t t-foreach="tmpl.product_variant_ids" t-as="product">
                    <t t-call="web.basic_layout">
                        <div class="page">
                            <t t-call="custom_barcode_label.report_custom_label_content"/>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================
         Single label card
         FIX 1: Use product.name instead of display_name
                (display_name includes [ref] prefix — name does not)
         FIX 2: Logo loaded via /web/image/ URL instead of
                image_data_uri() which fails in wkhtmltopdf context
         FIX 3: Full-page layout so label fills the paper
    ============================================================ -->
    <template id="report_custom_label_content">

        <style type="text/css">
            /* Page fill */
            html, body { margin: 0; padding: 0; width: 100%; height: 100%; }
            .page { margin: 0 !important; padding: 0 !important; }

            * { box-sizing: border-box; }

            .cl-label {
                width: 86mm;
                height: 26mm;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                font-family: Arial, Helvetica, sans-serif;
                color: #000;
                background: #fff;
                border: 0.3mm solid #ccc;
                padding: 1.2mm 2mm;
                overflow: hidden;
            }

            /* ── ROW 1: logo + name ── */
            .cl-top {
                display: flex;
                align-items: center;
                height: 9mm;
                gap: 2mm;
                overflow: hidden;
            }
            .cl-logo {
                flex: 0 0 auto;
                width: 18mm;
                height: 8mm;
                display: flex;
                align-items: center;
            }
            .cl-logo img {
                max-width: 18mm;
                max-height: 8mm;
                object-fit: contain;
            }
            .cl-company-text {
                font-size: 7pt;
                font-weight: bold;
                color: #333;
            }
            .cl-name {
                flex: 1;
                text-align: center;
                font-size: 9pt;
                font-weight: bold;
                line-height: 1.2;
                overflow: hidden;
                word-break: break-word;
            }

            /* ── ROW 2: barcode ── */
            .cl-mid {
                display: flex;
                justify-content: center;
                align-items: center;
                height: 10mm;
                overflow: hidden;
            }
            .cl-barcode-img {
                max-width: 64mm;
                height: 9mm;
                object-fit: contain;
            }
            .cl-no-barcode {
                font-size: 7pt;
                color: #aaa;
                font-style: italic;
            }

            /* ── ROW 3: price ── */
            .cl-bottom {
                display: flex;
                justify-content: flex-end;
                align-items: baseline;
                height: 5.5mm;
                border-top: 0.2mm solid #ddd;
                padding-top: 0.5mm;
            }
            .cl-currency {
                font-size: 8pt;
                font-weight: bold;
                margin-right: 0.5mm;
            }
            .cl-amount {
                font-size: 12pt;
                font-weight: bold;
            }

            @media print {
                .cl-label {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }
            }
        </style>

        <div class="cl-label">

            <!-- ROW 1: Logo + Product Name (NOT display_name — avoids [FS1] prefix) -->
            <div class="cl-top">
                <div class="cl-logo">
                    <!-- Use /web/image/ URL — works reliably in wkhtmltopdf -->
                    <t t-if="product.company_id and product.company_id.logo">
                        <img t-att-src="'/web/image/res.company/%d/logo' % product.company_id.id"
                             alt="logo"/>
                    </t>
                    <t t-else="">
                        <span class="cl-company-text">
                            <t t-esc="product.company_id.name or ''"/>
                        </span>
                    </t>
                </div>
                <div class="cl-name">
                    <!-- product.name = clean name, NO [internal ref] prefix -->
                    <t t-esc="product.name"/>
                </div>
            </div>

            <!-- ROW 2: Barcode image, digits hidden via humanreadable=0 -->
            <div class="cl-mid">
                <t t-if="product.barcode">
                    <img class="cl-barcode-img"
                         t-att-src="'/report/barcode/?type=Code128&amp;value=%s&amp;width=600&amp;height=100&amp;humanreadable=0' % product.barcode"
                         alt="barcode"/>
                </t>
                <t t-else="">
                    <span class="cl-no-barcode">No barcode</span>
                </t>
            </div>

            <!-- ROW 3: Price, bottom-right -->
            <div class="cl-bottom">
                <span class="cl-currency">
                    <t t-esc="product.currency_id.symbol if product.currency_id else '&#8377;'"/>
                </span>
                <span class="cl-amount">
                    <t t-esc="'%.2f' % (product.lst_price or 0.0)"/>
                </span>
            </div>

        </div>

    </template>

</odoo>
