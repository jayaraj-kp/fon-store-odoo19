<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pos_special_offer_list" model="ir.ui.view">
        <field name="name">pos.special.offer.list</field>
        <field name="model">pos.special.offer</field>
        <field name="arch" type="xml">
            <list string="Special Offers"
                  decoration-success="state=='active'"
                  decoration-muted="state=='expired'"
                  decoration-warning="state=='draft'">
                <field name="name"/>
                <field name="offer_type"/>
                <field name="coupon_code" optional="show"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="discount_type"/>
                <field name="discount_value"/>
                <field name="purchase_limit"/>
                <field name="usage_count"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="state" widget="badge"
                    decoration-success="state=='active'"
                    decoration-warning="state=='draft'"
                    decoration-danger="state=='expired'"/>
            </list>
        </field>
    </record>

    <record id="view_pos_special_offer_form" model="ir.ui.view">
        <field name="name">pos.special.offer.form</field>
        <field name="model">pos.special.offer</field>
        <field name="arch" type="xml">
            <form string="Special Offer">
                <header>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,active,expired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Offer Name..."/></h1>
                    </div>

                    <group>
                        <!-- LEFT: Offer Settings -->
                        <group string="Offer Settings">
                            <field name="offer_type" widget="radio"/>
                            <field name="coupon_code"
                                invisible="offer_type != 'coupon'"
                                required="offer_type == 'coupon'"/>
                            <field name="purchase_limit"/>
                            <field name="usage_count"/>
                            <field name="active"/>
                        </group>

                        <!-- RIGHT: Offer Period (with datetime) -->
                        <group string="Offer Period">
                            <field name="date_from" widget="datetime"/>
                            <field name="date_to"   widget="datetime"/>
                            <field name="days_remaining"/>
                        </group>
                    </group>

                    <!-- Discount section -->
                    <group string="Discount">
                        <group>
                            <field name="discount_type"/>
                            <field name="discount_value"/>
                        </group>
                    </group>

                    <!-- Products & Categories as fields (not tabs) -->
                    <group string="Apply To">
                        <field name="product_ids"
                            widget="many2many_tags"
                            string="Products"
                            options="{'no_create': True}"
                            help="Leave empty to apply to all products"/>
                        <field name="category_ids"
                            widget="many2many_tags"
                            string="Product Categories"
                            options="{'no_create': True}"
                            help="Leave empty to apply to all categories"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_special_offer_search" model="ir.ui.view">
        <field name="name">pos.special.offer.search</field>
        <field name="model">pos.special.offer</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="coupon_code"/>
                <filter string="Active"         name="active"         domain="[('state','=','active')]"/>
                <filter string="Draft"          name="draft"          domain="[('state','=','draft')]"/>
                <filter string="Expired"        name="expired"        domain="[('state','=','expired')]"/>
                <separator/>
                <filter string="Flat Discount"  name="flat"           domain="[('offer_type','=','flat_discount')]"/>
                <filter string="Coupon"         name="coupon"         domain="[('offer_type','=','coupon')]"/>
            </search>
        </field>
    </record>

    <record id="action_pos_special_offer" model="ir.actions.act_window">
        <field name="name">Special Offers</field>
        <field name="res_model">pos.special.offer</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pos_special_offer_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem id="menu_pos_special_offers"
        name="Special Offers"
        parent="point_of_sale.menu_point_of_sale"
        action="action_pos_special_offer"
        sequence="25"
        groups="point_of_sale.group_pos_manager"/>

</odoo>
