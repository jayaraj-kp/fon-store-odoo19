<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Scheduled Action: update latest purchase cost on stock quants daily. -->
    <record forcecreate="True"
            id="set_products_latest_purchase_cost_scheduler_action"
            model="ir.cron">
        <field name="name">Stock: Set Latest Purchase Cost</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="code">model._set_latest_cost()</field>
    </record>

</odoo>