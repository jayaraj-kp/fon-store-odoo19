<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_config_cash_transfer" model="ir.ui.view">
        <field name="name">pos.config.form.cash.transfer</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='iface_tax_included']" position="after">
                <field name="allow_cash_transfer"/>
                <field name="cash_transfer_requires_manager"
                       invisible="not allow_cash_transfer"/>
            </xpath>
        </field>
    </record>
</odoo>
