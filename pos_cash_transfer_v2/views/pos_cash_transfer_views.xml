<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pos_cash_transfer_list" model="ir.ui.view">
        <field name="name">pos.cash.transfer.list</field>
        <field name="model">pos.cash.transfer</field>
        <field name="arch" type="xml">
            <list string="POS Cash Transfers"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="transfer_date"/>
                <field name="from_pos_id"/>
                <field name="to_pos_id"/>
                <field name="amount"/>
                <field name="reason"/>
                <field name="cashier_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_pos_cash_transfer_form" model="ir.ui.view">
        <field name="name">pos.cash.transfer.form</field>
        <field name="model">pos.cash.transfer</field>
        <field name="arch" type="xml">
            <form string="POS Cash Transfer">
                <header>
                    <button name="action_transfer" string="Process Transfer"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Transfer Details">
                            <field name="from_session_id"/>
                            <field name="to_session_id"/>
                            <field name="amount"/>
                            <field name="transfer_date"/>
                        </group>
                        <group string="Other Info">
                            <field name="from_pos_id"/>
                            <field name="to_pos_id"/>
                            <field name="cashier_id"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" placeholder="Reason for transfer..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_cash_transfer_search" model="ir.ui.view">
        <field name="name">pos.cash.transfer.search</field>
        <field name="model">pos.cash.transfer</field>
        <field name="arch" type="xml">
            <search string="Cash Transfers">
                <field name="name"/>
                <field name="from_pos_id"/>
                <field name="to_pos_id"/>
                <field name="cashier_id"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <group expand="0" string="Group By">
                    <filter string="From Counter" name="grp_from" context="{'group_by': 'from_pos_id'}"/>
                    <filter string="To Counter" name="grp_to" context="{'group_by': 'to_pos_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pos_cash_transfer" model="ir.actions.act_window">
        <field name="name">Cash Transfers</field>
        <field name="res_model">pos.cash.transfer</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_pos_cash_transfer"
              name="Cash Transfers"
              parent="point_of_sale.menu_point_of_sale"
              action="action_pos_cash_transfer"
              sequence="25"/>

</odoo>
