<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="point_of_sale.Navbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//DropdownItem[last()]" position="before">
            <DropdownItem onSelected="() => this.openCashTransferDialog()">
                <i class="fa fa-exchange me-2"/>
                Cash Transfer
            </DropdownItem>
        </xpath>
    </t>

</templates>
