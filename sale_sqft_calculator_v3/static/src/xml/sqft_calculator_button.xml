<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        Template for the Sqft Calculator Button field widget.
        Renders a focusable 📐 calculator icon.
        Tab → focus | Enter/Space → open popup
    -->
    <t t-name="sale_sqft_calculator.SqftCalculatorButton">
        <button
            t-if="isVisible"
            class="btn btn-sm btn-link text-primary o_sqft_calc_btn"
            title="📐 Open Sq.Ft Calculator (Press Enter to open)"
            tabindex="0"
            t-on-click.stop="openWizard"
            t-on-keydown="onKeyDown"
            style="font-size: 16px; padding: 0 4px; line-height: 1.5;"
        >
            <i class="fa fa-calculator" aria-label="Square Feet Calculator"/>
        </button>
        <span t-else="" style="display:inline-block; width:24px;"/>
    </t>

</templates>
