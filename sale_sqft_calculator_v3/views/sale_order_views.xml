<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_sqft_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.sqft.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!--
                Place the 📐 calculator button (OWL widget) right after the product field.
                Uses `is_sqft_product` boolean field as the widget carrier.
                  - Tab from product → focus lands on this button
                  - Press Enter / Space → opens the Sq.Ft Calculator popup
            -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']"
                   position="after">
                <field
                    name="is_sqft_product"
                    widget="sqft_calculator_button"
                    string=""
                    nolabel="1"
                    optional="show"
                    readonly="0"
                    column_invisible="False"
                />
            </xpath>

        </field>
    </record>
</odoo>
