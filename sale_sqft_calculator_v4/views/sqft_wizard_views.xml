<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sqft_calculator_wizard_form" model="ir.ui.view">
        <field name="name">sqft.calculator.wizard.form</field>
        <field name="model">sqft.calculator.wizard</field>
        <field name="arch" type="xml">
            <form string="Square Feet Calculator">
                <sheet>

                    <!-- Product title -->
                    <div class="oe_title mb-3">
                        <span class="text-muted" style="font-size:13px;">
                            Calculating area for:
                        </span>
                        <h3 style="margin-top:4px;">
                            <field name="product_id" readonly="1" nolabel="1"/>
                        </h3>
                    </div>

                    <separator string="Enter Dimensions (in feet)"/>

                    <div class="row mt-2 mb-2">
                        <div class="col-6">
                            <group>
                                <field name="width"
                                       string="Width (ft)"
                                       widget="float"
                                       placeholder="e.g. 10.5"
                                       options="{'precision': 4}"/>
                            </group>
                        </div>
                        <div class="col-6">
                            <group>
                                <field name="height"
                                       string="Height (ft)"
                                       widget="float"
                                       placeholder="e.g. 8.0"
                                       options="{'precision': 4}"/>
                            </group>
                        </div>
                    </div>

                    <separator string="Calculated Result"/>

                    <div class="alert alert-success text-center mt-2"
                         role="status"
                         style="border-radius:8px; padding:20px;">
                        <div style="font-size:14px; color:#555; margin-bottom:6px;">
                            Width x Height
                        </div>
                        <div style="font-size:32px; font-weight:bold; color:#28a745; margin:8px 0;">
                            <field name="sqft_display"
                                   readonly="1"
                                   nolabel="1"
                                   widget="char"/>
                        </div>
                        <div style="font-size:12px; color:#888; margin-top:6px;">
                            This value will replace the Quantity on the order line
                        </div>
                    </div>

                    <!-- Keyboard shortcut hint -->
                    <div class="text-center mt-3"
                         style="font-size:12px; color:#aaa; letter-spacing:0.3px;">
                        Keyboard shortcuts:
                        Alt + C to Apply  |  Alt + X to Cancel
                    </div>

                </sheet>

                <footer>
                    <!--
                        data-hotkey="c"  means  Alt + C  triggers this button (native Odoo feature).
                        data-hotkey="x"  means  Alt + X  triggers Cancel.
                        No custom JavaScript needed.
                    -->
                    <button name="action_apply"
                            string="Apply to Order Line"
                            type="object"
                            class="btn-primary"
                            data-hotkey="c"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"
                            data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
