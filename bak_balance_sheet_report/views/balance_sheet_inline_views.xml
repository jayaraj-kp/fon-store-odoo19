<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         INLINE REPORT PAGE TEMPLATE
         ================================================================ -->
    <template id="balance_sheet_inline_template" name="Balance Sheet Report">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <link rel="stylesheet"
                      href="/bak_balance_sheet_report/static/src/css/balance_sheet.css"/>
            </t>
            <t t-set="body_classname">o_web_client</t>

            <div id="bak_bs_app"
                 t-att-data-wizard-id="wizard.id"
                 t-att-data-date-to="wizard.date_to"
                 t-att-data-date-from="wizard.date_from or ''"
                 t-att-data-target-move="wizard.target_move"
                 t-att-data-display-dc="'true' if wizard.display_debit_credit else 'false'">

                <!-- ── TOP BAR ─────────────────────────────────────────── -->
                <div class="bak-bs-topbar">
                    <div class="bak-bs-topbar-left">
                        <a href="/web#action=account.action_account_form"
                           class="bak-bs-back">
                            &#8592; Accounting
                        </a>
                        <span class="bak-bs-title">Balance Sheet</span>
                    </div>
                    <div class="bak-bs-topbar-right">
                        <button class="bak-btn bak-btn-outline" id="btn_pdf">
                            &#128438; PDF
                        </button>
                        <button class="bak-btn bak-btn-outline" id="btn_xlsx">
                            &#128202; XLSX
                        </button>
                        <button class="bak-btn bak-btn-outline" id="btn_comparison"
                                title="Enable/Disable Comparison Period">
                            &#8646; Comparison
                        </button>
                        <select class="bak-select" id="sel_moves">
                            <option value="posted">Posted Entries</option>
                            <option value="all">All Entries</option>
                        </select>
                    </div>
                </div>

                <!-- ── FILTER BAR ──────────────────────────────────────── -->
                <div class="bak-bs-filterbar">
                    <div class="bak-filter-group">
                        <label>As of Date</label>
                        <input type="date" id="flt_date_to" class="bak-input"/>
                    </div>
                    <div class="bak-filter-group">
                        <label>From Date</label>
                        <input type="date" id="flt_date_from" class="bak-input"/>
                    </div>
                    <div class="bak-filter-group">
                        <label class="bak-check-label">
                            <input type="checkbox" id="chk_dc"/>
                            Show Debit/Credit
                        </label>
                    </div>
                    <div class="bak-filter-group" id="grp_comparison" style="display:none">
                        <label>Compare As of</label>
                        <input type="date" id="flt_comp_date_to" class="bak-input"/>
                    </div>
                    <div class="bak-filter-group" id="grp_comparison_from" style="display:none">
                        <label>Compare From</label>
                        <input type="date" id="flt_comp_date_from" class="bak-input"/>
                    </div>
                    <div class="bak-filter-group">
                        <button class="bak-btn bak-btn-primary" id="btn_apply">
                            &#8635; Apply Filters
                        </button>
                    </div>
                </div>

                <!-- ── REPORT CONTENT ──────────────────────────────────── -->
                <div class="bak-bs-body">
                    <div id="bak_report_content" class="bak-report-wrap">
                        <!-- Spinner on first load -->
                        <div id="bak_loading" class="bak-loading">
                            <div class="bak-spinner"></div>
                            <span>Loading report…</span>
                        </div>
                    </div>
                </div>

            </div><!-- /#bak_bs_app -->

            <t t-set="body_end">
                <script src="/bak_balance_sheet_report/static/src/js/balance_sheet_action.js"/>
            </t>
        </t>
    </template>

    <!-- ================================================================
         PDF PRINT TEMPLATE
         ================================================================ -->
    <template id="balance_sheet_pdf_template" name="Balance Sheet PDF">
        <html>
            <head>
                <meta charset="UTF-8"/>
                <style>
                    body { font-family: Arial, sans-serif; font-size: 11px; margin: 20px; }
                    h1 { text-align: center; font-size: 16px; margin-bottom: 4px; }
                    .subtitle { text-align: center; color: #555; margin-bottom: 16px; }
                    table { width: 100%; border-collapse: collapse; }
                    th { background: #4B4B6E; color: white; padding: 6px 8px; text-align: left; }
                    td { padding: 4px 8px; border-bottom: 1px solid #eee; }
                    .section-header td { background: #D9D9E8; font-weight: bold;
                                         padding: 6px 8px; }
                    .subsection-header td { font-weight: bold; padding: 4px 8px 2px 16px; }
                    .subtotal td { font-weight: bold; border-top: 1px solid #aaa; }
                    .grand-total td { font-weight: bold; background: #B8B8D0;
                                       border-top: 2px solid #555; }
                    .liab-equity-total td { font-weight: bold; background: #4B4B6E;
                                             color: white; border-top: 2px solid #333; }
                    .num { text-align: right; }
                    .negative { color: #c00; }
                    .indent { padding-left: 24px; }
                </style>
            </head>
            <body>
                <h1><t t-esc="data.get('company_name', '')"/> — Balance Sheet</h1>
                <p class="subtitle">
                    As of <t t-esc="data.get('date_to', '')"/>
                    <t t-if="data.get('date_from')">
                        (from <t t-esc="data['date_from']"/>)
                    </t>
                </p>

                <t t-set="show_dc" t-value="data.get('display_debit_credit', False)"/>
                <t t-set="show_comp" t-value="data.get('enable_comparison', False)"/>
                <t t-set="sym" t-value="data.get('currency_symbol', '')"/>

                <table>
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Account</th>
                            <t t-if="show_dc">
                                <th class="num">Debit</th>
                                <th class="num">Credit</th>
                            </t>
                            <th class="num">Balance</th>
                            <t t-if="show_comp">
                                <th class="num">Comparison</th>
                            </t>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- ASSETS -->
                        <tr class="section-header">
                            <td colspan="10">ASSETS</td>
                        </tr>
                        <t t-foreach="data.get('assets', [])" t-as="sub">
                            <tr class="subsection-header">
                                <td colspan="10"><t t-esc="sub['name']"/></td>
                            </tr>
                            <t t-foreach="sub.get('rows', [])" t-as="row">
                                <tr>
                                    <td><t t-esc="row.get('code','')"/></td>
                                    <td class="indent"><t t-esc="row['name']"/></td>
                                    <t t-if="show_dc">
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('debit',0))"/></td>
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('credit',0))"/></td>
                                    </t>
                                    <td class="num">
                                        <t t-att-class="'negative' if row['balance'] &lt; 0 else ''">
                                            <t t-esc="'%s %.2f' % (sym, row['balance'])"/>
                                        </t>
                                    </td>
                                    <t t-if="show_comp">
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('comp_balance',0))"/></td>
                                    </t>
                                </tr>
                            </t>
                            <tr class="subtotal">
                                <td></td>
                                <td>Total <t t-esc="sub['name']"/></td>
                                <t t-if="show_dc"><td></td><td></td></t>
                                <td class="num"><t t-esc="'%s %.2f' % (sym, sub['subtotal'])"/></td>
                                <t t-if="show_comp">
                                    <td class="num"><t t-esc="'%s %.2f' % (sym, sub.get('comp_subtotal',0))"/></td>
                                </t>
                            </tr>
                        </t>
                        <tr class="grand-total">
                            <td></td>
                            <td>Total ASSETS</td>
                            <t t-if="show_dc"><td></td><td></td></t>
                            <td class="num"><t t-esc="'%s %.2f' % (sym, data['total_assets'])"/></td>
                            <t t-if="show_comp">
                                <td class="num"><t t-esc="'%s %.2f' % (sym, data.get('comp_total_assets',0))"/></td>
                            </t>
                        </tr>

                        <!-- LIABILITIES -->
                        <tr class="section-header">
                            <td colspan="10">LIABILITIES</td>
                        </tr>
                        <t t-foreach="data.get('liabilities', [])" t-as="sub">
                            <tr class="subsection-header">
                                <td colspan="10"><t t-esc="sub['name']"/></td>
                            </tr>
                            <t t-foreach="sub.get('rows', [])" t-as="row">
                                <tr>
                                    <td><t t-esc="row.get('code','')"/></td>
                                    <td class="indent"><t t-esc="row['name']"/></td>
                                    <t t-if="show_dc">
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('debit',0))"/></td>
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('credit',0))"/></td>
                                    </t>
                                    <td class="num">
                                        <t t-att-class="'negative' if row['balance'] &lt; 0 else ''">
                                            <t t-esc="'%s %.2f' % (sym, row['balance'])"/>
                                        </t>
                                    </td>
                                    <t t-if="show_comp">
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('comp_balance',0))"/></td>
                                    </t>
                                </tr>
                            </t>
                            <tr class="subtotal">
                                <td></td>
                                <td>Total <t t-esc="sub['name']"/></td>
                                <t t-if="show_dc"><td></td><td></td></t>
                                <td class="num"><t t-esc="'%s %.2f' % (sym, sub['subtotal'])"/></td>
                                <t t-if="show_comp">
                                    <td class="num"><t t-esc="'%s %.2f' % (sym, sub.get('comp_subtotal',0))"/></td>
                                </t>
                            </tr>
                        </t>
                        <tr class="grand-total">
                            <td></td>
                            <td>Total LIABILITIES</td>
                            <t t-if="show_dc"><td></td><td></td></t>
                            <td class="num"><t t-esc="'%s %.2f' % (sym, data['total_liabilities'])"/></td>
                            <t t-if="show_comp">
                                <td class="num"><t t-esc="'%s %.2f' % (sym, data.get('comp_total_liabilities',0))"/></td>
                            </t>
                        </tr>

                        <!-- EQUITY -->
                        <tr class="section-header">
                            <td colspan="10">EQUITY</td>
                        </tr>
                        <t t-foreach="data.get('equity', [])" t-as="sub">
                            <tr class="subsection-header">
                                <td colspan="10"><t t-esc="sub['name']"/></td>
                            </tr>
                            <t t-foreach="sub.get('rows', [])" t-as="row">
                                <tr>
                                    <td><t t-esc="row.get('code','')"/></td>
                                    <td class="indent"><t t-esc="row['name']"/></td>
                                    <t t-if="show_dc">
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('debit',0))"/></td>
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('credit',0))"/></td>
                                    </t>
                                    <td class="num">
                                        <t t-att-class="'negative' if row['balance'] &lt; 0 else ''">
                                            <t t-esc="'%s %.2f' % (sym, row['balance'])"/>
                                        </t>
                                    </td>
                                    <t t-if="show_comp">
                                        <td class="num"><t t-esc="'%s %.2f' % (sym, row.get('comp_balance',0))"/></td>
                                    </t>
                                </tr>
                            </t>
                            <tr class="subtotal">
                                <td></td>
                                <td>Total <t t-esc="sub['name']"/></td>
                                <t t-if="show_dc"><td></td><td></td></t>
                                <td class="num"><t t-esc="'%s %.2f' % (sym, sub['subtotal'])"/></td>
                                <t t-if="show_comp">
                                    <td class="num"><t t-esc="'%s %.2f' % (sym, sub.get('comp_subtotal',0))"/></td>
                                </t>
                            </tr>
                        </t>
                        <tr class="grand-total">
                            <td></td>
                            <td>Total EQUITY</td>
                            <t t-if="show_dc"><td></td><td></td></t>
                            <td class="num"><t t-esc="'%s %.2f' % (sym, data['total_equity'])"/></td>
                            <t t-if="show_comp">
                                <td class="num"><t t-esc="'%s %.2f' % (sym, data.get('comp_total_equity',0))"/></td>
                            </t>
                        </tr>

                        <!-- LIABILITIES + EQUITY -->
                        <tr class="liab-equity-total">
                            <td></td>
                            <td>LIABILITIES + EQUITY</td>
                            <t t-if="show_dc"><td></td><td></td></t>
                            <td class="num"><t t-esc="'%s %.2f' % (sym, data['total_liabilities_equity'])"/></td>
                            <t t-if="show_comp">
                                <td class="num"><t t-esc="'%s %.2f' % (sym, data.get('comp_total_liabilities_equity',0))"/></td>
                            </t>
                        </tr>
                    </tbody>
                </table>
            </body>
        </html>
    </template>

</odoo>
