<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- URL Action for direct menu access -->
    <record id="action_bak_balance_sheet_url" model="ir.actions.act_url">
        <field name="name">Balance Sheet (Inline)</field>
        <field name="url">/bak/balance_sheet</field>
        <field name="target">self</field>
    </record>

    <!--
        We create our own standalone submenu under account.menu_finance
        (the root Accounting app menu — always present in Odoo CE).
        This avoids any dependency on Enterprise or third-party menu IDs.
    -->
    <menuitem
        id="menu_bak_reports_root"
        name="Inline Reports"
        parent="account.menu_finance"
        sequence="100"
    />

    <menuitem
        id="menu_bak_balance_sheet"
        name="Balance Sheet"
        parent="menu_bak_reports_root"
        action="action_bak_balance_sheet_url"
        sequence="1"
    />

</odoo>
