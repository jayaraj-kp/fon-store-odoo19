<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Product Template Form View -->
        <record id="product_template_form_view_model" model="ir.ui.view">
            <field name="name">product.template.form.model</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="model_number" placeholder="e.g., MODEL-2024-001"/>
                </xpath>
            </field>
        </record>

        <!-- Product Variant Form View -->
        <record id="product_product_form_view_model" model="ir.ui.view">
            <field name="name">product.product.form.model</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="model_number" placeholder="e.g., MODEL-2024-001"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>