<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        CustomerRequiredDialog
        A standalone OWL dialog (no POS popup inheritance).
        Rendered by the 'dialog' service - compatible with Odoo 19.
    -->
    <t t-name="pos_require_customer.CustomerRequiredDialog" owl="1">
        <!-- Backdrop -->
        <div style="
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
        ">
            <!-- Dialog Box -->
            <div style="
                background: #ffffff;
                border-radius: 14px;
                box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
                min-width: 360px;
                max-width: 440px;
                overflow: hidden;
                font-family: 'Roboto', 'Segoe UI', sans-serif;
                animation: fadeInScale 0.18s ease;
            ">
                <!-- Header -->
                <div style="
                    background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
                    padding: 18px 24px;
                    display: flex;
                    align-items: center;
                    gap: 12px;
                ">
                    <span style="font-size: 26px;">⚠️</span>
                    <span style="
                        color: #fff;
                        font-size: 19px;
                        font-weight: 700;
                        letter-spacing: 0.3px;
                    ">
                        <t t-esc="props.title"/>
                    </span>
                </div>

                <!-- Body -->
                <div style="padding: 26px 28px 10px 28px; text-align: center;">
                    <p style="
                        font-size: 15px;
                        color: #333;
                        line-height: 1.65;
                        margin: 0 0 24px 0;
                    ">
                        <t t-esc="props.body"/>
                    </p>
                </div>

                <!-- Footer -->
                <div style="
                    padding: 0 28px 24px 28px;
                    display: flex;
                    justify-content: center;
                ">
                    <button
                        t-on-click="confirm"
                        style="
                            background: linear-gradient(135deg, #e74c3c, #c0392b);
                            color: #fff;
                            border: none;
                            border-radius: 8px;
                            padding: 12px 52px;
                            font-size: 16px;
                            font-weight: 700;
                            cursor: pointer;
                            letter-spacing: 0.5px;
                            box-shadow: 0 4px 14px rgba(231, 76, 60, 0.4);
                            transition: transform 0.1s, box-shadow 0.1s;
                        "
                        onmouseover="this.style.transform='scale(1.03)'"
                        onmouseout="this.style.transform='scale(1)'"
                    >
                        OK
                    </button>
                </div>
            </div>
        </div>
    </t>

</templates>
