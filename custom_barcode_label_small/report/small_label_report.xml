<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  PAPER FORMAT — 27x12mm                                         -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <record id="paperformat_small_label" model="report.paperformat">
        <field name="name">Custom Label 27x12mm</field>
        <field name="default">False</field>
        <field name="format">custom</field>
        <field name="page_height">12</field>
        <field name="page_width">27</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line">False</field>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  REPORT ACTIONS                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- product.product -->
    <record id="action_report_small_label" model="ir.actions.report">
        <field name="name">Custom Small Product Label (27x12mm)</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label_small.report_small_label_main</field>
        <field name="report_file">custom_barcode_label_small.report_small_label_main</field>
        <field name="paperformat_id" ref="custom_barcode_label_small.paperformat_small_label"/>
    </record>

    <!-- product.template -->
    <record id="action_report_small_label_tmpl" model="ir.actions.report">
        <field name="name">Custom Small Product Label (27x12mm)</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_barcode_label_small.report_small_label_tmpl_main</field>
        <field name="report_file">custom_barcode_label_small.report_small_label_tmpl_main</field>
        <field name="paperformat_id" ref="custom_barcode_label_small.paperformat_small_label"/>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  QWEB TEMPLATES                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- product.product wrapper -->
    <template id="report_small_label_main">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-set="qty" t-value="label_qty.get(product.id, 1) if label_qty.get(product.id, 0) else 1"/>
                <t t-foreach="range(int(qty))" t-as="copy_index">
                    <div style="page-break-after: always;">
                        <t t-call="custom_barcode_label_small.report_small_label_content"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- product.template wrapper -->
    <template id="report_small_label_tmpl_main">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="product">
                <t t-set="qty" t-value="label_qty.get(product.id, 1) if label_qty.get(product.id, 0) else 1"/>
                <t t-foreach="range(int(qty))" t-as="copy_index">
                    <div style="page-break-after: always;">
                        <t t-call="custom_barcode_label_small.report_small_label_content"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  LABEL CONTENT  27x12mm                                         -->
    <!--                                                                 -->
    <!--  ROW 1  ~3mm : Product name (bold, centred)                     -->
    <!--  ROW 2  ~6mm : Barcode image via Odoo built-in URL              -->
    <!--  ROW 3  ~3mm : Barcode number (left) | MRP price (right)        -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <template id="report_small_label_content">
        <style type="text/css">
            @page {
                margin: 0mm;
                padding: 0mm;
                size: 27mm 12mm;
            }
            html, body {
                margin: 0 !important;
                padding: 0 !important;
                width: 27mm;
                height: 12mm;
            }
            .page { margin: 0 !important; padding: 0 !important; }
            table { border-collapse: collapse; }
            tr, td { border: none !important; }
        </style>

        <table style="width:27mm; height:12mm; table-layout:fixed;
                      border-collapse:collapse;
                      font-family:Arial,Helvetica,sans-serif; background:#fff;">

            <t t-if="product.barcode">

                <!-- ROW 1: Product name -->
                <tr style="height:3mm;">
                    <td colspan="2"
                        style="width:27mm; height:3mm; padding:0 0.5mm;
                               font-size:5pt; font-weight:bold; color:#000;
                               text-align:center; vertical-align:middle;
                               overflow:hidden; white-space:nowrap;">
                        <t t-esc="product.name"/>
                    </td>
                </tr>

                <!-- ROW 2: Barcode image — uses Odoo's built-in /report/barcode/ endpoint -->
                <tr style="height:6mm;">
                    <td colspan="2"
                        style="width:27mm; height:6mm; padding:0 0.3mm;
                               text-align:center; vertical-align:middle;">
                        <img t-attf-src="/report/barcode/Code128/{{ product.barcode }}?width=600&amp;height=100&amp;humanreadable=0"
                             style="display:block; width:25mm; height:5.5mm; margin:0 auto;"
                             alt="barcode"/>
                    </td>
                </tr>

                <!-- ROW 3: Barcode number + MRP -->
                <tr style="height:3mm;">
                    <td style="width:14mm; height:3mm; padding:0 0 0 0.5mm;
                               font-size:4pt; font-weight:bold; color:#000;
                               vertical-align:middle;
                               overflow:hidden; white-space:nowrap;">
                        <t t-esc="product.barcode"/>
                    </td>
                    <td style="width:13mm; height:3mm; padding:0 0.5mm 0 0;
                               font-size:4pt; font-weight:bold; color:#000;
                               text-align:right; vertical-align:middle;">
                        MRP Rs.<t t-esc="'%.2f' % (product.lst_price or 0.0)"/>
                    </td>
                </tr>

            </t>

            <!-- No barcode fallback -->
            <t t-else="">
                <tr style="height:9mm;">
                    <td colspan="2"
                        style="width:27mm; height:9mm; padding:1mm;
                               font-size:5pt; font-weight:bold; color:#000;
                               text-align:center; vertical-align:middle;">
                        <t t-esc="product.name"/>
                        <br/>
                        <span style="font-size:4pt; color:#aaa; font-style:italic;">No barcode</span>
                    </td>
                </tr>
                <tr style="height:3mm;">
                    <td style="width:14mm; height:3mm;"/>
                    <td style="width:13mm; height:3mm; padding:0 0.5mm 0 0;
                               font-size:4pt; font-weight:bold; color:#000;
                               text-align:right; vertical-align:middle;">
                        MRP Rs.<t t-esc="'%.2f' % (product.lst_price or 0.0)"/>
                    </td>
                </tr>
            </t>

        </table>
    </template>

</odoo>


