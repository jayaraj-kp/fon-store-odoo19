<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherit sale.order form view.

        We replace the plain <button> (which Odoo skips during Tab navigation)
        with a FIELD widget (sqft_button_field).  Fields ARE included in the
        Tab cycle, so after selecting a product the user can:
            Tab  →  focus lands on the 🖩 icon
            Enter / Space  →  wizard opens
            (fill Width + Height)
            Alt+C  →  applied, popup closes
    -->
    <record id="view_sale_order_form_sqft_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.sqft.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!--
                Insert the calculator field widget BEFORE the Quantity column.
                This places it visually between Product and Quantity.
                The field carrier is `is_sqft_product` (a Boolean on sale.order.line).
            -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']"
                   position="before">
                <field
                    name="is_sqft_product"
                    widget="sqft_button_field"
                    string=" "
                    nolabel="1"
                    optional="show"
                    readonly="0"
                />
            </xpath>

        </field>
    </record>

</odoo>
