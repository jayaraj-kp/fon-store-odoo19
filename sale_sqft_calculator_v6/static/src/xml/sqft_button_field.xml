<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        Template for SqftButtonField widget.
        Renders a focusable calculator icon that sits inside the Tab order.
        - tabindex="0"  makes it reachable by Tab
        - t-on-keydown  handles Enter / Space to open the wizard
        - t-on-click    handles mouse click
    -->
    <t t-name="sale_sqft_calculator.SqftButtonField">
        <button
            t-if="hasProduct"
            type="button"
            tabindex="0"
            class="btn btn-sm btn-link text-primary o_sqft_calc_btn"
            title="Sq.Ft Calculator — Tab to focus, Enter to open, Alt+C to apply"
            t-on-click="onClick"
            t-on-keydown="onKeyDown"
            style="padding: 0 6px; font-size: 15px; vertical-align: middle;"
        >
            <i class="fa fa-calculator"/>
        </button>
        <span t-else="" style="display:inline-block; width:28px;"/>
    </t>

</templates>
