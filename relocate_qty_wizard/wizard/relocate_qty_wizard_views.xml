<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="relocate_qty_wizard_form_view" model="ir.ui.view">
        <field name="name">relocate.qty.wizard.form</field>
        <field name="model">relocate.qty.wizard</field>
        <field name="arch" type="xml">
            <form string="Relocate Stock Quant">
                <sheet>
                    <group>
                        <field name="reason" placeholder="Product Relocated"/>
                        <field name="dest_location_id"
                               options="{'no_create': True}"
                               placeholder="Select destination location..."/>
                    </group>

                    <separator string="Products &amp; Quantities"/>

                    <field name="line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="product_id" readonly="1"/>
                            <field name="location_id" readonly="1" optional="show"/>
                            <field name="available_qty" readonly="1" string="On Hand"/>
                            <field name="qty" string="Qty to Relocate"/>
                        </list>
                    </field>
                </sheet>

                <footer>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Discard"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
