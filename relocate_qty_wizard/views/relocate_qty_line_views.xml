<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_quant_relocate_view_form_inherit" model="ir.ui.view">
        <field name="name">stock.quant.relocate.form.inherit.qty</field>
        <field name="model">stock.quant.relocate</field>
        <field name="inherit_id" ref="stock.stock_quant_relocate_view_form"/>
        <field name="arch" type="xml">

            <!-- Insert the product/quantity table just before the footer -->
            <footer position="before">
                <separator string="Products &amp; Quantities"/>
                <field name="line_ids" nolabel="1">
                    <list editable="bottom">
                        <field name="quant_id" column_invisible="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="available_qty" readonly="1" string="On Hand"/>
                        <field name="qty" string="Qty to Relocate"/>
                    </list>
                </field>
            </footer>

        </field>
    </record>

</odoo>
