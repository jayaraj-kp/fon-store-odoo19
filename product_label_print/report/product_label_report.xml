<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Custom paper format MUST be defined first before the report action references it -->
    <record id="paperformat_label_gp1125t" model="report.paperformat">
        <field name="name">GP-1125T Label Sheet (150mm x 30mm)</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">30</field>
        <field name="page_width">150</field>
        <field name="orientation">Portrait</field>
        <field name="top_margin">0</field>
        <field name="bottom_margin">0</field>
        <field name="left_margin">0</field>
        <field name="right_margin">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">203</field>
    </record>

    <record id="action_product_label_report" model="ir.actions.report">
        <field name="name">Product Labels - GP1125T</field>
        <field name="model">product.label.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">product_label_print.product_label_template</field>
        <field name="report_file">product_label_print.product_label_template</field>
        <field name="print_report_name">'Product_Labels'</field>
        <field name="paperformat_id" ref="product_label_print.paperformat_label_gp1125t"/>
    </record>

</odoo>
