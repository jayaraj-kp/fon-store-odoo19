<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="product_label_template">
    <t t-call="web.html_container">
        <style type="text/css">
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { font-family: Arial, Helvetica, sans-serif; background: white; }

            table.sheet {
                border-collapse: separate;
                border-spacing: 0;
                width: 132mm;       /* 65 + 2 + 65 */
                margin-left: 10mm;
                table-layout: fixed;
            }

            /* Shared label cell style */
            td.lbl {
                border: 1.5px solid #999;
                border-radius: 3mm;
                background: white;
                overflow: hidden;
                vertical-align: middle;
                text-align: center;
            }

            /* QR label (top die-cut) */
            td.lbl-qr {
                width: 65mm;
                height: 33mm;
                padding: 2mm 1mm 1mm 1mm;
            }
            .qr-img {
                width: 8mm;
                height: 8mm;
                display: block;
                margin: 0 auto 1.5mm auto;
            }
            .lbl-code {
                font-size: 7pt;
                font-weight: bold;
                letter-spacing: 0.3mm;
                white-space: nowrap;
                text-align: center;
            }

            /* Name label (bottom die-cut) */
            td.lbl-name {
                width: 65mm;
                height: 20mm;
                padding: 1.5mm 1mm;
            }
            .prod-name {
                font-size: 12.5pt;
                font-weight: bold;
                text-transform: uppercase;
                white-space: nowrap;
            }
            .prod-mrp {
                font-size: 6pt;
                margin-top: 1.5mm;
                white-space: nowrap;
            }

            /* Column gap */
            td.cgap { width: 2mm; border: none; padding: 0; }

            /* Spacer rows */
            tr.igap td { height: 2mm; border: none; padding: 0; }   /* QR↔Name gap */
            tr.rgap td { height: 4mm; border: none; padding: 0; }   /* product pair gap */
        </style>

        <t t-foreach="docs" t-as="wizard">
            <table class="sheet" cellspacing="0" cellpadding="0">

                <t t-foreach="wizard._get_label_rows()" t-as="row">

                    <!-- ── QR ROW ── -->
                    <tr>
                        <t t-foreach="row" t-as="lbl">
                            <td class="lbl lbl-qr">
                                <t t-if="wizard.show_qr">
                                    <img class="qr-img"
                                         t-attf-src="data:image/png;base64,{{ lbl['qr_b64'] }}"
                                         alt="QR" />
                                </t>
                                <t t-if="wizard.show_label_code and lbl['label_code']">
                                    <div class="lbl-code">
                                        <t t-esc="lbl['label_code']"/>
                                    </div>
                                </t>
                            </td>
                            <t t-if="lbl_index == 0"><td class="cgap"/></t>
                        </t>
                    </tr>

                    <!-- ── inner gap between QR label and Name label ── -->
                    <tr class="igap"><td colspan="3"/></tr>

                    <!-- ── NAME ROW ── -->
                    <tr>
                        <t t-foreach="row" t-as="lbl">
                            <td class="lbl lbl-name">
                                <div class="prod-name">
                                    <t t-esc="lbl['name']"/>
                                </div>
                                <t t-if="wizard.show_mrp">
                                    <div class="prod-mrp">
                                        MRP Rs. <t t-esc="lbl['mrp']"/>
                                    </div>
                                </t>
                            </td>
                            <t t-if="lbl_index == 0"><td class="cgap"/></t>
                        </t>
                    </tr>

                    <!-- ── gap before next product pair ── -->
                    <t t-if="not row_last">
                        <tr class="rgap"><td colspan="3"/></tr>
                    </t>

                </t>

            </table>
        </t>

    </t>
</template>
</odoo>

