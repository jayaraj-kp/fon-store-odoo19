<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="product_label_template">
    <t t-call="web.html_container">
        <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { font-family: Arial, Helvetica, sans-serif; background: #fff; }

            .label-page {
                width: 100%;
                display: flex;
                flex-wrap: wrap;
                align-items: flex-start;
            }
            .label-row {
                display: flex;
                flex-direction: row;
                align-items: center;
                page-break-inside: avoid;
                margin-bottom: 1mm;
                width: 100%;
            }
            .label-cell {
                display: inline-flex;
                flex-direction: row;
                align-items: stretch;
                border: 0.5px solid #aaa;
                border-radius: 3mm;
                overflow: hidden;
                background: #fff;
                width: 74mm;
                height: 29mm;
                min-width: 74mm;
            }
            .label-left {
                display: flex;
                flex-direction: row;
                align-items: center;
                padding: 1mm;
                gap: 0.5mm;
                flex-shrink: 0;
            }
            .label-qr img {
                display: block;
                width: 25mm;
                height: 25mm;
            }
            .label-code-vertical {
                writing-mode: vertical-rl;
                text-orientation: mixed;
                transform: rotate(180deg);
                font-size: 5pt;
                font-weight: bold;
                letter-spacing: 0.5px;
                color: #000;
                white-space: nowrap;
                line-height: 1;
            }
            .label-right {
                display: flex;
                flex-direction: column;
                justify-content: flex-end;
                padding: 1mm 1mm 2mm 1mm;
                flex: 1;
            }
            .label-product-name {
                font-size: 6pt;
                font-weight: bold;
                text-transform: uppercase;
                color: #000;
                letter-spacing: 0.3px;
                line-height: 1.3;
                word-break: break-word;
            }
            .label-mrp {
                font-size: 5.5pt;
                color: #000;
                margin-top: 1mm;
                letter-spacing: 0.2px;
            }
            .label-gap {
                width: 2mm;
                flex-shrink: 0;
            }

            @media print {
                @page { margin: 0; padding: 0; }
                body { margin: 0; padding: 0; }
            }
        </style>

        <div class="label-page">
            <t t-set="labels" t-value="data.get('label_data', [])"/>
            <t t-set="col_count" t-value="data.get('columns', 2)"/>
            <t t-set="show_qr" t-value="data.get('show_qr', True)"/>
            <t t-set="show_mrp" t-value="data.get('show_mrp', True)"/>
            <t t-set="show_label_code" t-value="data.get('show_label_code', True)"/>
            <t t-set="total" t-value="len(labels)"/>

            <t t-foreach="range(0, total, col_count)" t-as="row_start">
                <div class="label-row">
                    <t t-set="row_end" t-value="row_start + col_count if row_start + col_count &lt; total else total"/>
                    <t t-foreach="range(row_start, row_end)" t-as="col_idx">
                        <t t-set="lbl" t-value="labels[col_idx]"/>

                        <div class="label-cell">
                            <div class="label-left">
                                <t t-if="show_qr">
                                    <div class="label-qr">
                                        <img t-attf-src="/report/barcode/QR/{{ lbl.get('qr_value', lbl.get('name', 'X')) }}?width=75&amp;height=75"
                                             alt="QR"/>
                                    </div>
                                </t>
                                <t t-if="show_label_code and lbl.get('label_code')">
                                    <div class="label-code-vertical">
                                        <t t-esc="lbl.get('label_code', '')"/>
                                    </div>
                                </t>
                            </div>

                            <div class="label-right">
                                <div class="label-product-name">
                                    <t t-esc="lbl.get('name', '')"/>
                                </div>
                                <t t-if="show_mrp">
                                    <div class="label-mrp">
                                        MRP Rs&#160;&#160;<t t-esc="'%.0f' % (lbl.get('mrp', 0) or 0)"/>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <t t-if="col_idx + 1 &lt; row_end">
                            <div class="label-gap"/>
                        </t>

                    </t>
                </div>
            </t>
        </div>

    </t>
</template>
</odoo>
