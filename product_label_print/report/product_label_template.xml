<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="product_label_template">
    <t t-call="web.html_container">
        <style type="text/css">
            body {
                margin: 0;
                padding: 0;
                font-family: Arial, sans-serif;
                background: white;
            }
            table.label-sheet {
                border-collapse: collapse;
                width: 100%;
            }
            td.label-cell {
                border: 1px solid #888;
                border-radius: 4px;
                width: 73mm;
                height: 28mm;
                padding: 0;
                vertical-align: middle;
            }
            td.label-gap {
                width: 2mm;
                border: none;
                padding: 0;
            }
            tr.label-gap-row {
                height: 1mm;
            }
            table.label-inner {
                border-collapse: collapse;
                width: 100%;
                height: 28mm;
            }
            td.label-qr-cell {
                width: 26mm;
                text-align: center;
                vertical-align: middle;
                padding: 1mm;
            }
            td.label-code-cell {
                width: 6mm;
                text-align: center;
                vertical-align: middle;
                padding: 0;
            }
            .label-code-text {
                display: inline-block;
                writing-mode: vertical-rl;
                text-orientation: mixed;
                transform: rotate(180deg);
                font-size: 5pt;
                font-weight: bold;
                color: #000;
                white-space: nowrap;
            }
            td.label-info-cell {
                vertical-align: bottom;
                padding: 1mm 1mm 2mm 1mm;
            }
            .label-name {
                font-size: 6pt;
                font-weight: bold;
                text-transform: uppercase;
                color: #000;
                display: block;
                line-height: 1.3;
            }
            .label-mrp {
                font-size: 5.5pt;
                color: #000;
                display: block;
                margin-top: 1mm;
            }
        </style>

        <t t-foreach="docs" t-as="wizard">
            <table class="label-sheet" cellspacing="0" cellpadding="0">
                <t t-foreach="wizard._get_label_rows()" t-as="row">
                    <tr>
                        <t t-foreach="row" t-as="lbl">
                            <td class="label-cell">
                                <table class="label-inner" cellspacing="0" cellpadding="0">
                                    <tr>
                                        <!-- QR Code -->
                                        <t t-if="wizard.show_qr">
                                            <td class="label-qr-cell">
                                                <img t-attf-src="/report/barcode/QR/{{ lbl['qr_value'] }}?width=70&amp;height=70"
                                                     style="width:24mm;height:24mm;display:block;margin:auto;"
                                                     alt="QR"/>
                                            </td>
                                        </t>
                                        <!-- Vertical label code -->
                                        <t t-if="wizard.show_label_code and lbl['label_code']">
                                            <td class="label-code-cell">
                                                <span class="label-code-text">
                                                    <t t-esc="lbl['label_code']"/>
                                                </span>
                                            </td>
                                        </t>
                                        <!-- Product name + MRP -->
                                        <td class="label-info-cell">
                                            <span class="label-name">
                                                <t t-esc="lbl['name']"/>
                                            </span>
                                            <t t-if="wizard.show_mrp">
                                                <span class="label-mrp">
                                                    MRP Rs&#160;&#160;<t t-esc="lbl['mrp']"/>
                                                </span>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                            <!-- Gap between labels -->
                            <t t-if="not lbl_last">
                                <td class="label-gap"/>
                            </t>
                        </t>
                    </tr>
                    <!-- Row gap -->
                    <t t-if="not row_last">
                        <tr class="label-gap-row"><td/></tr>
                    </t>
                </t>
            </table>
        </t>

    </t>
</template>
</odoo>
