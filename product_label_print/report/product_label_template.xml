<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="product_label_template">
    <t t-call="web.html_container">
        <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { font-family: Arial, Helvetica, sans-serif; background: #fff; }
            .label-page { width: 100%; }
            .label-row {
                display: flex;
                flex-direction: row;
                align-items: flex-start;
                page-break-inside: avoid;
                margin-bottom: 1mm;
            }
            .label-cell {
                display: inline-flex;
                flex-direction: row;
                align-items: stretch;
                border: 0.5px solid #999;
                border-radius: 3mm;
                overflow: hidden;
                background: #fff;
                width: 73mm;
                height: 28mm;
            }
            .label-left {
                display: flex;
                flex-direction: row;
                align-items: center;
                padding: 1mm;
                gap: 0.5mm;
                flex-shrink: 0;
            }
            .label-qr img {
                display: block;
                width: 24mm;
                height: 24mm;
            }
            .label-code-vertical {
                writing-mode: vertical-rl;
                text-orientation: mixed;
                transform: rotate(180deg);
                font-size: 5pt;
                font-weight: bold;
                color: #000;
                white-space: nowrap;
                line-height: 1;
            }
            .label-right {
                display: flex;
                flex-direction: column;
                justify-content: flex-end;
                padding: 1mm 1mm 2mm 1mm;
                flex: 1;
            }
            .label-product-name {
                font-size: 6pt;
                font-weight: bold;
                text-transform: uppercase;
                color: #000;
                line-height: 1.3;
                word-break: break-word;
            }
            .label-mrp {
                font-size: 5.5pt;
                color: #000;
                margin-top: 1mm;
            }
            .label-gap { width: 2mm; flex-shrink: 0; }
            @media print {
                @page { margin: 0; }
                body { margin: 0; }
            }
        </style>

        <!-- Loop over each wizard record (usually just one) -->
        <t t-foreach="docs" t-as="wizard">
            <t t-set="labels" t-value="wizard._parse_label_data()"/>
            <t t-set="col_count" t-value="int(wizard.columns)"/>
            <t t-set="show_qr" t-value="wizard.show_qr"/>
            <t t-set="show_mrp" t-value="wizard.show_mrp"/>
            <t t-set="show_label_code" t-value="wizard.show_label_code"/>
            <t t-set="total" t-value="len(labels)"/>

            <div class="label-page">
                <t t-set="row_index" t-value="0"/>
                <t t-foreach="labels" t-as="lbl">
                    <!-- Open a new row every col_count labels -->
                    <t t-if="lbl_index % col_count == 0">
                        <div class="label-row">
                    </t>

                    <div class="label-cell">
                        <div class="label-left">
                            <t t-if="show_qr">
                                <div class="label-qr">
                                    <img t-attf-src="/report/barcode/QR/{{ lbl['qr_value'] }}?width=72&amp;height=72"
                                         alt="QR"/>
                                </div>
                            </t>
                            <t t-if="show_label_code and lbl['label_code']">
                                <div class="label-code-vertical">
                                    <t t-esc="lbl['label_code']"/>
                                </div>
                            </t>
                        </div>
                        <div class="label-right">
                            <div class="label-product-name">
                                <t t-esc="lbl['name']"/>
                            </div>
                            <t t-if="show_mrp">
                                <div class="label-mrp">
                                    MRP Rs&#160;&#160;<t t-esc="int(lbl['mrp'])"/>
                                </div>
                            </t>
                        </div>
                    </div>

                    <t t-if="(lbl_index + 1) % col_count != 0 and lbl_index + 1 &lt; total">
                        <div class="label-gap"/>
                    </t>

                    <!-- Close row when full or last item -->
                    <t t-if="(lbl_index + 1) % col_count == 0 or lbl_index + 1 == total">
                        </div><!-- end label-row -->
                    </t>

                </t><!-- end labels loop -->
            </div>
        </t><!-- end docs loop -->
    </t>
</template>
</odoo>
