<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="product_label_template">
    <t t-call="web.html_container">

        <style type="text/css">
            * { margin: 0; padding: 0; box-sizing: border-box; }

            body {
                font-family: Arial, Helvetica, sans-serif;
                background: white;
            }

            table.sheet {
                border-collapse: separate;
                border-spacing: 0;
                width: 132mm;   /* 65 + 2 + 65 */
                margin-left: 10mm;
                table-layout: fixed;
            }

            td.lbl {
                border: 1.5px solid #999;
                border-radius: 3mm;
                background: white;
                width: 65mm;
                height: 55mm;
                padding: 2mm;
                vertical-align: top;
                text-align: center;
            }

            td.cgap {
                width: 2mm;
                border: none;
            }

            tr.rgap td {
                height: 4mm;
                border: none;
            }

            .qr-img {
                width: 22mm;
                height: 22mm;
                display: block;
                margin: 0 auto 1mm auto;
            }

            .lbl-code {
                font-size: 7pt;
                font-weight: bold;
                letter-spacing: 0.3mm;
                margin-top: 1mm;
            }

            .prod-name {
                font-size: 7.5pt;
                font-weight: bold;
                text-transform: uppercase;
                margin-top: 3mm;
                white-space: nowrap;
            }

            .prod-mrp {
                font-size: 6pt;
                margin-top: 1.5mm;
            }

        </style>

        <t t-foreach="docs" t-as="wizard">
            <table class="sheet">

                <t t-foreach="wizard._get_label_rows()" t-as="row">

                    <!-- ONE ROW = TWO PRODUCTS -->
                    <tr>
                        <t t-foreach="row" t-as="lbl">

                            <td class="lbl">

                                <!-- QR SECTION -->
                                <t t-if="wizard.show_qr">
                                    <img class="qr-img"
                                         t-attf-src="data:image/png;base64,{{ lbl['qr_b64'] }}"
                                         alt="QR"/>
                                </t>

                                <!-- LABEL CODE -->
                                <t t-if="wizard.show_label_code and lbl['label_code']">
                                    <div class="lbl-code">
                                        <t t-esc="lbl['label_code']"/>
                                    </div>
                                </t>

                                <!-- PRODUCT NAME -->
                                <div class="prod-name">
                                    <t t-esc="lbl['name']"/>
                                </div>

                                <!-- PRICE -->
                                <t t-if="wizard.show_mrp">
                                    <div class="prod-mrp">
                                        MRP Rs. <t t-esc="lbl['mrp']"/>
                                    </div>
                                </t>

                            </td>

                            <!-- GAP BETWEEN 2 LABELS -->
                            <t t-if="lbl_index == 0">
                                <td class="cgap"/>
                            </t>

                        </t>
                    </tr>

                    <!-- GAP BETWEEN ROWS -->
                    <t t-if="not row_last">
                        <tr class="rgap">
                            <td colspan="3"></td>
                        </tr>
                    </t>

                </t>

            </table>
        </t>

    </t>
</template>
</odoo>