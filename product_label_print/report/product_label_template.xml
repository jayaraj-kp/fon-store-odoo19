<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="product_label_template">
    <t t-call="web.html_container">
        <style type="text/css">
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { font-family: Arial, Helvetica, sans-serif; background: white; }

            table.sheet {
                border-collapse: separate;
                border-spacing: 0;
                width: 142mm;       /* 65mm label + 12mm gap + 65mm label */
                margin-left: 5mm;
                table-layout: fixed;
            }

            /* Each label cell wrapper */
            td.lbl {
                width: 65mm;
                border: 1.5px solid #888;
                border-radius: 3mm;
                background: white;
                overflow: hidden;
                vertical-align: top;
                text-align: center;
                padding: 3mm 2mm 2mm 2mm;
            }

            /* QR / barcode image */
            .qr-img {
                width: 54mm;
                height: 20mm;
                display: block;
                margin: 0 auto 1mm auto;
            }

            /* Small reference code below barcode */
            .lbl-code {
                font-size: 6pt;
                letter-spacing: 0.2mm;
                white-space: nowrap;
                text-align: left;
                margin-bottom: 1mm;
                padding-left: 1mm;
            }

            /* Product name */
            .prod-name {
                font-size: 12pt;
                font-weight: bold;
                text-transform: uppercase;
                white-space: nowrap;
                text-align: center;
            }

            /* MRP line */
            .prod-mrp {
                font-size: 9pt;
                font-weight: bold;
                margin-top: 1mm;
                text-align: right;
                white-space: nowrap;
            }

            /* Column gap between two labels */
            td.cgap { width: 12mm; border: none; padding: 0; }

            /* Row gap between product rows */
            tr.rgap td { height: 4mm; border: none; padding: 0; }
        </style>

        <t t-foreach="docs" t-as="wizard">
            <table class="sheet" cellspacing="0" cellpadding="0">

                <t t-foreach="wizard._get_label_rows()" t-as="row">

                    <!-- ── LABEL ROW: each label is a single cell ── -->
                    <tr>
                        <t t-foreach="row" t-as="lbl">

                            <td class="lbl">
                                <!-- QR / barcode image -->
                                <t t-if="wizard.show_qr">
                                    <img class="qr-img"
                                         t-attf-src="data:image/png;base64,{{ lbl['qr_b64'] }}"
                                         alt="QR" />
                                </t>

                                <!-- Reference code (default_code) below image -->
                                <t t-if="wizard.show_label_code and lbl['label_code']">
                                    <div class="lbl-code">
                                        <t t-esc="lbl['label_code']"/>
                                    </div>
                                </t>

                                <!-- Product name -->
                                <div class="prod-name">
                                    <t t-esc="lbl['name']"/>
                                </div>

                                <!-- MRP -->
                                <t t-if="wizard.show_mrp">
                                    <div class="prod-mrp">
                                        MRP Rs.<t t-esc="lbl['mrp']"/>
                                    </div>
                                </t>
                            </td>

                            <!-- Gap between left and right label -->
                            <t t-if="lbl_index == 0">
                                <td class="cgap"/>
                            </t>

                        </t>
                    </tr>

                    <!-- ── Row gap before next product row ── -->
                    <t t-if="not row_last">
                        <tr class="rgap"><td colspan="3"/></tr>
                    </t>

                </t>

            </table>
        </t>

    </t>
</template>
</odoo>


