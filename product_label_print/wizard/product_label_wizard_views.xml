<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_label_wizard_view_form" model="ir.ui.view">
        <field name="name">product.label.wizard.form</field>
        <field name="model">product.label.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Product Labels">
                <sheet>
                    <group string="Products">
                        <field name="product_tmpl_ids" widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="Select product templates..."/>
                        <field name="product_ids" widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="Or select product variants..."/>
                    </group>
                    <group string="Label Settings">
                        <group>
                            <field name="label_type" widget="radio"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="show_qr"/>
                            <field name="show_label_code"/>
                            <field name="show_mrp"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_labels" type="object"
                            string="Print Labels" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard standalone (from menu) -->
    <record id="action_product_label_wizard" model="ir.actions.act_window">
        <field name="name">Print Product Labels</field>
        <field name="res_model">product.label.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu item under Inventory > Operations -->
    <menuitem id="menu_product_label_print"
              name="Print Product Labels"
              parent="stock.menu_stock_warehouse_mgmt"
              action="action_product_label_wizard"
              sequence="50"/>

</odoo>


