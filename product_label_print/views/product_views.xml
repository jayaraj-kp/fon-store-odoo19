<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Label Code field to product template form -->
    <record id="view_product_template_form_label" model="ir.ui.view">
        <field name="name">product.template.form.label.code</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Add Print Labels button in header -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_print_labels"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tag"
                        string="Print Labels"/>
            </xpath>
            <!-- Add Label Code field after product name (safe location in all Odoo 19 product views) -->
<!--            <xpath expr="//field[@name='name']" position="after">-->
<!--                <field name="label_code"-->
<!--                       placeholder="e.g. KC110"-->
<!--                       help="Short code shown on printed label. If empty, uses internal reference."/>-->
<!--            </xpath>-->
        </field>
    </record>

    <!-- Also add Print Labels to product.product list action -->
    <record id="action_print_labels_from_product_list" model="ir.actions.server">
        <field name="name">Print Labels</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = {
        'type': 'ir.actions.act_window',
        'name': 'Print Product Labels',
        'res_model': 'product.label.wizard',
        'view_mode': 'form',
        'target': 'new',
        'context': {
            'default_product_tmpl_ids': records.ids,
        },
    }
    action = action
        </field>
    </record>

</odoo>
