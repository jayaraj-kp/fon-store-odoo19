<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="product_label_print.ProductLabelPrintDialog">
    <Dialog title="dialogTitle" size="'xl'" contentClass="'plpd-dialog-content p-0'" footer="false" close.bind="onClose">

        <div class="plpd-body d-flex" style="height: 82vh; overflow: hidden;">

            <!-- ── LEFT: PDF Preview ──────────────────────────────────── -->
            <div class="plpd-preview-panel d-flex flex-column flex-grow-1" style="min-width:0; background:#525659;">

                <div class="plpd-preview-toolbar d-flex align-items-center px-3 py-2 gap-2"
                     style="background:#3c3f41; color:#ccc; font-size:13px; flex-shrink:0;">
                    <i class="fa fa-file-pdf-o text-danger"/>
                    <span class="fw-semibold">Preview</span>
                    <span class="ms-auto text-muted small" t-if="!state.loading and !state.loadError">PDF Report</span>
                </div>

                <div t-if="state.loading" class="d-flex align-items-center justify-content-center flex-grow-1">
                    <div class="text-center text-white">
                        <i class="fa fa-spinner fa-spin fa-3x mb-3" style="color:#aaa;"/>
                        <p style="color:#ccc;">Generating preview...</p>
                    </div>
                </div>

                <div t-elif="state.loadError" class="d-flex align-items-center justify-content-center flex-grow-1">
                    <div class="text-center text-white p-4">
                        <i class="fa fa-exclamation-triangle fa-3x mb-3 text-warning"/>
                        <p>Could not load the PDF preview.</p>
                        <p class="small" style="color:#aaa;">Please check that the product data is correct.</p>
                    </div>
                </div>

                <iframe
                    t-ref="previewIframe"
                    t-att-src="pdfPreviewUrl"
                    t-on-load="onIframeLoad"
                    t-on-error="onIframeError"
                    t-att-class="state.loading
                        ? 'plpd-iframe plpd-iframe--hidden border-0 w-100 flex-grow-1'
                        : 'plpd-iframe border-0 w-100 flex-grow-1'"
                    title="Product Labels Preview"
                />
            </div>

            <!-- ── RIGHT: Settings ────────────────────────────────────── -->
            <div class="plpd-settings-panel d-flex flex-column border-start"
                 style="width:320px; min-width:290px; background:#fff;">

                <div class="plpd-settings-header px-3 py-2 border-bottom" style="background:#f8f9fa; flex-shrink:0;">
                    <span class="fw-bold" style="font-size:14px;">
                        <i class="fa fa-print me-2 text-primary"/>Print Labels
                    </span>
                </div>

                <div class="plpd-settings-body flex-grow-1 overflow-auto px-3 py-3" style="font-size:13px;">

                    <!-- Summary -->
                    <div class="plpd-group mb-3">
                        <div class="plpd-group-label">Summary</div>
                        <div class="border rounded px-3 py-2 bg-light">
                            <i class="fa fa-tag me-1 text-primary"/>
                            <strong t-esc="props.productCount"/> product(s) ×
                            <strong t-esc="props.labelQty"/> cop<t t-if="props.labelQty == 1">y</t><t t-else="">ies</t>
                            = <strong t-esc="props.productCount * props.labelQty"/> label(s) total
                        </div>
                    </div>

                    <!-- Destination -->
                    <div class="plpd-group mb-3">
                        <div class="plpd-group-label">Destination</div>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#f8f9fa;">
                                <i t-att-class="saveButtonIcon + (state.saving ? '' : ' text-danger')"/>
                            </span>
                            <select class="form-select" t-att-disabled="state.saving">
                                <option value="pdf" selected="1">Save as PDF</option>
                            </select>
                        </div>
                    </div>

                    <!-- Destination Location -->
                    <div class="plpd-group mb-4">
                        <div class="plpd-group-label">Destination Location</div>
                        <div class="input-group">
                            <input type="text"
                                   class="form-control"
                                   readonly="1"
                                   t-att-placeholder="locationPlaceholder"
                                   t-att-value="state.savePath"
                                   style="background:#fff; cursor:default;"/>
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    title="Choose save location"
                                    t-att-disabled="state.saving"
                                    t-on-click="onChooseLocation">
                                <i class="fa fa-folder-open-o"/>
                            </button>
                        </div>
                        <div class="mt-1" style="font-size:11px; line-height:1.5;">
                            <t t-if="state.savePath">
                                <span class="text-success">
                                    <i class="fa fa-check-circle me-1"/>
                                    Location selected — click <strong t-esc="saveButtonLabel"/> to save
                                </span>
                            </t>
                            <t t-else="">
                                <span class="text-muted">
                                    <i class="fa fa-info-circle me-1"/>
                                    Click <i class="fa fa-folder-open-o mx-1"/> to choose where to save
                                </span>
                            </t>
                        </div>
                    </div>

                    <!-- Pages -->
                    <div class="plpd-group mb-4">
                        <div class="plpd-group-label">Pages</div>
                        <div class="border rounded bg-white">
                            <label class="plpd-radio-row border-bottom d-flex align-items-center gap-2 px-3 py-2 m-0" style="cursor:pointer;">
                                <input type="radio" name="plp_pages" class="form-check-input m-0 flex-shrink-0" checked="1"/>
                                <span>All</span>
                            </label>
                        </div>
                    </div>

                    <!-- Layout -->
                    <div class="plpd-group mb-4">
                        <div class="plpd-group-label">Layout</div>
                        <div class="border rounded bg-white">
                            <label class="plpd-radio-row d-flex align-items-center gap-2 px-3 py-2 m-0" style="cursor:pointer;">
                                <input type="radio" name="plp_layout" class="form-check-input m-0 flex-shrink-0" checked="1"/>
                                <i class="fa fa-file-o fa-rotate-90" style="width:14px;"/>
                                <span>Landscape (label format)</span>
                            </label>
                        </div>
                    </div>

                    <!-- Copies -->
                    <div class="plpd-group mb-3">
                        <div class="plpd-group-label">Copies per Product</div>
                        <input type="number" class="form-control" readonly="1"
                               t-att-value="props.labelQty" min="1" max="99"/>
                        <div class="mt-1 text-muted" style="font-size:11px;">
                            To change copies, cancel and re-open the wizard.
                        </div>
                    </div>

                </div>

                <!-- Footer buttons -->
                <div class="plpd-settings-footer border-top p-3 d-flex flex-column gap-2"
                     style="background:#fafafa; flex-shrink:0;">

                    <button class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2"
                            t-att-disabled="state.saving"
                            t-on-click="onSave">
                        <i t-att-class="saveButtonIcon"/>
                        <span t-esc="saveButtonLabel"/>
                    </button>

                    <button class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2"
                            t-att-disabled="state.saving"
                            t-on-click="onPrint">
                        <i class="fa fa-print"/>
                        <span>Print Directly</span>
                        <span class="badge bg-primary ms-1" t-if="props.labelQty > 1">
                            × <t t-esc="props.labelQty"/> copies
                        </span>
                    </button>

                    <button class="btn btn-outline-secondary w-100"
                            t-att-disabled="state.saving"
                            t-on-click="onClose">
                        Cancel
                    </button>

                </div>
            </div>

        </div>
    </Dialog>
</t>

</templates>